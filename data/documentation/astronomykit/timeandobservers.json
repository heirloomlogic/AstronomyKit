{"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Work with astronomical time and geographic observer locations."}],"sections":[],"seeAlsoSections":[{"anchor":"Essentials","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted"],"generated":true,"title":"Essentials"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Accurate time handling is fundamental to astronomy. AstronomyKit provides "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","isActive":true},{"type":"text","text":" for precise time representation and "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","isActive":true},{"type":"text","text":" for geographic locations."}]},{"type":"heading","text":"Working with Time","level":2,"anchor":"Working-with-Time"},{"type":"heading","text":"Creating Times","level":3,"anchor":"Creating-Times"},{"type":"codeListing","syntax":"swift","code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From calendar components (in UTC)","let eclipse = AstroTime(year: 2024, month: 4, day: 8, hour: 18, minute: 15)","","\/\/ From Foundation Date","let time = AstroTime(Date())","","\/\/ From Julian days since J2000","let jd = AstroTime(ut: 9132.5)"]},{"type":"heading","text":"Time Arithmetic","level":3,"anchor":"Time-Arithmetic"},{"type":"codeListing","syntax":"swift","code":["let now = AstroTime.now","","\/\/ Add days or hours","let tomorrow = now.addingDays(1)","let nextHour = now.addingHours(1)","let lastWeek = now.addingDays(-7)","","\/\/ Compare times","if tomorrow > now {","    print(\"Tomorrow comes after now\")","}"]},{"type":"heading","text":"Converting to Date","level":3,"anchor":"Converting-to-Date"},{"type":"codeListing","syntax":"swift","code":["let time = AstroTime.now","let date: Date = time.date","","\/\/ Format for display","let formatter = DateFormatter()","formatter.dateStyle = .medium","formatter.timeStyle = .short","print(formatter.string(from: time.date))"]},{"type":"heading","text":"Understanding UT vs TT","level":3,"anchor":"Understanding-UT-vs-TT"},{"type":"paragraph","inlineContent":[{"text":"AstroTime stores two time values internally:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Universal Time (UT)"}]},{"type":"text","text":": Based on Earth’s rotation, used for rise\/set times"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Terrestrial Time (TT)","type":"text"}],"type":"strong"},{"text":": Uniform time scale, used for planetary orbits","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["let time = AstroTime.now","print(\"UT: \\(time.ut)\")  \/\/ Days since J2000 noon (UTC)","print(\"TT: \\(time.tt)\")  \/\/ Days since J2000 noon (TT)"]},{"type":"paragraph","inlineContent":[{"text":"The difference (ΔT) is automatically handled by AstronomyKit.","type":"text"}]},{"type":"heading","text":"Sidereal Time","level":3,"anchor":"Sidereal-Time"},{"type":"paragraph","inlineContent":[{"text":"Get the sidereal time at the prime meridian:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sidereal = AstroTime.now.siderealTime","print(\"Greenwich Sidereal Time: \\(sidereal) hours\")"]},{"type":"paragraph","inlineContent":[{"text":"Calculate local sidereal time for any longitude:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)  \/\/ NYC","let lst = AstroTime.now.siderealTime(longitude: observer.longitude)","print(\"Local Sidereal Time: \\(lst) hours\")"]},{"type":"heading","text":"Working with Observers","level":2,"anchor":"Working-with-Observers"},{"type":"heading","text":"Creating Observers","level":3,"anchor":"Creating-Observers"},{"type":"codeListing","syntax":"swift","code":["\/\/ Basic location (sea level)","let seattle = Observer(latitude: 47.6062, longitude: -122.3321)","","\/\/ With height above sea level (meters)","let everest = Observer(","    latitude: 27.9881,","    longitude: 86.9250,","    height: 8848.86",")"]},{"type":"heading","text":"Coordinate Conventions","level":3,"anchor":"Coordinate-Conventions"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Latitude","type":"text"}],"type":"strong"},{"type":"text","text":": -90° (south) to +90° (north)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Longitude","type":"text"}]},{"type":"text","text":": -180° (west) to +180° (east)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Height"}]},{"type":"text","text":": Meters above sea level"}]}]}]},{"type":"heading","text":"Built-in Locations","level":3,"anchor":"Built-in-Locations"},{"type":"codeListing","syntax":"swift","code":["let greenwich = Observer.greenwich       \/\/ Royal Observatory","let primeMeridian = Observer.primeMeridian  \/\/ 0°, 0°"]},{"type":"heading","text":"Observer Properties","level":3,"anchor":"Observer-Properties"},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.0, longitude: -105.0, height: 1600)","","\/\/ Local gravity (accounts for latitude and altitude)","let gravity = observer.gravity  \/\/ m\/s²","","\/\/ Atmospheric conditions at this elevation","let atmosphere = try observer.atmosphere","print(\"Pressure: \\(atmosphere.pressure) mbar\")"]},{"type":"heading","text":"Observer Vectors","level":3,"anchor":"Observer-Vectors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the observer’s position relative to Earth’s center:"}]},{"type":"codeListing","syntax":"swift","code":["le