{"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Essentials","title":"Essentials","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted"]}],"kind":"article","abstract":[{"text":"Work with astronomical time and geographic observer locations.","type":"text"}],"metadata":{"title":"Time and Observers","role":"article","modules":[{"name":"AstronomyKit"}],"roleHeading":"Article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/timeandobservers"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Accurate time handling is fundamental to astronomy. AstronomyKit provides ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","type":"reference","isActive":true},{"text":" for precise time representation and ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","type":"reference","isActive":true},{"text":" for geographic locations.","type":"text"}],"type":"paragraph"},{"text":"Working with Time","level":2,"type":"heading","anchor":"Working-with-Time"},{"text":"Creating Times","level":3,"type":"heading","anchor":"Creating-Times"},{"syntax":"swift","code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From calendar components (in UTC)","let eclipse = AstroTime(year: 2024, month: 4, day: 8, hour: 18, minute: 15)","","\/\/ From Foundation Date","let time = AstroTime(Date())","","\/\/ From Julian days since J2000","let jd = AstroTime(ut: 9132.5)"],"type":"codeListing"},{"text":"Time Arithmetic","level":3,"type":"heading","anchor":"Time-Arithmetic"},{"syntax":"swift","code":["let now = AstroTime.now","","\/\/ Add days or hours","let tomorrow = now.addingDays(1)","let nextHour = now.addingHours(1)","let lastWeek = now.addingDays(-7)","","\/\/ Compare times","if tomorrow > now {","    print(\"Tomorrow comes after now\")","}"],"type":"codeListing"},{"text":"Converting to Date","level":3,"type":"heading","anchor":"Converting-to-Date"},{"syntax":"swift","code":["let time = AstroTime.now","let date: Date = time.date","","\/\/ Format for display","let formatter = DateFormatter()","formatter.dateStyle = .medium","formatter.timeStyle = .short","print(formatter.string(from: time.date))"],"type":"codeListing"},{"text":"Understanding UT vs TT","level":3,"type":"heading","anchor":"Understanding-UT-vs-TT"},{"inlineContent":[{"text":"AstroTime stores two time values internally:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Universal Time (UT)","type":"text"}],"type":"strong"},{"type":"text","text":": Based on Earth’s rotation, used for rise\/set times"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Terrestrial Time (TT)","type":"text"}]},{"text":": Uniform time scale, used for planetary orbits","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","code":["let time = AstroTime.now","print(\"UT: \\(time.universalTime)\")  \/\/ Days since J2000 noon (UTC)","print(\"TT: \\(time.terrestrialTime)\")  \/\/ Days since J2000 noon (TT)","","\/\/ Create from Terrestrial Time directly","let fromTT = AstroTime(tt: 9132.5)"],"type":"codeListing"},{"inlineContent":[{"text":"The difference (ΔT) is automatically handled by AstronomyKit.","type":"text"}],"type":"paragraph"},{"text":"Delta T Configuration","level":3,"type":"heading","anchor":"Delta-T-Configuration"},{"inlineContent":[{"type":"text","text":"The difference between TT and UT (called ΔT) varies over time and is estimated"},{"type":"text","text":" "},{"type":"text","text":"using a model. AstronomyKit defaults to the Espenak-Meeus model, but you can"},{"type":"text","text":" "},{"type":"text","text":"switch to JPL Horizons for compatibility:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Switch to JPL Horizons Delta T model","AstronomyConfig.setDeltaTModel(.jplHorizons)","","\/\/ Query Delta T for a specific time","let deltaT = AstronomyConfig.deltaTEspenakMeeus(universalTime: 0)  \/\/ Seconds at J2000","","\/\/ Reset to defaults","AstronomyConfig.reset()"],"type":"codeListing"},{"text":"Sidereal Time","level":3,"type":"heading","anchor":"Sidereal-Time"},{"inlineContent":[{"text":"Get the sidereal time at the prime meridian:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let sidereal = AstroTime.now.siderealTime","print(\"Greenwich Sidereal Time: \\(sidereal) hours\")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Calculate local sidereal time for any longitude:"}],"type":"paragraph"},{"syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)  \/\/ NYC","let lst = AstroTime.now.siderealTime(longitude: observer.longitude)","print(\"Local Sidereal Time: \\(lst) hours\")"],"type":"codeListing"},{"text":"Working with Observers","level":2,"type":"heading","anchor":"Working-with-Observers"},{"text":"Creating Observers","level":3,"type":"heading","anchor":"Creating-Observers"},{"syntax":"swift","code":["\/\/ Basic location (sea level)","let seattle = Observer(latitude: 47.6062, longitude: -122.3321)","","\/\/ With height above sea level (meters)","let everest = Observer(","    latitude: 27.9881,","    longitude: 86.9250,","    height: 8848.86",")"],"type":"codeListing"},{"text":"Coordinate Conventions","level":3,"type":"heading","anchor":"Coordinate-Conventions"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Latitude","type":"text"}]},{"text":": -90° (south) to +90° (north)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Longitude"}]},{"text":": -180° (west) to +180° (east)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Height"}],"type":"strong"},{"text":": Meters above sea level","type":"text"}]}]}],"type":"unorderedList"},{"text":"Built-in Locations","level":3,"type":"heading","anchor":"Built-in-Locations"},{"syntax":"swift","code":["let greenwich = Observer.greenwich       \/\/ Royal Observatory","let primeMeridian = Observer.primeMeridian  \/\/ 0°, 0°"],"type":"codeListing"},{"text":"Observer Properties","level":3,"type":"heading","anchor":"Observer-Properties"},{"syntax":"swift","code":["let observer = Observer(latitude: 40.0, longitude: -105.0, height: 1600)","","\/\/ Local gravity (accounts for latitude and altitude)","let gravity = observer.gravity  \/\/ m\/s²","","\/\/ Atmospheric conditions at this elevation","let atmosphere = try observer.atmosphere","print(\"Pressure: \\(atmosphere.pressure) mbar\")"],"type":"codeListing"},{"text":"Observer Vectors","level":3,"type":"heading","anchor":"Observer-Vectors"},{"inlineContent":[{"type":"text","text":"Get the observer’s position relative to Earth’s center:"}],"type":"paragraph"},{"syntax":"swift","code":["let observer = Observer.greenwich","","\/\/ Position vector in AU","let position = try observer.vector(at: .now)","","\/\/ Full state (position and velocity)","let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")"],"type":"codeListing"},{"text":"Time Zones","level":2,"type":"heading","anchor":"Time-Zones"},{"inlineContent":[{"type":"text","text":"AstronomyKit works entirely in UTC. Convert to local time using Foundation:"}],"type":"paragraph"},{"syntax":"swift","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise (local): \\(formatter.string(from: sunrise.date))\")"],"type":"codeListing"},{"text":"Codable Support","level":2,"type":"heading","anchor":"Codable-Support"},{"inlineContent":[{"text":"Both types support ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":" for persistence:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)","let data = try JSONEncoder().encode(observer)","","let time = AstroTime.now","let timeData = try JSONEncoder().encode(time)"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://AstronomyKit/documentation/AstronomyKit":{"role":"collection","type":"topic","url":"\/documentation\/astronomykit","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","title":"AstronomyKit","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","isActive":true,"type":"reference"},{"text":" library.","type":"text"}]},"doc://AstronomyKit/documentation/AstronomyKit/GettingStarted":{"url":"\/documentation\/astronomykit\/gettingstarted","title":"Getting Started with AstronomyKit","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted","abstract":[{"text":"Learn how to add AstronomyKit to your project and perform basic astronomical calculations.","type":"text"}],"kind":"article","type":"topic","role":"article"},"https://github.com/cosinekitty/astronomy":{"type":"link","title":"Astronomy Engine","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy"},"doc://AstronomyKit/documentation/AstronomyKit/AstroTime":{"navigatorTitle":[{"text":"AstroTime","kind":"identifier"}],"url":"\/documentation\/astronomykit\/astrotime","type":"topic","kind":"symbol","identifier":"doc:\/\/Astronomy