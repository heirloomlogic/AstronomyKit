{"metadata":{"modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article","title":"Time and Observers"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"type":"text","text":"Work with astronomical time and geographic observer locations."}],"seeAlsoSections":[{"generated":true,"anchor":"Essentials","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted"],"title":"Essentials"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"Accurate time handling is fundamental to astronomy. AstronomyKit provides "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","isActive":true,"type":"reference"},{"type":"text","text":" for precise time representation and "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","isActive":true},{"type":"text","text":" for geographic locations."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Working with Time","anchor":"Working-with-Time"},{"type":"heading","level":3,"text":"Creating Times","anchor":"Creating-Times"},{"syntax":"swift","type":"codeListing","code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From calendar components (in UTC)","let eclipse = AstroTime(year: 2024, month: 4, day: 8, hour: 18, minute: 15)","","\/\/ From Foundation Date","let time = AstroTime(Date())","","\/\/ From Julian days since J2000","let jd = AstroTime(ut: 9132.5)"]},{"type":"heading","level":3,"text":"Time Arithmetic","anchor":"Time-Arithmetic"},{"syntax":"swift","type":"codeListing","code":["let now = AstroTime.now","","\/\/ Add days or hours","let tomorrow = now.addingDays(1)","let nextHour = now.addingHours(1)","let lastWeek = now.addingDays(-7)","","\/\/ Compare times","if tomorrow > now {","    print(\"Tomorrow comes after now\")","}"]},{"type":"heading","level":3,"text":"Converting to Date","anchor":"Converting-to-Date"},{"syntax":"swift","type":"codeListing","code":["let time = AstroTime.now","let date: Date = time.date","","\/\/ Format for display","let formatter = DateFormatter()","formatter.dateStyle = .medium","formatter.timeStyle = .short","print(formatter.string(from: time.date))"]},{"type":"heading","level":3,"text":"Understanding UT vs TT","anchor":"Understanding-UT-vs-TT"},{"inlineContent":[{"type":"text","text":"AstroTime stores two time values internally:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Universal Time (UT)"}],"type":"strong"},{"type":"text","text":": Based on Earth’s rotation, used for rise\/set times"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Terrestrial Time (TT)"}],"type":"strong"},{"text":": Uniform time scale, used for planetary orbits","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":"swift","code":["let time = AstroTime.now","print(\"UT: \\(time.universalTime)\")  \/\/ Days since J2000 noon (UTC)","print(\"TT: \\(time.terrestrialTime)\")  \/\/ Days since J2000 noon (TT)","","\/\/ Create from Terrestrial Time directly","let fromTT = AstroTime(tt: 9132.5)"]},{"type":"paragraph","inlineContent":[{"text":"The difference (ΔT) is automatically handled by AstronomyKit.","type":"text"}]},{"type":"heading","anchor":"Delta-T-Configuration","level":3,"text":"Delta T Configuration"},{"type":"paragraph","inlineContent":[{"text":"The difference between TT and UT (called ΔT) varies over time and is estimated","type":"text"},{"text":" ","type":"text"},{"text":"using a model. AstronomyKit defaults to the Espenak-Meeus model, but you can","type":"text"},{"text":" ","type":"text"},{"text":"switch to JPL Horizons for compatibility:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Switch to JPL Horizons Delta T model","AstronomyConfig.setDeltaTModel(.jplHorizons)","","\/\/ Query Delta T for a specific time","let deltaT = AstronomyConfig.deltaTEspenakMeeus(universalTime: 0)  \/\/ Seconds at J2000","","\/\/ Reset to defaults","AstronomyConfig.reset()"]},{"type":"heading","anchor":"Sidereal-Time","level":3,"text":"Sidereal Time"},{"type":"paragraph","inlineContent":[{"text":"Get the sidereal time at the prime meridian:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sidereal = AstroTime.now.siderealTime","print(\"Greenwich Sidereal Time: \\(sidereal) hours\")"]},{"type":"paragraph","inlineContent":[{"text":"Calculate local sidereal time for any longitude:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)  \/\/ NYC","let lst = AstroTime.now.siderealTime(longitude: observer.longitude)","print(\"Local Sidereal Time: \\(lst) hours\")"]},{"type":"heading","anchor":"Working-with-Observers","level":2,"text":"Working with Observers"},{"type":"heading","anchor":"Creating-Observers","level":3,"text":"Creating Observers"},{"type":"codeListing","syntax":"swift","code":["\/\/ Basic location (sea level)","let seattle = Observer(latitude: 47.6062, longitude: -122.3321)","","\/\/ With height above sea level (meters)","let everest = Observer(","    latitude: 27.9881,","    longitude: 86.9250,","    height: 8848.86",")"]},{"type":"heading","anchor":"Coordinate-Conventions","level":3,"text":"Coordinate Conventions"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Latitude"}],"type":"strong"},{"text":": -90° (south) to +90° (north)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Longitude"}],"type":"strong"},{"text":": -180° (west) to +180° (east)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Height"}],"type":"strong"},{"text":": Meters above sea level","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Built-in-Locations","level":3,"text":"Built-in Locations"},{"type":"codeListing","syntax":"swift","code":["let greenwich = Observer.greenwich       \/\/ Royal Observatory","let primeMeridian = Observer.primeMeridian  \/\/ 0°, 0°"]},{"type":"heading","anchor":"Observer-Properties","level":3,"text":"Observer Properties"},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.0, longitude: -105.0, height: 1600)","","\/\/ Local gravity (accounts for latitude and altitude)","let gravity = observer.gravity  \/\/ m\/s²","","\/\/ Atmospheric conditions at this elevation","let atmosphere = try observer.atmosphere","print(\"Pressure: \\(atmosphere.pressure) mbar\")"]},{"type":"heading","anchor":"Observer-Vectors","level":3,"text":"Observer Vectors"},{"type":"paragraph","inlineContent":[{"text":"Get the observer’s position relative to Earth’s center:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer.greenwich","","\/\/ Position vector in AU","let position = try observer.vector(at: .now)","","\/\/ Full state (position and velocity)","let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")"]},{"type":"heading","anchor":"Time-Zones","level":2,"text":"Time Zones"},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit works entirely in UTC. Convert to local time using Foundation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise (local): \\(formatter.string(from: sunrise.date))\")"]},{"type":"heading","anchor":"Codable-Support","level":2,"text":"Codable Support"},{"type":"paragraph","inlineContent":[{"text":"Both types support ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":" for persistence:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)","let data = try JSONEncoder().encode(observer)","","let time = AstroTime.now","let timeData = try JSONEncoder().encode(time)"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers","interfaceLanguage":"swift"},"kind":"article","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/timeandobservers"]}],"references":{"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"navigatorTitle":[{"kind":"identifier","text":"Observer"}],"abstract":[{"type":"text","text":"A geographic location for observing celestial objects."}],"type":"topic","role":"symbol","title":"Observer","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","url":"\/documentation\/astronomykit\/observer","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Observer","kind":"identifier"}],"kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/GettingStarted":{"abstract":[{"type":"text","text":"Learn how to add AstronomyKit to your project and perform basic astronomical calculations."}],"title":"Getting Started with AstronomyKit","role":"article","type":"topic","kind":"article","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted","url":"\/documentation\/astronomykit\/gettingstarted"},"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link"},"doc://AstronomyKit/documentation/AstronomyKit":{"type":"topic","abstract":[{"type":"text","text":"Swift bindings for Don Cross’ "},{"type":"r