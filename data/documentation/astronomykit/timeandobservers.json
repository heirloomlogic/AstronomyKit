{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","metadata":{"title":"Time and Observers","modules":[{"name":"AstronomyKit"}],"role":"article","roleHeading":"Article"},"variants":[{"paths":["\/documentation\/astronomykit\/timeandobservers"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Accurate time handling is fundamental to astronomy. AstronomyKit provides "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","isActive":true},{"type":"text","text":" for precise time representation and "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","isActive":true},{"type":"text","text":" for geographic locations."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Working with Time","anchor":"Working-with-Time"},{"level":3,"type":"heading","text":"Creating Times","anchor":"Creating-Times"},{"code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From calendar components (in UTC)","let eclipse = AstroTime(year: 2024, month: 4, day: 8, hour: 18, minute: 15)","","\/\/ From Foundation Date","let time = AstroTime(Date())","","\/\/ From Julian days since J2000","let jd = AstroTime(ut: 9132.5)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Time Arithmetic","anchor":"Time-Arithmetic"},{"code":["let now = AstroTime.now","","\/\/ Add days or hours","let tomorrow = now.addingDays(1)","let nextHour = now.addingHours(1)","let lastWeek = now.addingDays(-7)","","\/\/ Compare times","if tomorrow > now {","    print(\"Tomorrow comes after now\")","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Converting to Date","anchor":"Converting-to-Date"},{"code":["let time = AstroTime.now","let date: Date = time.date","","\/\/ Format for display","let formatter = DateFormatter()","formatter.dateStyle = .medium","formatter.timeStyle = .short","print(formatter.string(from: time.date))"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Understanding UT vs TT","anchor":"Understanding-UT-vs-TT"},{"inlineContent":[{"type":"text","text":"AstroTime stores two time values internally:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Universal Time (UT)","type":"text"}]},{"type":"text","text":": Based on Earth’s rotation, used for rise\/set times"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Terrestrial Time (TT)","type":"text"}]},{"type":"text","text":": Uniform time scale, used for planetary orbits"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["let time = AstroTime.now","print(\"UT: \\(time.universalTime)\")  \/\/ Days since J2000 noon (UTC)","print(\"TT: \\(time.terrestrialTime)\")  \/\/ Days since J2000 noon (TT)","","\/\/ Create from Terrestrial Time directly","let fromTT = AstroTime(tt: 9132.5)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The difference (ΔT) is automatically handled by AstronomyKit."}]},{"type":"heading","anchor":"Delta-T-Configuration","text":"Delta T Configuration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The difference between TT and UT (called ΔT) varies over time and is estimated"},{"type":"text","text":" "},{"type":"text","text":"using a model. AstronomyKit defaults to the Espenak-Meeus model, but you can"},{"type":"text","text":" "},{"type":"text","text":"switch to JPL Horizons for compatibility:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Switch to JPL Horizons Delta T model","AstronomyConfig.setDeltaTModel(.jplHorizons)","","\/\/ Query Delta T for a specific time","let deltaT = AstronomyConfig.deltaTEspenakMeeus(universalTime: 0)  \/\/ Seconds at J2000","","\/\/ Reset to defaults","AstronomyConfig.reset()"]},{"type":"heading","anchor":"Sidereal-Time","text":"Sidereal Time","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the sidereal time at the prime meridian:"}]},{"type":"codeListing","syntax":"swift","code":["let sidereal = AstroTime.now.siderealTime","print(\"Greenwich Sidereal Time: \\(sidereal) hours\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate local sidereal time for any longitude:"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)  \/\/ NYC","let lst = AstroTime.now.siderealTime(longitude: observer.longitude)","print(\"Local Sidereal Time: \\(lst) hours\")"]},{"type":"heading","anchor":"Working-with-Observers","text":"Working with Observers","level":2},{"type":"heading","anchor":"Creating-Observers","text":"Creating Observers","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Basic location (sea level)","let seattle = Observer(latitude: 47.6062, longitude: -122.3321)","","\/\/ With height above sea level (meters)","let everest = Observer(","    latitude: 27.9881,","    longitude: 86.9250,","    height: 8848.86",")"]},{"type":"heading","anchor":"Coordinate-Conventions","text":"Coordinate Conventions","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Latitude"}]},{"type":"text","text":": -90° (south) to +90° (north)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Longitude","type":"text"}]},{"text":": -180° (west) to +180° (east)","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Height","type":"text"}],"type":"strong"},{"type":"text","text":": Meters above sea level"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Built-in-Locations","text":"Built-in Locations","level":3},{"type":"codeListing","syntax":"swift","code":["let greenwich = Observer.greenwich       \/\/ Royal Observatory","let primeMeridian = Observer.primeMeridian  \/\/ 0°, 0°"]},{"type":"heading","anchor":"Observer-Properties","text":"Observer Properties","level":3},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.0, longitude: -105.0, height: 1600)","","\/\/ Local gravity (accounts for latitude and altitude)","let gravity = observer.gravity  \/\/ m\/s²","","\/\/ Atmospheric conditions at this elevation","let atmosphere = try observer.atmosphere","print(\"Pressure: \\(atmosphere.pressure) mbar\")"]},{"type":"heading","anchor":"Observer-Vectors","text":"Observer Vectors","level":3},{"type":"paragraph","inlineContent":[{"text":"Get the observer’s position relative to Earth’s center:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer.greenwich","","\/\/ Position vector in AU","let position = try observer.vector(at: .now)","","\/\/ Full state (position and velocity)","let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")"]},{"type":"heading","anchor":"Time-Zones","text":"Time Zones","level":2},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit works entirely in UTC. Convert to local time using Foundation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise (local): \\(formatter.string(from: sunrise.date))\")"]},{"type":"heading","anchor":"Codable-Support","text":"Codable Support","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both types support "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" for persistence:"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)","let data = try JSONEncoder().encode(observer)","","let time = AstroTime.now","let timeData = try JSONEncoder().encode(time)"]}],"kind":"content"}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted"],"anchor":"Essentials","generated":true}],"abstract":[{"type":"text","text":"Work with astronomical time and geographic observer locations."}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"references":{"doc://AstronomyKit/documentation/AstronomyKit/GettingStarted":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted","abstract":[{"type":"text","text":"Learn how to add AstronomyKit to your project and perform basic astronomical calculations."}],"title":"Getting Started with AstronomyKit","type":"topic","kind":"article","url":"\/documentation\/astronomykit\/gettingstarted","role":"article"},"https://github.com/cosinekitty/astronomy":{"title":"Astronomy Engine","titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"type":"link","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","url":"https:\/\/github.com\/cosinekitty\/astronomy"},"doc://AstronomyKit/documentation/AstronomyKit/AstroTime":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AstroTime","kind":"identifier"}],"navigatorTitle":[{"text":"AstroTime","kind":"identifier"}],"kind":"symbol","title":"AstroTime","type":"topic","role":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","abstract":[{"text":"Represents a moment in time for astronomical calculations.","type":"text"}],"url":"\/documentation\/astronomykit\/astrotime"},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"url":"\/documentation\/astronomykit\/observer","title":"Observer","fragme