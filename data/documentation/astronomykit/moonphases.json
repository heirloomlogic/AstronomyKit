{"abstract":[{"text":"Calculate moon phases, quarters, libration, and lunar nodes.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/astronomykit\/moonphases"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Moon","type":"reference"},{"text":" type provides comprehensive lunar calculations including phase angles, illumination, quarter searches, libration data, and node crossings.","type":"text"}]},{"anchor":"Phase-Angle","type":"heading","level":2,"text":"Phase Angle"},{"type":"paragraph","inlineContent":[{"text":"The phase angle indicates the Moon’s position in its cycle:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let angle = try Moon.phaseAngle(at: .now)","print(\"Phase angle: \\(angle)°\")","\/\/ 0° = New Moon, 90° = First Quarter, 180° = Full, 270° = Third Quarter"]},{"anchor":"Phase-Names-and-Emoji","type":"heading","level":2,"text":"Phase Names and Emoji"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convert angles to human-readable descriptions:"}]},{"type":"codeListing","syntax":"swift","code":["let angle = try Moon.phaseAngle(at: .now)","","print(Moon.phaseName(for: angle))  \/\/ \"Waxing Gibbous\"","print(Moon.emoji(for: angle))      \/\/ \"🌔\""]},{"type":"paragraph","inlineContent":[{"text":"The eight phase names:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New Moon (🌑)"}]}]},{"content":[{"inlineContent":[{"text":"Waxing Crescent (🌒)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"First Quarter (🌓)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Waxing Gibbous (🌔)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Full Moon (🌕)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Waning Gibbous (🌖)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Third Quarter (🌗)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Waning Crescent (🌘)"}],"type":"paragraph"}]}]},{"anchor":"Illumination","type":"heading","level":2,"text":"Illumination"},{"type":"paragraph","inlineContent":[{"text":"Calculate the fraction of the Moon that’s lit:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let angle = try Moon.phaseAngle(at: .now)","let illumination = Moon.illumination(for: angle)","print(\"Moon is \\(Int(illumination * 100))% illuminated\")"]},{"anchor":"Finding-Quarter-Phases","type":"heading","level":2,"text":"Finding Quarter Phases"},{"anchor":"Search-for-a-Specific-Phase","type":"heading","level":3,"text":"Search for a Specific Phase"},{"type":"codeListing","syntax":"swift","code":["\/\/ Next full moon","let fullMoon = try Moon.searchPhase(.full, after: .now)","print(\"Next full moon: \\(fullMoon)\")","","\/\/ Next new moon","let newMoon = try Moon.searchPhase(.new, after: .now)"]},{"anchor":"Get-the-Next-Quarter","type":"heading","level":3,"text":"Get the Next Quarter"},{"type":"codeListing","syntax":"swift","code":["let quarter = try Moon.nextQuarter(after: .now)","print(\"\\(quarter.phase.emoji) \\(quarter.phase.name) at \\(quarter.time)\")"]},{"anchor":"All-Quarters-in-a-Date-Range","type":"heading","level":3,"text":"All Quarters in a Date Range"},{"type":"codeListing","syntax":"swift","code":["let start = AstroTime(year: 2025, month: 1, day: 1)","let end = AstroTime(year: 2025, month: 2, day: 1)","","let quarters = try Moon.quarters(from: start, to: end)","for quarter in quarters {","    print(\"\\(quarter.phase.emoji) \\(quarter.time)\")","}"]},{"anchor":"Lunar-Position","type":"heading","level":2,"text":"Lunar Position"},{"anchor":"Ecliptic-Coordinates","type":"heading","level":3,"text":"Ecliptic Coordinates"},{"type":"codeListing","syntax":"swift","code":["let position = try Moon.eclipticPosition(at: .now)","print(\"Longitude: \\(position.longitude)°\")","print(\"Latitude: \\(position.latitude)°\")","print(\"Distance: \\(position.distance) AU\")"]},{"anchor":"Moon-State-Position-and-Velocity","type":"heading","level":3,"text":"Moon State (Position and Velocity)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the Moon’s complete state vector including velocity:"}]},{"type":"codeListing","syntax":"swift","code":["let state = try Moon.geoState(at: .now)","","\/\/ Position in AU","print(\"Distance: \\(state.position.magnitude) AU\")","","\/\/ Velocity in AU\/day","let speed = sqrt(","    state.velocity.x * state.velocity.x +","    state.velocity.y * state.velocity.y +","    state.velocity.z * state.velocity.z",")","print(\"Speed: \\(speed) AU\/day\")"]},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"code":"geoState(at:)","type":"codeVoice"},{"type":"text","text":" for velocity calculations instead of differencing"},{"type":"text","text":" "},{"type":"text","text":"ecliptic longitude positions, which gives inaccurate results."}],"type":"paragraph"}],"name":"Tip"},{"anchor":"Using-CelestialBody","type":"heading","level":3,"text":"Using CelestialBody"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Moon is also available as a "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let horizon = try CelestialBody.moon.horizon(at: .now, from: observer)","let equatorial = try CelestialBody.moon.equatorial(at: .now)"]},{"anchor":"Libration","type":"heading","level":2,"text":"Libration"},{"type":"paragraph","inlineContent":[{"text":"Libration is the Moon’s apparent wobble that lets us see slightly more than 50% of its surface:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let lib = Moon.libration(at: .now)","","\/\/ Sub-Earth point (what's at the center of the visible disc)","print(\"Latitude: \\(lib.subEarthLatitude)°\")","print(\"Longitude: \\(lib.subEarthLongitude)°\")","","\/\/ Distance and apparent size","print(\"Distance: \\(Int(lib.distanceKM)) km\")","print(\"Apparent diameter: \\(lib.apparentDiameter)°\")"]},{"type":"paragraph","inlineContent":[{"text":"Interpret libration values:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Positive latitude: More of the north polar region is visible"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Positive longitude: More of the Moon’s east limb is visible","type":"text"}]}]}]},{"anchor":"Lunar-Nodes","type":"heading","level":2,"text":"Lunar Nodes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The nodes are where the Moon’s orbit crosses the ecliptic plane:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Find next node crossing","let node = try Moon.searchNode(after: .now)","print(\"\\(node.kind.symbol) \\(node.kind.name) at \\(node.time)\")","\/\/ Output: \"☊ Ascending Node at 2025-01-15...\""]},{"anchor":"Node-Types","type":"heading","level":3,"text":"Node Types"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Ascending (☊)","type":"text"}]},{"type":"text","text":": Moon crosses from south to north of the ecliptic"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Descending (☋)"}]},{"type":"text","text":": Moon crosses from north to south"}],"type":"paragraph"}]}]},{"anchor":"All-Nodes-in-a-Range","type":"heading","level":3,"text":"All Nodes in a Range"},{"type":"codeListing","syntax":"swift","code":["let nodes = try Moon.nodeCrossings(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2025, month: 12, day: 31)",")","for node in nodes {","    print(\"\\(node.kind.symbol) \\(node.time)\")","}"]},{"anchor":"Lunar-Apsis","type":"heading","level":2,"text":"Lunar Apsis"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find perigee (closest) and apogee (farthest) points:"}]},{"type":"codeListing","syntax":"swift","code":["let apsis = try Moon.searchApsis(after: .now)","print(\"\\(apsis.kind.lunarName): \\(Int(apsis.distanceKM)) km\")","\/\/ Output: \"Perigee: 356,500 km\""]},{"anchor":"All-Apsides-in-a-Range","type":"heading","level":3,"text":"All Apsides in a Range"},{"type":"codeListing","syntax":"swift","code":["let apsides = try Moon.apsides(","    from: .now,","    to: .now.addingDays(60)",")","for apsis in apsides {","    print(\"\\(apsis.kind.lunarName) at \\(apsis.time)\")","}"]},{"anchor":"Moonrise-and-Moonset","type":"heading","level":2,"text":"Moonrise and Moonset"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","isActive":true,"type":"reference"},{"text":" interface:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7, longitude: -74.0)","","if let moonrise = try CelestialBody.moon.riseTime(after: .now, from: observer) {","    print(\"Moonrise: \\(moonrise)\")","}","","if let moonset = try CelestialBody.moon.setTime(after: .now, from: observer) {","    print(\"Moonset: \\(moonset)\")","}"]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Moon","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/MoonPhase","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/MoonQuarter","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Libra