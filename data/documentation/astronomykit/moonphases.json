ers-in-a-Date-Range","type":"heading","level":3,"text":"All Quarters in a Date Range"},{"type":"codeListing","syntax":"swift","code":["let start = AstroTime(year: 2025, month: 1, day: 1)","let end = AstroTime(year: 2025, month: 2, day: 1)","","let quarters = try Moon.quarters(from: start, to: end)","for quarter in quarters {","    print(\"\\(quarter.phase.emoji) \\(quarter.time)\")","}"]},{"anchor":"Lunar-Position","type":"heading","level":2,"text":"Lunar Position"},{"anchor":"Ecliptic-Coordinates","type":"heading","level":3,"text":"Ecliptic Coordinates"},{"type":"codeListing","syntax":"swift","code":["let position = try Moon.eclipticPosition(at: .now)","print(\"Longitude: \\(position.longitude)°\")","print(\"Latitude: \\(position.latitude)°\")","print(\"Distance: \\(position.distance) AU\")"]},{"anchor":"Moon-State-Position-and-Velocity","type":"heading","level":3,"text":"Moon State (Position and Velocity)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the Moon’s complete state vector including velocity:"}]},{"type":"codeListing","syntax":"swift","code":["let state = try Moon.geoState(at: .now)","","\/\/ Position in AU","print(\"Distance: \\(state.position.magnitude) AU\")","","\/\/ Velocity in AU\/day","let speed = sqrt(","    state.velocity.x * state.velocity.x +","    state.velocity.y * state.velocity.y +","    state.velocity.z * state.velocity.z",")","print(\"Speed: \\(speed) AU\/day\")"]},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"geoState(at:)","type":"codeVoice"},{"text":" for velocity calculations instead of differencing","type":"text"},{"text":" ","type":"text"},{"text":"ecliptic longitude positions, which gives inaccurate results.","type":"text"}]}]},{"anchor":"Using-CelestialBody","type":"heading","level":3,"text":"Using CelestialBody"},{"type":"paragraph","inlineContent":[{"text":"The Moon is also available as a ","type":"text"},{"isActive":true,"id