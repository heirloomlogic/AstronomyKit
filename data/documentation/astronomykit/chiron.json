ragraph"},{"inlineContent":[{"text":"Calculations are supported for years 1900 through 2150. Integration error","type":"text"},{"text":" ","type":"text"},{"text":"grows with distance from the reference epochs, so times outside this range","type":"text"},{"text":" ","type":"text"},{"text":"throw ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstronomyError\/badTime","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"syntax":"swift","type":"codeListing","code":["\/\/ Get Chiron's ecliptic longitude","let longitude = try Chiron.eclipticLongitude(at: .now)","print(\"Chiron is at \\(longitude)°\")","","\/\/ Get Chiron's geocentric position","let position = try Chiron.geocentricPosition(at: .now)","print(\"Chiron position: \\(position)\")"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron"},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/chiron"]}],"references":{"doc://AstronomyKit/documentation/AstronomyKit/Chiron/equatorial(at:)":{"title":"equatorial(at:)","abstract":[{"type":"text","text":"Calculates Chiron’s equatorial coordinates at a given time."}],"role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/equatorial(at:)","url":"\/documentation\/astronomykit\/chiron\/equatorial(at:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"equatorial","kind":"identifier"},{"text":"(","kind":"text"},{"text":"at","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"AstroTime","kind":"typeIdentifier","preciseIdentifier":"s:12AstronomyKit9AstroTimeV"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","