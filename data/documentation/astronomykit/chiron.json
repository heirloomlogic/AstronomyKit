{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"text":"Provides position calculations for 2060 Chiron.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/ecliptic(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/eclipticLatitude(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/eclipticLongitude(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/equatorial(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/geoPosition(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/geoState(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/helioPosition(at:)","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron\/horizon(at:from:refraction:)"],"anchor":"Type-Methods","title":"Type Methods","generated":true}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Chiron"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Chiron is a minor planet (centaur) orbiting between Saturn and Uranus."},{"type":"text","text":" "},{"type":"text","text":"Since Astronomy Engine doesn’t include Chiron as a built-in body,"},{"type":"text","text":" "},{"type":"text","text":"positions are calculated using gravity simulation with pre-computed"},{"type":"text","text":" "},{"type":"text","text":"state vectors from JPL Horizons."}]},{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Chiron’s position is computed by:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Selecting the nearest reference epoch to the requested time"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initializing a gravity simulation at that epoch"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Propagating to the requested time"}]}]},{"content":[{"inlineContent":[{"text":"Converting to the desired coordinate system","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Accuracy","anchor":"Accuracy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Accuracy is highest near the reference epochs (2000, 2010, 2020, 2030, 2040)"},{"type":"text","text":" "},{"type":"text","text":"and degrades slightly as distance from these epochs increases due to"},{"type":"text","text":" "},{"type":"text","text":"numerical integration error. For typical usage within ±5 years of an epoch,"},{"type":"text","text":" "},{"type":"text","text":"error is expected to be less than 1 arcminute."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","code":["\/\/ Get Chiron's ecliptic longitude","let longitude = try Chiron.eclipticLongitude(at: .now)","print(\"Chiron is at \\(longitude)°\")","","\/\/ Get Chiron's geocentric position","let position = try Chiron.geoPosition(at: .now)","print(\"Chiron position: \\(position)\")"],"syntax":"swift"}],"kind":"content"}],"metadata":{"externalID":"s:12AstronomyKit6ChironO","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Chiron","kind":"identifier"}],"navigatorTitle":[{"text":"Chiron","kind":"identifier"}],"symbolKind":"enum","title":"Chiron","modules":[{"name":"AstronomyKit"}],"roleHeading":"Enumeration"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/chiron"]}],"references":{"https://github.com/cosinekit