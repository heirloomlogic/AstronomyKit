{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstronomyConfig\/reset()"},"abstract":[{"text":"Frees all dynamic memory allocated by the Astronomy Engine.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"reset","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The engine allocates memory in only one place: a cache of orbit"},{"type":"text","text":" "},{"type":"text","text":"segments that speeds up Pluto calculations. This purges that cache,"},{"type":"text","text":" "},{"type":"text","text":"which slows down the next nearby Pluto calculation but releases the"},{"type":"text","text":" "},{"type":"text","text":"memory (useful before running leak checkers). It does not affect the"},{"type":"text","text":" "},{"type":"text","text":"Delta T model or any "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","type":"reference","isActive":true},{"type":"text","text":" definitions."}]},{"type":"paragraph","inlineContent":[{"text":"This is safe to call concurrently with other calculations.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstronomyConfig"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/astronomykit\/astronomyconfig\/reset()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","modules":[{"name":"AstronomyKit"}],"title":"reset()","roleHeading":"Type Method","externalID":"s:12AstronomyKit0A6ConfigO5resetyyFZ","symbolKind