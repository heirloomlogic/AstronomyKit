{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AdvancedFeatures"},"metadata":{"modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article","title":"Advanced Features"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"AstronomyKit includes advanced features for specialized astronomical calculations, including gravity simulations, Lagrange point positions, Jupiter’s Galilean moons, planetary rotation axes, and atmospheric modeling.","type":"text"}],"type":"paragraph"},{"text":"N-Body Gravity Simulation","anchor":"N-Body-Gravity-Simulation","level":2,"type":"heading"},{"inlineContent":[{"text":"Simulate the gravitational motion of objects in the solar system.","type":"text"}],"type":"paragraph"},{"text":"Creating a Simulation","anchor":"Creating-a-Simulation","level":3,"type":"heading"},{"code":["\/\/ Initial state for a small body (e.g., a comet)","let initialState = StateVector(...)  \/\/ Position and velocity","","let sim = try GravitySimulation(","    origin: .sun,","    time: .now,","    initialState: initialState",")"],"syntax":"swift","type":"codeListing"},{"text":"Running the Simulation","anchor":"Running-the-Simulation","level":3,"type":"heading"},{"code":["\/\/ Advance 30 days","try sim.update(to: .now.addingDays(30))","","\/\/ Get the current simulation time","let currentTime = sim.currentTime()","","\/\/ Get state of a major body","let jupiterState = try sim.state(of: .jupiter)","print(\"Jupiter position: \\(jupiterState.position)\")"],"syntax":"swift","type":"codeListing"},{"text":"Reversing Time","anchor":"Reversing-Time","level":3,"type":"heading"},{"code":["\/\/ Switch direction (forward ↔ backward)","sim.swap()","","\/\/ Now updates go backward in time","try sim.update(to: .now.addingDays(-30))"],"syntax":"swift","type":"codeListing"},{"text":"Lagrange Points","anchor":"Lagrange-Points","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Lagrange points are stable\/semi-stable locations in a two-body gravitational system."}],"type":"paragraph"},{"text":"Calculate Lagrange Point Position","anchor":"Calculate-Lagrange-Point-Position","level":3,"type":"heading"},{"code":["\/\/ Sun-Earth L2 (where JWST orbits)","let l2 = try LagrangePoint.calculate(","    point: .l2,","    at: .now,","    majorBody: .sun,","    minorBody: .earth",")","print(\"L2 position: \\(l2.position)\")","print(\"L2 velocity: \\(l2.velocity)\")"],"syntax":"swift","type":"codeListing"},{"text":"The Five Lagrange Points","anchor":"The-Five-Lagrange-Points","level":3,"type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Point"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Location"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stability"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Between bodies"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unstable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Beyond smaller body"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unstable"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Beyond larger body"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unstable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"60° ahead"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Stable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"60° behind","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stable"}],"type":"paragraph"}]]],"type":"table"},{"text":"Jupiter’s Galilean Moons","anchor":"Jupiters-Galilean-Moons","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Get positions of Io, Europa, Ganymede, and Callisto."}],"type":"paragraph"},{"text":"Moon States","anchor":"Moon-States","level":3,"type":"heading"},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ Each moon has position and velocity relative to Jupiter","print(\"Io: \\(moons.io.position)\")","print(\"Europa: \\(moons.europa.position)\")","print(\"Ganymede: \\(moons.ganymede.position)\")","print(\"Callisto: \\(moons.callisto.position)\")"],"syntax":"swift","type":"codeListing"},{"text":"Checking Moon Position","anchor":"Checking-Moon-Position","level":3,"type":"heading"},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ X > 0 means east of Jupiter","if moons.io.position.x > 0 {","    print(\"Io is east of Jupiter\")","} else {","    print(\"Io is west of Jupiter\")","}"],"syntax":"swift","type":"codeListing"},{"text":"Using as CelestialBodies","anchor":"Using-as-CelestialBodies","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The moons are also available as celestial bodies:"}],"type":"paragraph"},{"code":["for moon in CelestialBody.galileanMoons {","    let eq = try moon.equatorial(at: .now)","    print(\"\\(moon.name): RA \\(eq.rightAscension)h\")","}"],"syntax":"swift","type":"codeListing"},{"text":"Planetary Rotation Axes","anchor":"Planetary-Rotation-Axes","level":2,"type":"heading"},{"inlineContent":[{"text":"Get the orientation of a body’s rotation axis and prime meridian.","type":"text"}],"type":"paragraph"},{"code":["let axis = try CelestialBody.mars.rotationAxis(at: .now)","","\/\/ North pole direction (J2000)","print(\"Pole RA: \\(axis.rightAscension) hours\")","print(\"Pole Dec: \\(axis.declination)°\")","","\/\/ Prime meridian rotation","print(\"Spin angle: \\(axis.spin)°\")","","\/\/ Unit vector toward north pole","let north = axis.north"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is useful for:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Calculating solar angles on planetary surfaces","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Determining which hemisphere faces Earth"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Rendering accurate planetary graphics"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Atmospheric Modeling","anchor":"Atmospheric-Modeling","level":2,"type":"heading"},{"inlineContent":[{"text":"Model Earth’s atmosphere based on elevation.","type":"text"}],"type":"paragraph"},{"text":"Atmosphere at Elevation","anchor":"Atmosphere-at-Elevation","level":3,"type":"heading"},{"code":["let atmosphere = try Atmosphere.at(elevation: 5000)  \/\/ 5000m","print(\"Pressure: \\(atmosphere.pressure) mbar\")","print(\"Temperature: \\(atmosphere.temperature)°C\")","print(\"Density: \\(atmosphere.density)\")  \/\/ Relative to sea level"],"syntax":"swift","type":"codeListing"},{"text":"Observer’s Atmosphere","anchor":"Observers-Atmosphere","level":3,"type":"heading"},{"code":["let observer = Observer(latitude: 39.7, longitude: -104.9, height: 1600)","let atm = try observer.atmosphere","print(\"Local pressure: \\(atm.pressure) mbar\")"],"syntax":"swift","type":"codeListing"},{"text":"Extreme Altitudes","anchor":"Extreme-Altitudes","level":3,"type":"heading"},{"code":["\/\/ Mount Everest summit","let everest = try Atmosphere.at(elevation: 8848.86)","print(\"Pressure: \\(Int(everest.pressure)) mbar\")  \/\/ ~314 mbar (vs 1013 at sea level)"],"syntax":"swift","type":"codeListing"},{"text":"Fixed Stars","anchor":"Fixed-Stars","level":2,"type":"heading"},{"inlineContent":[{"text":"Define and track fixed stars by their J2000 catalog coordinates.","type":"text"}],"type":"paragraph"},{"text":"Defining a Star","anchor":"Defining-a-Star","level":3,"type":"heading"},{"code":["\/\/ Algol (Beta Persei) - the \"Demon Star\"","let algol = FixedStar(","    name: \"Algol\",","    ra: 3.136148,      \/\/ J2000 RA in hours","    dec: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Sirius - the brightest star","let sirius = FixedStar(","    name: \"Sirius\",","    ra: 6.7525,","    dec: -16.7161,","    distance: 8.6",")"],"syntax":"swift","type":"codeListing"},{"text":"Getting Positions","anchor":"Getting-Positions","level":3,"type":"heading"},{"code":["\/\/ Ecliptic longitude (for astrological calculations)","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)","","\/\/ Constellation","let constellation = try sirius.constellation(at: .now)"],"syntax":"swift","type":"codeListing"},{"text":"Finding Catalog Data","anchor":"Finding-Catalog-Data","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"J2000 coordinates can be found from:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hipparcos Catalog"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Yale Bright Star Catalog"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Observer Gravity","anchor":"Observer-Gravity","level":2,"type":"heading"},{"inlineContent":[{"text":"Calculate local gravitational acceleration:","type":"text"}],"type":"paragraph"},{"code":["let observer = Observer(latitude: 45.0, longitude: 0.0, height: 0)","let gravity = observer.gravity  \/\/ m\/s²","print(\"Local g: \\(gravity) m\/s²\")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This accounts for:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Latitude (Earth’s oblateness)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Altitude (distance from Earth’s center)"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"abstract":[{"text":"N-body simulations, Lagrange points, Jupiter’s moons, and more.","type":"text"}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/advancedfeatures"]}],"seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Transit"],"anchor":"Advanced","generated":true,"title":"Advanced"}],"references":{"doc://AstronomyKit/documentation/AstronomyKit":{"url":"\/documentation\/astronomykit","type":"topic","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"text":" library.","type":"text"}],"title":"AstronomyKit","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","role":"collection"},"doc://AstronomyKit/documentation/AstronomyKit/Transit":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Transit"}],"navigatorTitle":[{"kind":"identifier","text":"Transit"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Transit","role":"symbol","url":"\/documentation\/astronomykit\/transit","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Information about a transit of Mercury or Venus across the Sun."}],"title":"Transit"},"doc://AstronomyKit/documentation/AstronomyKit/LagrangePoint":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LagrangePoint"}],"navigatorTitle":[{"kind":"identifier","text":"LagrangePoint"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint","kind":"symbol","type":"topic","abstract":[{"text":"Lagrange point calculation functions.","type":"text"}],"url":"\/documentation\/astronomykit\/lagrangepoint","role":"symbol","title":"LagrangePoint"},"doc://AstronomyKit/documentation/AstronomyKit/GravitySimulation":{"kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","url":"\/documentation\/astronomykit\/gravitysimulation","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"GravitySimulation"}],"title":"GravitySimulation","abstract":[{"type":"text","text":"An n-body gravity simulation for tracking object trajectories."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"GravitySimulation"}]},"https://simbad.cds.unistra.fr/simbad/":{"type":"link","url":"https:\/\/simbad.cds.unistra.fr\/simbad\/","titleInlineContent":[{"text":"SIMBAD Astronomical Database","type":"text"}],"title":"SIMBAD Astronomical Database","identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/"},"https://github.com/cosinekitty/astronomy":{"type":"link","title":"Astronomy Engine","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy"}}}