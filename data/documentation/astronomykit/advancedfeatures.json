{"metadata":{"modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article","title":"Advanced Features"},"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AdvancedFeatures","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","seeAlsoSections":[{"generated":true,"anchor":"Advanced","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Transit"],"title":"Advanced"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit includes advanced features for specialized astronomical calculations, including gravity simulations, Lagrange point positions, Jupiter’s Galilean moons, planetary rotation axes, and atmospheric modeling.","type":"text"}]},{"type":"heading","level":2,"text":"N-Body Gravity Simulation","anchor":"N-Body-Gravity-Simulation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Simulate the gravitational motion of objects in the solar system."}]},{"type":"heading","level":3,"text":"Creating a Simulation","anchor":"Creating-a-Simulation"},{"type":"codeListing","syntax":"swift","code":["\/\/ Initial state for a small body (e.g., a comet)","let initialState = StateVector(...)  \/\/ Position and velocity","","let sim = try GravitySimulation(","    origin: .sun,","    time: .now,","    initialState: initialState",")"]},{"type":"heading","level":3,"text":"Running the Simulation","anchor":"Running-the-Simulation"},{"type":"codeListing","syntax":"swift","code":["\/\/ Advance 30 days","try sim.update(to: .now.addingDays(30))","","\/\/ Get the current simulation time","let currentTime = sim.currentTime()","","\/\/ Get state of a major body","let jupiterState = try sim.state(of: .jupiter)","print(\"Jupiter position: \\(jupiterState.position)\")"]},{"type":"heading","level":3,"text":"Reversing Time","anchor":"Reversing-Time"},{"type":"codeListing","syntax":"swift","code":["\/\/ Switch direction (forward ↔ backward)","sim.swap()","","\/\/ Now updates go backward in time","try sim.update(to: .now.addingDays(-30))"]},{"type":"heading","level":2,"text":"Lagrange Points","anchor":"Lagrange-Points"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lagrange points are stable\/semi-stable locations in a two-body gravitational system."}]},{"type":"heading","level":3,"text":"Calculate Lagrange Point Position","anchor":"Calculate-Lagrange-Point-Position"},{"type":"codeListing","syntax":"swift","code":["\/\/ Sun-Earth L2 (where JWST orbits)","let l2 = try LagrangePoint.calculate(","    point: .l2,","    at: .now,","    majorBody: .sun,","    minorBody: .earth",")","print(\"L2 position: \\(l2.position)\")","print(\"L2 velocity: \\(l2.velocity)\")"]},{"type":"heading","level":3,"text":"The Five Lagrange Points","anchor":"The-Five-Lagrange-Points"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Point"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Location","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Stability","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"L1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Between bodies"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unstable"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"L2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Beyond smaller body","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unstable","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"L3"}]}],[{"type":"paragraph","inlineContent":[{"text":"Beyond larger body","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unstable","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"L4"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"60° ahead"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Stable"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"L5"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"60° behind"}]}],[{"type":"paragraph","inlineContent":[{"text":"Stable","type":"text"}]}]]]},{"type":"heading","level":2,"text":"Jupiter’s Galilean Moons","anchor":"Jupiters-Galilean-Moons"},{"type":"paragraph","inlineContent":[{"text":"Get positions of Io, Europa, Ganymede, and Callisto.","type":"text"}]},{"type":"heading","level":3,"text":"Moon States","anchor":"Moon-States"},{"type":"codeListing","syntax":"swift","code":["let moons = try Jupiter.moons(at: .now)","","\/\/ Each moon has position and velocity relative to Jupiter","print(\"Io: \\(moons.io.position)\")","print(\"Europa: \\(moons.europa.position)\")","print(\"Ganymede: \\(moons.ganymede.position)\")","print(\"Callisto: \\(moons.callisto.position)\")"]},{"type":"heading","level":3,"text":"Checking Moon Position","anchor":"Checking-Moon-Position"},{"type":"codeListing","syntax":"swift","code":["let moons = try Jupiter.moons(at: .now)","","\/\/ X > 0 means east of Jupiter","if moons.io.position.x > 0 {","    print(\"Io is east of Jupiter\")","} else {","    print(\"Io is west of Jupiter\")","}"]},{"type":"heading","level":3,"text":"Using as CelestialBodies","anchor":"Using-as-CelestialBodies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The moons are also available as celestial bodies:"}]},{"type":"codeListing","syntax":"swift","code":["for moon in CelestialBody.galileanMoons {","    let eq = try moon.equatorial(at: .now)","    print(\"\\(moon.name): RA \\(eq.rightAscension)h\")","}"]},{"type":"heading","level":2,"text":"Planetary Rotation Axes","anchor":"Planetary-Rotation-Axes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"