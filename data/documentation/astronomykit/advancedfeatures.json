{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Article","role":"article","title":"Advanced Features","modules":[{"name":"AstronomyKit"}]},"seeAlsoSections":[{"anchor":"Advanced","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Chiron","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePointID","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Jupiter","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/JupiterMoons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RotationAxis","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Atmosphere"],"title":"Advanced","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit includes advanced features for specialized astronomical calculations, including gravity simulations, Lagrange point positions, Jupiter’s Galilean moons, planetary rotation axes, and atmospheric modeling."}]},{"type":"heading","anchor":"N-Body-Gravity-Simulation","level":2,"text":"N-Body Gravity Simulation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Simulate the gravitational motion of objects in the solar system."}]},{"type":"heading","anchor":"Creating-a-Simulation","level":3,"text":"Creating a Simulation"},{"code":["\/\/ Initial state for a small body (e.g., a comet)","let initialState = StateVector(...)  \/\/ Position and velocity","","let sim = try GravitySimulation(","    origin: .sun,","    time: .now,","    initialState: initialState",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Running-the-Simulation","level":3,"text":"Running the Simulation"},{"code":["\/\/ Advance 30 days","try sim.update(to: .now.addingDays(30))","","\/\/ Get the current simulation time","let currentTime = sim.currentTime()","","\/\/ Get state of a major body","let jupiterState = try sim.state(of: .jupiter)","print(\"Jupiter position: \\(jupiterState.position)\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Reversing-Time","level":3,"text":"Reversing Time"},{"code":["\/\/ Switch direction (forward ↔ backward)","sim.swap()","","\/\/ Now updates go backward in time","try sim.update(to: .now.addingDays(-30))"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Lagrange-Points","level":2,"text":"Lagrange Points"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lagrange points are stable\/semi-stable locations in a two-body gravitational system."}]},{"type":"heading","anchor":"Calculate-Lagrange-Point-Position","level":3,"text":"Calculate Lagrange Point Position"},{"code":["\/\/ Sun-Earth L2 (where JWST orbits)","let l2 = try LagrangePoint.calculate(","    point: .l2,","    at: .now,","    majorBody: .sun,","    minorBody: .earth",")","print(\"L2 position: \\(l2.position)\")","print(\"L2 velocity: \\(l2.velocity)\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"The-Five-Lagrange-Points","level":3,"text":"The Five Lagrange Points"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Point"}]}],[{"inlineContent":[{"text":"Location","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Stability","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Between bodies"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unstable"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Beyond smaller body","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unstable"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Beyond larger body"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unstable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L4"}],"type":"paragraph"}],[{"inlineContent":[{"text":"60° ahead","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Stable"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"L5"}]}],[{"type":"paragraph","inlineContent":[{"text":"60° behind","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Stable","type":"text"}]}]]]},{"type":"heading","anchor":"Jupiters-Galilean-Moons","level":2,"text":"Jupiter’s Galilean Moons"},{"type":"paragraph","inlineContent":[{"text":"Get positions of Io, Europa, Ganymede, and Callisto.","type":"text"}]},{"type":"heading","anchor":"Moon-States","level":3,"text":"Moon States"},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ Each moon has position and velocity relative to Jupiter","print(\"Io: \\(moons.io.position)\")","print(\"Europa: \\(moons.europa.position)\")","print(\"Ganymede: \\(moons.ganymede.position)\")","print(\"Callisto: \\(moons.callisto.position)\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Checking-Moon-Position","level":3,"text":"Checking Moon Position"},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ X > 0 means east of Jupiter","if moons.io.position.x > 0 {","    print(\"Io is east of Jupiter\")","} else {","    print(\"Io is west of Jupiter\")","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Using-as-CelestialBodies","level":3,"text":"Using as CelestialBodies"},{"type":"paragraph","inlineContent":[{"text":"The moons are also available as celestial bodies:","type":"text"}]},{"code":["for moon in CelestialBody.galileanMoons {","    let eq = try moon.equatorial(at: .now)","    print(\"\\(moon.name): RA \\(eq.rightAscension)h\")","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Planetary-Rotation-Axes","level":2,"text":"Planetary Rotation Axes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the orientation of a body’s rotation axis and prime meridian."}]},{"code":["let axis = try CelestialBody.mars.rotationAxis(at: .now)","","\/\/ North pole direction (J2000)","print(\"Pole RA: \\(axis.rightAscension) hours\")","print(\"Pole Dec: \\(axis.declination)°\")","","\/\/ Prime meridian rotation","print(\"Spin angle: \\(axis.spin)°\")","","\/\/ Unit vector toward north pole","let north = axis.north"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Calculating solar angles on planetary surfaces"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Determining which hemisphere faces Earth"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rendering accurate planetary graphics"}]}]}]},{"type":"heading","anchor":"Atmospheric-Modeling","level":2,"text":"Atmospheric Modeling"},{"type":"paragraph","inlineContent":[{"text":"Model Earth’s atmosphere based on elevation.","type":"text"}]},{"type":"heading","anchor":"Atmosphere-at-Elevation","level":3,"text":"Atmosphere at Elevation"},{"code":["let atmosphere = try Atmosphere.at(elevation: 5000)  \/\/ 5000m","print(\"Pressure: \\(atmosphere.pressure) mbar\")","print(\"Temperature: \\(atmosphere.temperature)°C\")","print(\"Density: \\(atmosphere.density)\")  \/\/ Relative to sea level"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Observers-Atmosphere","level":3,"text":"Observer’s Atmosphere"},{"code":["let observer = Observer(latitude: 39.7, longitude: -104.9, height: 1600)","let atm = try observer.atmosphere","print(\"Local pressure: \\(atm.pressure) mbar\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Extreme-Altitudes","level":3,"text":"Extreme Altitudes"},{"code":["\/\/ Mount Everest summit","let everest = try Atmosphere.at(elevation: 8848.86)","print(\"Pressure: \\(Int(everest.pressure)) mbar\")  \/\/ ~314 mbar (vs 1013 at sea level)"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Fixed-Stars","level":2,"text":"Fixed Stars"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"FixedStar","type":"codeVoice"},{"type":"text","text":" is an AstronomyKit addition. It wraps Astronomy Engine’s "},{"code":"Astronomy_DefineStar()","type":"codeVoice"},{"type":"text","text":" with a thread-safe, Swift-idiomatic value type and mutex-protected calculation slots."}]}]},{"type":"paragraph","inlineContent":[{"text":"Define and track fixed stars by their J2000 catalog coordinates.","type":"text"}]},{"type":"heading","anchor":"Defining-a-Star","level":3,"text":"Defining a Star"},{"code":["\/\/ Algol (Beta Persei) - the \"Demon Star\"","let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95            \/\/ Light-years",")","","\/\/ Sirius - the brightest star","let sirius = FixedStar(","    name: \"Sirius\",","    rightAscension: 6.7525,","    declination: -16.7161,","    distance: 8.6",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Getting-Positions","level":3,"text":"Getting Positions"},{"code":["\/\/ Ecliptic longitude (for astrological calculations)","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)","","\/\/ Constellation","let constellation = try sirius.constellation(at: .now)"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Finding-Catalog-Data","level":3,"text":"Finding Catalog Data"},{"type":"paragraph","inlineContent":[{"text":"J2000 coordinates can be found from:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Hipparcos Catalog","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Yale Bright Star Catalog","type":"text"}]}]}]},{"type":"heading","anchor":"Chiron","level":2,"text":"Chiron"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Chiron"},{"text":" is an AstronomyKit addition. Astronomy Engine has no built-in support for 2060 Chiron.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit provides gravity-simulated positions for the centaur 2060 Chiron using pre-computed JPL Horizons state vectors at reference epochs (2000, 2010, 2020, 2030, 2040). The nearest epoch is selected and propagated via n-body gravity simulation.","type":"text"}]},{"type":"heading","anchor":"Getting-Chirons-Position","level":3,"text":"Getting Chiron’s Position"},{"code":["\/\/ Ecliptic longitude","let longitude = try Chiron.eclipticLongitude(at: .now)","","\/\/ Full ecliptic coordinates","let ecliptic = try Chiron.ecliptic(at: .now)","","\/\/ Horizon position for an observer","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try Chiron.horizon(at: .now, from: observer)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Accuracy is highest near the reference epochs and degrades as distance increases. Within ±5 years of an epoch, error is expected to be less than 1 arcminute."}]},{"type":"heading","anchor":"Observer-Gravity","level":2,"text":"Observer Gravity"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate local gravitational acceleration:"}]},{"code":["let observer = Observer(latitude: 45.0, longitude: 0.0, height: 0)","let gravity = observer.gravity  \/\/ m\/s²","print(\"Local g: \\(gravity) m\/s²\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This accounts for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Latitude (Earth’s oblateness)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Altitude (distance from Earth’s center)"}]}]}]}]}],"kind":"article","sections":[],"variants":[{"paths":["\/documentation\/astronomykit\/advancedfeatures"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AdvancedFeatures"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"text":"N-body simulations, Lagrange points, Jupiter’s moons, and more.","type":"text"}],"references":{"https://simbad.cds.unistra.fr/simbad/":{"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/","title":"SIMBAD Astronomical Database","type":"link","url":"https:\/\/simbad.cds.unistra.fr\/simbad\/","titleInlineContent":[{"type":"text","text":"SIMBAD Astronomical Database"}]},"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine"},"doc://AstronomyKit/documentation/AstronomyKit":{"role":"collection","type":"topic","url":"\/documentation\/astronomykit","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","title":"AstronomyKit","abstract":[{"text":"Swift bindings for Don Cross’ ","t