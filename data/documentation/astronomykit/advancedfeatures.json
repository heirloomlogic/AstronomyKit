t jupiterState = try sim.state(of: .jupiter)","print(\"Jupiter position: \\(jupiterState.position)\")"],"syntax":"swift"},{"anchor":"Reversing-Time","type":"heading","level":3,"text":"Reversing Time"},{"type":"codeListing","code":["\/\/ Switch direction (forward ↔ backward)","sim.swap()","","\/\/ Now updates go backward in time","try sim.update(to: .now.addingDays(-30))"],"syntax":"swift"},{"anchor":"Lagrange-Points","type":"heading","level":2,"text":"Lagrange Points"},{"inlineContent":[{"type":"text","text":"Lagrange points are stable\/semi-stable locations in a two-body gravitational system."}],"type":"paragraph"},{"anchor":"Calculate-Lagrange-Point-Position","type":"heading","level":3,"text":"Calculate Lagrange Point Position"},{"type":"codeListing","syntax":"swift","code":["\/\/ Sun-Earth L2 (where JWST orbits)","let l2 = try LagrangePoint.calculate(","    point: .l2,","    at: .now,","    majorBody: .sun,","    minorBody: .earth",")","print(\"L2 position: \\(l2.position)\")","print(\"L2 velocity: \\(l2.velocity)\")"]},{"level":3,"type":"heading","text":"The Five Lagrange Points","anchor":"The-Five-Lagrange-Points"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Point","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Location"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Stability","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Between bodies"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unstable"}]}]],[[{"inlineContent":[{"text":"L2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Beyond smaller body","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Unstable","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"L3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Beyond larger body"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unstable","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"L4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"60° ahead","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Stable","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"L5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"60° behind","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Stable","type":"text"}]}]]]},{"anchor":"Jupiters-Galilean-Moons","type":"heading","level":2,"text":"Jupiter’s Galilean Moons"},{"inlineContent":[{"text":"Get positions of Io, Europa, Ganymede, and Callisto.","type":"text"}],"type":"paragraph"},{"anchor":"Moon-States","type":"heading","level":3,"text":"Moon States"},{"type":"codeListing","code":["let moons = try Jupiter.moons(at: .now)","","\/\/ Each moon has position and velocity relative to Jupiter","print(\"Io: \\(moons.io.position)\")","print(\"Europa: \\(moons.europa.position)\")","print(\"Ganymede: \\(moons.ganymede.position)\")","print(\"Callisto: \\(moons.callisto.position)\")"],"syntax":"swift"},{"anchor":"Checking-Moon-Position","type":"heading","level":3,"text":"Checking Moon Position"},{"type":"codeListing","code":["let moons = try Jupiter.moons(at: .now)","","\/\/ X > 0 means east of Jupiter","if moons.io.position.x > 0 {","    print(\"Io is east of Jupiter\")","} else {","    print(\"Io is west of Jupiter\")","}"],"syntax":"swift"},{"text":"Using as CelestialBodies","type":"heading","anchor":"Using-as-CelestialBodies","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The moons are also available as celestial bodies:"}]},{"type":"codeListing","syntax":"swift","code":["for moon in CelestialBody.galileanMoons {","    let eq = try moon.equatorial(at: .now)","    print(\"\\(moon.name): RA \\(eq.rightAscension)h\")","}"]},{"text":"Planetary Rotation Axes","type":"heading","anchor":"Planetary-Rotation-Axes","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the orientation of a body’s rotation axis and prime meridian."}]},{"type":"codeListing","syntax":"swift","code":["let axis = try CelestialBody.mars.rotationAxis(at: .now)","","\/\/ North pole direction (J2000)","print(\"Pole RA: \\(axis.rightAscension) hours\")","print(\"Pole Dec: \\(axis.declination)°\")","","\/\/ Prime meridian rotation","print(\"Spin angle: \\(axis.spin)°\")","","\/\/ Unit vector toward north pole","let north = axis.north"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is useful for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculating solar angles on planetary surfaces"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Determining which hemisphere faces Earth"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rendering accurate planetary graphics"}]}]}]},{"text":"Atmospheric Modeling","type":"heading","anchor":"Atmospheric-Modeling","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Model Earth’s atmosphere based on elevation."}]},{"text":"Atmosphere at Elevation","type":"heading","anchor":"Atmosphere-at-Elevation","level":3},{"type":"codeListing","syntax":"swift","code":["let atmosphere = try Atmosphere.at(elevation: 5000)  \/\/ 5000m","print(\"Pressure: \\(atmosphere.pressure) mbar\")","print(\"Temperature: \\(atmosphere.temperature)°C\")","print(\"Density: \\(atmosphere.density)\")  \/\/ Relative to sea level"]},{"text":"Observer’s Atmosphere","type":"heading","anchor":"Observers-Atmosphere","level":3},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 39.7, longitude: -104.9, height: 1600)","let atm = try observer.atmosphere","print(\"Local pressure: \\(atm.pressure) mbar\")"]},{"text":"Extreme Altitudes","type":"heading","anchor":"Extreme-Altitudes","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Mount Everest summit","let everest = try Atmosphere.at(elevation: 8848.86)","print(\"Pressure: \\(Int(everest.pressure)) mbar\")  \/\/ ~314 mbar (vs 1013 at sea level)"]},{"text":"Fixed Stars","type":"heading","anchor":"Fixed-Stars","level":2},{"type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"FixedStar","type":"codeVoice"},{"text":" is an AstronomyKit addition. It wraps Astronomy Engine’s ","type":"text"},{"code":"Astronomy_DefineStar()","type":"codeVoice"},{"text":" with a thread-safe, Swift-idiomatic value type and mutex-protected calculation slots.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates."}]},{"text":"Defining a Star","type":"heading","anchor":"Defining-a-Star","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Algol (Beta Persei) - the \"Demon Star\"","let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95            \/\/ Light-years",")","","\/\/ Sirius - the brightest star","let sirius = FixedStar(","    name: \"Sirius\",","    rightAscension: 6.7525,","    declination: -16.7161,","    distance: 8.6",")"]},{"text":"Getting Positions","type":"heading","anchor":"Getting-Positions","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Ecliptic longitude (for astrological calculations)","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)","","\/\/ Constellation","let constellation = try sirius.constellation(at: .now)"]},{"text":"Finding Catalog Data","type":"heading","anchor":"Finding-Catalog-Data","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"J2000 coordinates can be found from:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hipparcos Catalog"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yale Bright Star Catalog"}]}]}]},{"text":"Chiron","type":"heading","anchor":"Chiron","level":2},{"type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"Chiron","type":"codeVoice"},{"text":" is an AstronomyKit addition. Astronomy Engine has no built-in support for 2060 Chiron.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit provides gravity-simulated positions for the centaur 2060 Chiron using pre-computed JPL Horizons state vectors at reference epochs (2000, 2010, 2020, 2030, 2040). The nearest epoch is selected and propagated via n-body gravity simulation."}]},{"text":"Getting Chiron’s Position","type":"heading","anchor":"Getting-Chirons-Position","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Ecliptic longitude","let longitude = try Chiron.eclipticLongitude(at: .now)","","\/\/ Full ecliptic coordinates","let ecliptic = try Chiron.ecliptic(at: .now)","","\/\/ Horizon position for an observer","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try Chiron.horizon(at: .now, from: observer)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Accuracy is highest near the reference epochs and degrades as distance increases. Within ±5 years of an epoch, error is expected to be less than 1 arcminute."}]},{"text":"Observer Gravity","type":"heading","anchor":"Observer-Gravity","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate local gravitational acceleration:"}]},