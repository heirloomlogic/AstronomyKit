{"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Transit"],"title":"Advanced","anchor":"Advanced","generated":true}],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AdvancedFeatures","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"AstronomyKit"}],"title":"Advanced Features"},"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"AstronomyKit includes advanced features for specialized astronomical calculations, including gravity simulations, Lagrange point positions, Jupiter’s Galilean moons, planetary rotation axes, and atmospheric modeling."}],"type":"paragraph"},{"anchor":"N-Body-Gravity-Simulation","type":"heading","level":2,"text":"N-Body Gravity Simulation"},{"inlineContent":[{"text":"Simulate the gravitational motion of objects in the solar system.","type":"text"}],"type":"paragraph"},{"anchor":"Creating-a-Simulation","type":"heading","level":3,"text":"Creating a Simulation"},{"code":["\/\/ Initial state for a small body (e.g., a comet)","let initialState = StateVector(...)  \/\/ Position and velocity","","let sim = try GravitySimulation(","    origin: .sun,","    time: .now,","    initialState: initialState",")"],"type":"codeListing","syntax":"swift"},{"anchor":"Running-the-Simulation","type":"heading","level":3,"text":"Running the Simulation"},{"code":["\/\/ Advance 30 days","try sim.update(to: .now.addingDays(30))","","\/\/ Get the current simulation time","let currentTime = sim.currentTime()","","\/\/ Get state of a major body","let jupiterState = try sim.state(of: .jupiter)","print(\"Jupiter position: \\(jupiterState.position)\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Reversing-Time","type":"heading","level":3,"text":"Reversing Time"},{"code":["\/\/ Switch direction (forward ↔ backward)","sim.swap()","","\/\/ Now updates go backward in time","try sim.update(to: .now.addingDays(-30))"],"type":"codeListing","syntax":"swift"},{"anchor":"Lagrange-Points","type":"heading","level":2,"text":"Lagrange Points"},{"inlineContent":[{"type":"text","text":"Lagrange points are stable\/semi-stable locations in a two-body gravitational system."}],"type":"paragraph"},{"anchor":"Calculate-Lagrange-Point-Position","type":"heading","level":3,"text":"Calculate Lagrange Point Position"},{"code":["\/\/ Sun-Earth L2 (where JWST orbits)","let l2 = try LagrangePoint.calculate(","    point: .l2,","    at: .now,","    majorBody: .sun,","    minorBody: .earth",")","print(\"L2 position: \\(l2.position)\")","print(\"L2 velocity: \\(l2.velocity)\")"],"type":"codeListing","syntax":"swift"},{"anchor":"The-Five-Lagrange-Points","type":"heading","level":3,"text":"The Five Lagrange Points"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Point"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Location"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stability"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Between bodies"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unstable"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Beyond smaller body"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unstable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Beyond larger body","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unstable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"L4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"60° ahead"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Stable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"L5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"60° behind"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Stable","type":"text"}],"type":"paragraph"}]]]},{"anchor":"Jupiters-Galilean-Moons","text":"Jupiter’s Galilean Moons","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Get positions of Io, Europa, Ganymede, and Callisto.","type":"text"}]},{"anchor":"Moon-States","text":"Moon States","type":"heading","level":3},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ Each moon has position and velocity relative to Jupiter","print(\"Io: \\(moons.io.position)\")","print(\"Europa: \\(moons.europa.position)\")","print(\"Ganymede: \\(moons.ganymede.position)\")","print(\"Callisto: \\(moons.callisto.position)\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Checking-Moon-Position","text":"Checking Moon Position","type":"heading","level":3},{"code":["let moons = try Jupiter.moons(at: .now)","","\/\/ X > 0 means east of Jupiter","if moons.io.position.x > 0 {","    print(\"Io is east of Jupiter\")","} else {","    print(\"Io is west of Jupiter\")","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Using-as-CelestialBodies","text":"Using as CelestialBodies","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The moons are also available as celestial bodies:","type":"text"}]},{"code":["for moon in CelestialBody.galileanMoons {","    let eq = try moon.equatorial(at: .now)","    print(\"\\(moon.name): RA \\(eq.rightAscension)h\")","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Planetary-Rotation-Axes","text":"Planetary Rotation Axes","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the orientation of a body’s rotation axis and prime meridian."}]},{"code":["let axis = try CelestialBody.mars.rotationAxis(at: .now)","","\/\/ North pole direction (J2000)","print(\"Pole RA: \\(axis.rightAscension) hours\")","print(\"Pole Dec: \\(axis.declination)°\")","","\/\/ Prime meridian rotation","print(\"Spin angle: \\(axis.spin)°\")","","\/\/ Unit vector toward north pole","let north = axis.north"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is useful for:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculating solar angles on planetary surfaces"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Determining which hemisphere faces Earth","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Rendering accurate planetary graphics","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Atmospheric-Modeling","text":"Atmospheric Modeling","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Model Earth’s atmosphere based on elevation."}]},{"anchor":"Atmosphere-at-Elevation","text":"Atmosphere at Elevation","type":"heading","level":3},{"code":["let atmosphere = try Atmosphere.at(elevation: 5000)  \/\/ 5000m","print(\"Pressure: \\(atmosphere.pressure) mbar\")","print(\"Temperature: \\(atmosphere.temperature)°C\")","print(\"Density: \\(atmosphere.density)\")  \/\/ Relative to sea level"],"type":"codeListing","syntax":"swift"},{"anchor":"Observers-Atmosphere","text":"Observer’s Atmosphere","type":"heading","level":3},{"code":["let observer = Observer(latitude: 39.7, longitude: -104.9, height: 1600)","let atm = try observer.atmosphere","print(\"Local pressure: \\(atm.pressure) mbar\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Extreme-Altitudes","text":"Extreme Altitudes","type":"heading","level":3},{"code":["\/\/ Mount Everest summit","let everest = try Atmosphere.at(elevation: 8848.86)","print(\"Pressure: \\(Int(everest.pressure)) mbar\")  \/\/ ~314 mbar (vs 1013 at sea level)"],"type":"codeListing","syntax":"swift"},{"anchor":"Fixed-Stars","text":"Fixed Stars","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Define and track fixed stars by their J2000 catalog coordinates.","type":"text"}]},{"anchor":"Defining-a-Star","text":"Defining a Star","type":"heading","level":3},{"code":["\/\/ Algol (Beta Persei) - the \"Demon Star\"","let algol = FixedStar(","    name: \"Algol\",","    ra: 3.136148,      \/\/ J2000 RA in hours","    dec: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Sirius - the brightest star","let sirius = FixedStar(","    name: \"Sirius\",","    ra: 6.7525,","    dec: -16.7161,","    distance: 8.6",")"],"type":"codeListing","syntax":"swift"},{"anchor":"Getting-Positions","text":"Getting Positions","type":"heading","level":3},{"code":["\/\/ Ecliptic longitude (for astrological calculations)","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)","","\/\/ Constellation","let constellation = try sirius.constellation(at: .now)"],"type":"codeListing","syntax":"swift"},{"anchor":"Finding-Catalog-Data","text":"Finding Catalog Data","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"J2000 coordinates can be found from:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Hipparcos Catalog","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yale Bright Star Catalog"}]}]}],"type":"unorderedList"},{"anchor":"Observer-Gravity","text":"Observer Gravity","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate local gravitational acceleration:"}]},{"code":["let observer = Observer(latitude: 45.0, longitude: 0.0, height: 0)","let gravity = observer.gravity  \/\/ m\/s²","print(\"Local g: \\(gravity) m\/s²\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This accounts for:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Latitude (Earth’s oblateness)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Altitude (distance from Earth’s center)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/advancedfeatures"]}],"abstract":[{"type":"text","text":"N-body simulations, Lagrange points, Jupiter’s moons, and more."}],"references":{"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link","titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"title":"Astronomy Engine","url":"https:\/\/github.com\/cosinekitty\/astronomy"},"doc://AstronomyKit/documentation/AstronomyKit":{"role":"collection","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"text":" library.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol","type":"topic","title":"AstronomyKit"},"doc://AstronomyKit/documentation/AstronomyKit/GravitySimulation":{"navigatorTitle":[{"text":"GravitySimulation","kind":"identifier"}],"abstract":[{"type":"text","text":"An n-body gravity simulation for tracking object trajectories."}],"type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GravitySimulation","url":"\/documentation\/astronomykit\/gravitysimulation","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GravitySimulation","kind":"identifier"}],"kind":"symbol","title":"GravitySimulation"},"https://simbad.cds.unistra.fr/simbad/":{"type":"link","identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/","titleInlineContent":[{"type":"text","text":"SIMBAD Astronomical Database"}],"title":"SIMBAD Astronomical Database","url":"https:\/\/simbad.cds.unistra.fr\/simbad\/"},"doc://AstronomyKit/documentation/AstronomyKit/LagrangePoint":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LagrangePoint","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"text":"Lagrange point calculation functions.","type":"text"}],"type":"topic","url":"\/documentation\/astronomykit\/lagrangepoint","title":"LagrangePoint","navigatorTitle":[{"text":"LagrangePoint","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LagrangePoint"},"doc://AstronomyKit/documentation/AstronomyKit/Transit":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Transit"}],"title":"Transit","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Transit"}],"abstract":[{"type":"text","text":"Information about a transit of Mercury or Venus across the Sun."}],"url":"\/documentation\/astronomykit\/transit","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Transit"}}}