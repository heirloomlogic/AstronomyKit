{"metadata":{"role":"article","modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","title":"Eclipses"},"sections":[],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"AstronomyKit can search for and predict lunar eclipses, global solar eclipses, and local solar eclipse visibility for specific observer locations."}],"type":"paragraph"},{"text":"Lunar Eclipses","anchor":"Lunar-Eclipses","type":"heading","level":2},{"text":"Finding the Next Lunar Eclipse","anchor":"Finding-the-Next-Lunar-Eclipse","type":"heading","level":3},{"code":["let eclipse = try Eclipse.searchLunar(after: .now)","print(\"\\(eclipse.kind.name) lunar eclipse at \\(eclipse.peak)\")"],"syntax":"swift","type":"codeListing"},{"text":"Eclipse Types","anchor":"Eclipse-Types","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Penumbral"}],"type":"strong"},{"type":"text","text":": Moon passes through Earth’s outer shadow"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Partial"}]},{"type":"text","text":": Part of Moon enters Earth’s umbra"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Total","type":"text"}]},{"type":"text","text":": Entire Moon enters Earth’s umbra"}]}]}],"type":"unorderedList"},{"code":["switch eclipse.kind {","case .total:","    print(\"Total lunar eclipse!\")","case .partial:","    print(\"Partial lunar eclipse\")","case .penumbral:","    print(\"Penumbral lunar eclipse\")","default:","    break","}"],"syntax":"swift","type":"codeListing"},{"text":"Eclipse Timing","anchor":"Eclipse-Timing","type":"heading","level":3},{"code":["let eclipse = try Eclipse.searchLunar(after: .now)","","print(\"Peak: \\(eclipse.peak)\")","print(\"Partial duration: \\(eclipse.partialDuration) minutes\")","print(\"Total duration: \\(eclipse.totalDuration) minutes\")  \/\/ 0 if not total","print(\"Penumbral duration: \\(eclipse.penumbralDuration) minutes\")"],"syntax":"swift","type":"codeListing"},{"text":"All Eclipses in a Date Range","anchor":"All-Eclipses-in-a-Date-Range","type":"heading","level":3},{"code":["let eclipses = try Eclipse.lunarEclipses(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2026, month: 1, day: 1)",")","","for eclipse in eclipses {","    print(\"\\(eclipse.kind.name) on \\(eclipse.peak)\")","}"],"syntax":"swift","type":"codeListing"},{"text":"Global Solar Eclipses","anchor":"Global-Solar-Eclipses","type":"heading","level":2},{"inlineContent":[{"text":"Global solar eclipses describe an eclipse as seen from anywhere on Earth.","type":"text"}],"type":"paragraph"},{"text":"Finding the Next Solar Eclipse","anchor":"Finding-the-Next-Solar-Eclipse","type":"heading","level":3},{"code":["let eclipse = try Eclipse.searchGlobalSolar(after: .now)","print(\"\\(eclipse.kind.name) solar eclipse at \\(eclipse.peak)\")","","\/\/ For total or annular eclipses, get the center line","if eclipse.kind == .total || eclipse.kind == .annular {","    if let lat = eclipse.latitude, let lon = eclipse.longitude {","        print(\"Path center: \\(lat)°, \\(lon)°\")","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"Eclipse Types","anchor":"Eclipse-Types","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Partial","type":"text"}]},{"type":"text","text":": Only part of the Sun is covered"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Annular","type":"text"}],"type":"strong"},{"text":": Moon is too far to fully cover the Sun (ring of fire)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Total","type":"text"}]},{"type":"text","text":": Moon completely covers the Sun"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"All Solar Eclipses in a Range","anchor":"All-Solar-Eclipses-in-a-Range","type":"heading","level":3},{"code":["let eclipses = try Eclipse.globalSolarEclipses(","    from: AstroTime(year: 2024, month: 1, day: 1),","    to: AstroTime(year: 2030, month: 1, day: 1)",")","","for eclipse in eclipses {","    print(\"\\(eclipse.kind.name): \\(eclipse.peak)\")","}"],"syntax":"swift","type":"codeListing"},{"text":"Local Solar Eclipses","anchor":"Local-Solar-Eclipses","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Local solar eclipses describe what an observer at a specific location will see."}],"type":"paragraph"},{"text":"Eclipse for Your Location","anchor":"Eclipse-for-Your-Location","type":"heading","level":3},{"code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let eclipse = try Eclipse.searchLocalSolar(after: .now, from: observer)","","print(\"Type: \\(eclipse.kind.name)\")","print(\"Obscuration: \\(Int(eclipse.obscuration * 100))%\")"],"syntax":"swift","type":"codeListing"},{"text":"Detailed Timing","anchor":"Detailed-Timing","type":"heading","level":3},{"code":["let eclipse = try Eclipse.searchLocalSolar(after: .now, from: observer)","","print(\"Partial begins: \\(eclipse.partialBegin.time)\")","print(\"Peak: \\(eclipse.peak.time)\")","print(\"Partial ends: \\(eclipse.partialEnd.time)\")","","\/\/ For total\/annular eclipses","if let totalBegin = eclipse.totalBegin,","   let totalEnd = eclipse.totalEnd {","    print(\"Totality: \\(totalBegin.time) to \\(totalEnd.time)\")","}"],"syntax":"swift","type":"codeListing"},{"text":"Eclipse Visibility","anchor":"Eclipse-Visibility","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Each event includes altitude information:"}],"type":"paragraph"},{"code":["let event = eclipse.peak","print(\"Time: \\(event.time)\")","print(\"Sun altitude: \\(event.altitude)°\")","","if event.isVisible {","    print(\"Sun is above the horizon\")","}","","if eclipse.isVisible {","    print(\"At least part of the eclipse is visible\")","}"],"syntax":"swift","type":"codeListing"},{"text":"All Local Eclipses in a Range","anchor":"All-Local-Eclipses-in-a-Range","type":"heading","level":3},{"code":["let observer = Observer(latitude: 35.0, longitude: -120.0)","let eclipses = try Eclipse.localSolarEclipses(","    from: .now,","    to: .now.addingDays(365 * 10),","    observer: observer",")","","for eclipse in eclipses {","    if eclipse.obscuration > 0.5 {","        print(\"Notable eclipse: \\(Int(eclipse.obscuration * 100))% on \\(eclipse.peak.time)\")","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"Eclipse Search Tips","anchor":"Eclipse-Search-Tips","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Search far ahead"}]},{"type":"text","text":": Eclipses are rare—search years in advance"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Check visibility","type":"text"}]},{"type":"text","text":": Local eclipses may occur when the Sun is below the horizon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Consider obscuration"}],"type":"strong"},{"text":": Even partial eclipses can be interesting when obscuration is high","type":"text"}]}]}],"type":"orderedList"}]}],"variants":[{"paths":["\/documentation\/astronomykit\/eclipses"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","seeAlsoSections":[{"generated":true,"anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroSearch","doc:\/\/AstronomyKit\/documentation\/AstronomyKi