{"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses"},"metadata":{"title":"Eclipses","roleHeading":"Article","role":"article","modules":[{"name":"AstronomyKit"}]},"kind":"article","abstract":[{"type":"text","text":"Predict lunar and solar eclipses with detailed timing information."}],"seeAlsoSections":[{"anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse"],"title":"Events","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/eclipses"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit can search for and predict lunar eclipses, global solar eclipses, and local solar eclipse visibility for specific observer locations."}]},{"level":2,"type":"heading","text":"Lunar Eclipses","anchor":"Lunar-Eclipses"},{"level":3,"type":"heading","text":"Finding the Next Lunar Eclipse","anchor":"Finding-the-Next-Lunar-Eclipse"},{"type":"codeListing","syntax":"swift","code":["let eclipse = try Eclipse.searchLunar(after: .now)","print(\"\\(eclipse.kind.name) lunar eclipse at \\(eclipse.peak)\")"]},{"level":3,"type":"heading","text":"Eclipse Types","anchor":"Eclipse-Types"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Penumbral","type":"text"}],"type":"strong"},{"text":": Moon passes through Earth’s outer shadow","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Partial"}]},{"type":"text","text":": Part of Moon enters Earth’s umbra"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Total","type":"text"}]},{"text":": Entire Moon enters Earth’s umbra","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":"swift","code":["switch eclipse.kind {","case .total:","    print(\"Total lunar eclipse!\")","case .partial:","    print(\"Partial lunar eclipse\")","case .penumbral:","    print(\"Penumbral lunar eclipse\")","default:","    break","}"]},{"level":3,"type":"heading","text":"Eclipse Timing","anchor":"Eclipse-Timing"},{"type":"codeListing","syntax":"swift","code":["let eclipse = try Eclipse.searchLunar(after: .now)","","print(\"Peak: \\(eclipse.peak)\")","print(\"Partial duration: \\(eclipse.sdPartial) minutes\")","print(\"Total duration: \\(eclipse.sdTotal) minutes\")  \/\/ 0 if not total","print(\"Penumbral duration: \\(eclipse.sdPenumbra) minutes\")"]},{"level":3,"type":"heading","text":"All Eclipses in a Date Range","anchor":"All-Eclipses-in-a-Date-Range"},{"type":"codeListing","syntax":"swift","code":["let eclipses = try Eclipse.lunarEclipses(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2026, month: 1, day: 1)",")","","for eclipse in eclipses {","    print(\"\\(eclipse.kind.name) on \\(eclipse.peak)\")","}"]},{"level":2,"type":"heading","text":"Global Solar Eclipses","anchor":"Global-Solar-Eclipses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Global solar eclipses describe an eclipse as seen from anywhere on Earth."}]},{"level":3,"type":"heading","text":"Finding the Next Solar Eclipse","anchor":"Finding-the-Next-Solar-Eclipse"},{"type":"codeListing","syntax":"swift","code":["let eclipse = try Eclipse.searchGlobalSolar(after: .now)","print(\"\\(eclipse.kind.name) solar eclipse at \\(eclipse.peak)\")","","\/\/ For total or annular eclipses, get the center line","if eclipse.kind == .total || eclipse.kind == .annular {","    if let lat = eclipse.latitude, let lon = eclipse.longitude {","        print(\"Path center: \\(lat)°, \\(lon)°\")","    }","}"]},{"level":3,"type":"heading","text":"Eclipse Types","anchor":"Eclipse-Types"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Partial","type":"text"}],"type":"strong"},{"text":": Only part of the Sun is covered","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Annular","type":"text"}],"type":"strong"},{"type":"text","text":": Moon is too far to fully cover the Sun (ring of fire)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Total"}],"type":"strong"},{"text":": Moon completely covers the Sun","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"All Solar Eclipses in a Range","anchor":"All-Solar-Eclipses-in-a-Range"},{"type":"codeListing","syntax":"swift","code":["let eclipses = try Eclipse.globalSolarEclipses(","    from: AstroTime(year: 2024, month: 1, day: 1),","    to: AstroTime(year: 2030, month: 1, day: 1)",")","","for eclipse in eclipses {","    print(\"\\(eclipse.kind.name): \\(eclipse.peak)\")","}"]},{"level":2,"type":"heading","text":"Local Solar Eclipses","anchor":"Local-Solar-Eclipses"},{"type":"paragraph","inlineContent":[{"text":"Local solar eclipses describe what an observer at a specific location will see.","type":"text"}]},{"level":3,"type":"heading","text":"Eclipse for Your Location","anchor":"Eclipse-for-Your-Location"},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let eclipse = try Eclipse.searchLocalSolar(after: .now, from: observer)","","print(\"Type: \\(eclipse.kind.name)\")","print(\"Obscuration: \\(Int(eclipse.obscuration * 100))%\")"]},{"level":3,"type":"heading","text":"Detailed Timing","anchor":"Detailed-Timing"},{"type":"codeListing","syntax":"swift","code":["let eclipse = try Eclipse.searchLocalSolar(after: .now, from: observer)","","print(\"Partial begins: \\(eclipse.partialBegin.time)\")","print(\"Peak: \\(eclipse.peak.time)\")","print(\"Partial ends: \\(eclipse.partialEnd.time)\")","","\/\/ For total\/annular eclipses","if let totalBegin = eclipse.totalBegin,","   let totalEnd = eclipse.totalEnd {","    print(\"Totality: \\(totalBegin.time) to \\(totalEnd.time)\")","}"]},{"level":3,"type":"heading","text":"Eclipse Visibility","anchor":"Eclipse-Visibility"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each event includes altitude information:"}]},{"type":"codeListing","syntax":"swift","code":["let event = eclipse.peak","print(\"Time: \\(event.time)\")","print(\"Sun altitude: \\(event.altitude)°\")","","if event.isVisible {","    print(\"Sun is above the horizon\")","}","","if eclipse.isVisible {","    print(\"At least part of the eclipse is visible\")","}"]},{"level":3,"type":"heading","text":"All Local Eclipses in a Range","anchor":"All-Local-Eclipses-in-a-Range"},{"type":"codeListing","syntax":"swift","code":["let observer = Observer(latitude: 35.0, longitude: -120.0)","let eclipses = try Eclipse.localSolarEclipses(","    from: .now,","    to: .now.addingDays(365 * 10),","    from: observer",")","","for eclipse in eclipses {","    if eclipse.obscuration > 0.5 {","        print(\"Notable eclipse: \\(Int(eclipse.obscuration * 100))% on \\(eclipse.peak.time)\")","    }","}"]},{"level":2,"type":"heading","text":"Eclipse Search Tips","anchor":"Eclipse-Search-Tips"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Search far ahead","type":"text"}],"type":"strong"},{"text":": Eclipses are rare—search years in advance","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Check visibility","type":"text"}],"type":"strong"},{"type":"text","text":": Local eclipses may occur when the Sun is below the horizon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Consider obscuration"}],"type":"strong"},{"text":": Even partial eclipses can be interesting when obscuration is high","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"}]}],"sections":[],"references":{"doc://AstronomyKit/documentation/AstronomyKit/GlobalSolarEclipse":{"kind":"symbol","title":"GlobalSolarEclipse","type":"topic","url":"\/documentation\/astronomykit\/globalsolareclipse","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GlobalSolarEclipse","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","navigatorTitle":[{"text":"GlobalSolarEclipse","kind":"identifier"}],"abstract":[{"type":"text","text":"Information about a solar eclipse as seen globally."}]},"doc://AstronomyKit/documentation/AstronomyKit/LunarEclipse":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LunarEclipse","kind":"identifier"}],"abstract":[{"text":"Information about a lunar eclipse.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","title":"LunarEclipse","url":"\/documentation\/astronomykit\/lunareclipse","navigatorTitle":[{"text":"LunarEclipse","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit/SeasonsAndEvents":{"role":"article","abstract":[{"text":"Calculate equinoxes, solstices, planetary apsides, elongations, and transits.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","url":"\/documentation\/astronomykit\/seasonsandevents","type":"topic","kind":"article","title":"Seasons and Events"},"doc://AstronomyKit/documentation/AstronomyKit/Seasons":{"type":"topic","navigatorTitle":[{"kind":"identifier