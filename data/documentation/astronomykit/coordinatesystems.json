{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"AstronomyKit supports multiple coordinate systems and provides rotation matrices for transforming between them. Understanding these systems is essential for precise astronomical work.","type":"text"}],"type":"paragraph"},{"anchor":"Coordinate-Systems","level":2,"text":"Coordinate Systems","type":"heading"},{"anchor":"Equatorial-J2000-EQJ","level":3,"text":"Equatorial J2000 (EQJ)","type":"heading"},{"inlineContent":[{"type":"text","text":"The standard reference frame used by most star catalogs:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Origin: Earth’s center"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Fundamental plane: Earth’s equator at J2000.0 epoch"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Primary direction: Vernal equinox at J2000.0"}]}]}],"type":"unorderedList"},{"code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .j2000)","print(\"RA: \\(eq.rightAscension)h, Dec: \\(eq.declination)°\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Equatorial-of-Date-EQD","level":3,"text":"Equatorial of Date (EQD)","type":"heading"},{"inlineContent":[{"type":"text","text":"Accounts for precession of Earth’s axis:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Same as EQJ but referenced to the current date","type":"text"}]}]}],"type":"unorderedList"},{"code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift","type":"codeListing"},{"anchor":"Ecliptic-ECL","level":3,"text":"Ecliptic (ECL)","type":"heading"},{"inlineContent":[{"type":"text","text":"Referenced to the plane of Earth’s orbit:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fundamental plane: Ecliptic (Earth’s orbital plane)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Primary direction: Vernal equinox"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["let lon = try CelestialBody.jupiter.eclipticLongitude(at: .now)","print(\"Ecliptic longitude: \\(lon)°\")","","\/\/ Full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"λ: \\(sunPos.longitude)°, β: \\(sunPos.latitude)°\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Horizontal-HOR","level":3,"text":"Horizontal (HOR)","type":"heading"},{"inlineContent":[{"type":"text","text":"Local sky coordinates for an observer:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Altitude: Height above the horizon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Azimuth: Compass direction from north"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["let observer = Observer(latitude: 40.0, longitude: -74.0)","let hor = try CelestialBody.venus.horizon(at: .now, from: observer)","print(\"Alt: \\(hor.altitude)°, Az: \\(hor.azimuth)°\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Galactic-GAL","level":3,"text":"Galactic (GAL)","type":"heading"},{"inlineContent":[{"type":"text","text":"Referenced to the Milky Way:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Fundamental plane: Galactic plane","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Primary direction: Galactic center"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Available via rotation matrices (see below).","type":"text"}],"type":"paragraph"},{"anchor":"Rotation-Matrices","level":2,"text":"Rotation Matrices","type":"heading"},{"anchor":"Creating-Rotation-Matrices","level":3,"text":"Creating Rotation Matrices","type":"heading"},{"code":["\/\/ Equatorial J2000 to Ecliptic","let eqjToEcl = try RotationMatrix.equatorialJ2000ToEcliptic()","","\/\/ Ecliptic to Equatorial J2000","let eclToEqj = try RotationMatrix.eclipticToEquatorialJ2000()","","\/\/ Equatorial J2000 to Galactic","let eqjToGal = try RotationMatrix.equatorialJ2000ToGalactic()"],"syntax":"swift","type":"codeListing"},{"anchor":"Time-Dependent-Rotations","level":3,"text":"Time-Dependent Rotations","type":"heading"},{"inlineContent":[{"text":"Some transformations require a time for precession\/nutation:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Equatorial J2000 to Equatorial of Date","let time = AstroTime.now","let eqjToEqd = try RotationMatrix.equatorialJ2000ToEquatorialOfDate(at: time)","","\/\/ Equatorial to Horizontal (requires time and observer)","let observer = Observer.greenwich","let eqjToHor = try RotationMatrix.equatorialJ2000ToHorizon(at: time, from: observer)"],"syntax":"swift","type":"codeListing"},{"anchor":"Applying-Rotations","level":3,"text":"Applying Rotations","type":"heading"},{"inlineContent":[{"type":"text","text":"Transform a vector using a rotation matrix:"}],"type":"paragraph"},{"code":["let position = try CelestialBody.mars.geoPosition(at: .now)","let rotation = try RotationMatrix.equatorialJ2000ToEcliptic()","let eclipticPosition = position.rotated(by: rotation)"],"syntax":"swift","type":"codeListing"},{"anchor":"Matrix-Operations","level":3,"text":"Matrix Operations","type":"heading"},{"code":["\/\/ Identity (no rotation)","let identity = RotationMatrix.identity","","\/\/ Inverse (reverse rotation)","let forward = try RotationMatrix.equatorialJ2000ToEcliptic()","let reverse = forward.inverse","","\/\/ Combine rotations","let combined = try forward.combined(with: anotherRotation)","","\/\/ Pivot around an axis","let rotated = try RotationMatrix.pivot(axis: 2, angle: 45.0)  \/\/ 45° around Z"],"syntax":"swift","type":"codeListing"},{"anchor":"Vector-Types","level":2,"text":"Vector Types","type":"heading"},{"anchor":"Vector3D","level":3,"text":"Vector3D","type":"heading"},{"inlineContent":[{"type":"text","text":"A 3D Cartesian position vector:"}],"type":"paragraph"},{"code":["let pos = try CelestialBody.jupiter.geoPosition(at: .now)","print(\"X: \\(pos.x) AU\")","print(\"Y: \\(pos.y) AU\")","print(\"Z: \\(pos.z) AU\")","print(\"Magnitude: \\(pos.magnitude) AU\")","","\/\/ Normalize to unit vector","let direction = pos.normalized"],"syntax":"swift","type":"codeListing"},{"anchor":"StateVector","level":3,"text":"StateVector","type":"heading"},{"inlineContent":[{"type":"text","text":"Position and velocity together:"}],"type":"paragraph"},{"code":["let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")  \/\/ AU\/day"],"syntax":"swift","type":"codeListing"},{"anchor":"Spherical-Coordinates","level":2,"text":"Spherical Coordinates","type":"heading"},{"inlineContent":[{"text":"Used for Moon’s ecliptic position:","type":"text"}],"type":"paragraph"},{"code":["let moonPos = try Moon.eclipticPosition(at: .now)","print(\"Longitude: \\(moonPos.longitude)°\")","print(\"Latitude: \\(moonPos.latitude)°\")","print(\"Distance: \\(moonPos.distance) AU\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Atmospheric-Effects","level":2,"text":"Atmospheric Effects","type":"heading"},{"anchor":"Refraction","level":3,"text":"Refraction","type":"heading"},{"inlineContent":[{"type":"text","text":"Atmospheric refraction bends light, affecting apparent altitude:"}],"type":"paragraph"},{"code":["\/\/ Normal refraction correction (default)","let apparent = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction (geometric position)","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons refraction model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"],"syntax":"swift","type":"codeListing"},{"anchor":"Aberration","level":3,"text":"Aberration","type":"heading"},{"inlineContent":[{"type":"text","text":"Light-time and stellar aberration affect apparent positions:"}],"type":"paragraph"},{"code":["\/\/ With aberration correction (default) - what you actually see","let apparent = try body.geoPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geoPosition(at: .now, aberration: .none)"],"syntax":"swift","type":"codeListing"},{"anchor":"Available-Rotations","level":2,"text":"Available Rotations","type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"From"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"To"}]}],[{"type":"paragraph","inlineContent":[{"text":"Method","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"EQJ","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"ECL","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"equatorialJ2000ToEcliptic()","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"ECL"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQJ"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"eclipticToEquatorialJ2000()"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQJ"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQD"}]}],[{"type":"paragraph","inlineContent":[{"code":"equatorialJ2000ToEquatorialOfDate(at:)","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQD"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQJ"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"equatorialOfDateToEquatorialJ2000(at:)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"EQJ"}]}],[{"type":"