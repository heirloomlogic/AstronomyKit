{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"AstronomyKit supports multiple coordinate systems and provides rotation matrices for transforming between them. Understanding these systems is essential for precise astronomical work."}],"type":"paragraph"},{"level":2,"anchor":"Coordinate-Systems","text":"Coordinate Systems","type":"heading"},{"level":3,"anchor":"Equatorial-J2000-EQJ","text":"Equatorial J2000 (EQJ)","type":"heading"},{"inlineContent":[{"type":"text","text":"The standard reference frame used by most star catalogs:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Origin: Earth’s center"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fundamental plane: Earth’s equator at J2000.0 epoch"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Primary direction: Vernal equinox at J2000.0","type":"text"}]}]}],"type":"unorderedList"},{"code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .j2000)","print(\"RA: \\(eq.rightAscension)h, Dec: \\(eq.declination)°\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Equatorial-of-Date-EQD","text":"Equatorial of Date (EQD)","type":"heading"},{"inlineContent":[{"text":"Accounts for precession of Earth’s axis:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Same as EQJ but referenced to the current date","type":"text"}]}]}],"type":"unorderedList"},{"code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"Ecliptic (ECL)","type":"heading","anchor":"Ecliptic-ECL"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Referenced to the plane of Earth’s orbit:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Fundamental plane: Ecliptic (Earth’s orbital plane)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Primary direction: Vernal equinox"}]}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["let lon = try CelestialBody.jupiter.eclipticLongitude(at: .now)","print(\"Ecliptic longitude: \\(lon)°\")","","\/\/ Full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"λ: \\(sunPos.longitude)°, β: \\(sunPos.latitude)°\")"]},{"level":3,"text":"Horizontal (HOR)","type":"heading","anchor":"Horizontal-HOR"},{"type":"paragraph","inlineContent":[{"text":"Local sky coordinates for an observer:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Altitude: Height above the horizon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Azimuth: Compass direction from north"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["let observer = Observer(latitude: 40.0, longitude: -74.0)","let hor = try CelestialBody.venus.horizon(at: .now, from: observer)","print(\"Alt: \\(hor.altitude)°, Az: \\(hor.azimuth)°\")"]},{"level":3,"text":"Galactic (GAL)","type":"heading","anchor":"Galactic-GAL"},{"type":"paragraph","inlineContent":[{"text":"Referenced to the Milky Way:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Fundamental plane: Galactic plane"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Primary direction: Galactic center"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Available via rotation matrices (see below)."}],"type":"paragraph"},{"level":2,"text":"Rotation Matrices","type":"heading","anchor":"Rotation-Matrices"},{"level":3,"text":"Creating Rotation Matrices","type":"heading","anchor":"Creating-Rotation-Matrices"},{"syntax":"swift","type":"codeListing","code":["\/\/ Equatorial J2000 to Ecliptic","let eqjToEcl = try RotationMatrix.equatorialJ2000ToEcliptic()","","\/\/ Ecliptic to Equatorial J2000","let eclToEqj = try RotationMatrix.eclipticToEquatorialJ2000()","","\/\/ Equatorial J2000 to Galactic","let eqjToGal = try RotationMatrix.equatorialJ2000ToGalactic()"]},{"level":3,"text":"Time-Dependent Rotations","type":"heading","anchor":"Time-Dependent-Rotations"},{"inlineContent":[{"text":"Some transformations require a time for precession\/nutation:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Equatorial J2000 to Equatorial of Date","let time = AstroTime.now","let eqjToEqd = try RotationMatrix.equatorialJ2000ToEquatorialOfDate(at: time)","","\/\/ Equatorial to Horizontal (requires time and observer)","let observer = Observer.greenwich","let eqjToHor = try RotationMatrix.equatorialJ2000ToHorizon(at: time, from: observer)"]},{"level":3,"text":"Applying Rotations","type":"heading","anchor":"Applying-Rotations"},{"inlineContent":[{"type":"text","text":"Transform a vector using a rotation matrix:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let position = try CelestialBody.mars.geocentricPosition(at: .now)","let rotation = try RotationMatrix.equatorialJ2000ToEcliptic()","let eclipticPosition = position.rotated(by: rotation)"]},{"level":3,"text":"Matrix Operations","type":"heading","anchor":"Matrix-Operations"},{"syntax":"swift","type":"codeListing","code":["\/\/ Identity (no rotation)","let identity = RotationMatrix.identity","","\/\/ Inverse (reverse rotation)","let forward = try RotationMatrix.equatorialJ2000ToEcliptic()","let reverse = forward.inverse","","\/\/ Combine rotations","let combined = try forward.combined(with: anotherRotation)","","\/\/ Pivot around an axis","let rotated = try RotationMatrix.pivot(axis: 2, angle: 45.0)  \/\/ 45° around Z"]},{"level":2,"text":"Vector Types","type":"heading","anchor":"Vector-Types"},{"level":3,"text":"Vector3D","type":"heading","anchor":"Vector3D"},{"inlineContent":[{"type":"text","text":"A 3D Cartesian position vector:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let pos = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"X: \\(pos.x) AU\")","print(\"Y: \\(pos.y) AU\")","print(\"Z: \\(pos.z) AU\")","print(\"Magnitude: \\(pos.magnitude) AU\")","","\/\/ Normalize to unit vector","let direction = pos.normalized"]},{"level":3,"text":"StateVector","type":"heading","anchor":"StateVector"},{"inlineContent":[{"text":"Position and velocity together:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")  \/\/ AU\/day"]},{"level":2,"text":"Spherical Coordinates","type":"heading","anchor":"Spherical-Coordinates"},{"inlineContent":[{"type":"text","text":"Used for Moon’s ecliptic position:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let moonPos = try Moon.eclipticPosition(at: .now)","print(\"Longitude: \\(moonPos.longitude)°\")","print(\"Latitude: \\(moonPos.latitude)°\")","print(\"Distance: \\(moonPos.distance) AU\")"]},{"level":2,"text":"Atmospheric Effects","type":"heading","anchor":"Atmospheric-Effects"},{"level":3,"text":"Refraction","type":"heading","anchor":"Refraction"},{"inlineContent":[{"type":"text","text":"Atmospheric refraction bends light, affecting apparent altitude:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Normal refraction correction (default)","let apparent = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction (geometric position)","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons refraction model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"]},{"level":3,"text":"Computing Refraction Directly","type":"heading","anchor":"Computing-Refraction-Directly"},{"inlineContent":[{"type":"text","text":"Calculate refraction angles independently of a coordinate conversion:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ How much does refraction raise an object at 5° geometric altitude?","let offset = Refraction.normal.refractionAngle(at: 5.0)","print(\"Refraction at 5°: +\\(offset)°\")","","\/\/ Given an apparent altitude of 5°, what was the geometric altitude?","let inverse = Refraction.normal.inverseRefractionAngle(at: 5.0)","let geometric = 5.0 - inverse"]},{"level":3,"text":"Aberration","type":"heading","anchor":"Aberration"},{"inlineContent":[{"text":"Light-time and stellar aberration affect apparent positions:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ With aberration correction (default) - what you actually see","let apparent = try body.geocentricPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geocentricPosition(at: .now, aberration: .none)"]},{"level":2,"text":"Available Rotations","type":"heading","anchor":"Available-Rotations"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"From"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"To"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Method","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"EQJ"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ECL"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"equatorialJ2000ToEcliptic()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"ECL"}],"type":"paragraph"}],[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"eclipticToEquatorialJ2000()","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"EQD","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"equatorialJ2000ToEquatorialOfDate(at:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"EQD","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"equatorialOfDateToEquatorialJ2000(at:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"EQJ"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"HOR"}],"type":"paragraph"}],[{"inlineContent":[{"code":"equatorialJ2000ToHorizon(at:from:)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"HOR","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"EQJ"}],"type":"paragraph"}],[{"inlineContent":[{"code":"horizonToEquatorialJ2000(at:from:)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GAL"}],"type":"paragraph"}],[{"inlineContent":[{"code":"equatorialJ2000ToGalactic()","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"GAL"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"EQJ"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"galacticToEquatorialJ2000()"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"ECL","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"HOR"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"eclipticToHorizon(at:from:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"HOR"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ECL","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"horizonToEcliptic(at:from:)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"EQD","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ECL"}],"type":"paragraph"}],[{"inli