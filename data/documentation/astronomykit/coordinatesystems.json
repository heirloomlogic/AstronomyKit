quatorial of Date (EQD)","type":"heading","anchor":"Equatorial-of-Date-EQD"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Accounts for precession of Earth’s axis:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as EQJ but referenced to the current date"}]}]}],"type":"unorderedList"},{"type":"codeListing","code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift"},{"level":3,"text":"Ecliptic (ECL)","type":"heading","anchor":"Ecliptic-ECL"},{"type":"paragraph","inlineContent":[{"text":"Referenced to the plane of Earth’s orbit:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fundamental plane: Ecliptic (Earth’s orbital plane)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Primary direction: Vernal equinox"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","code":["let lon = try CelestialBody.jupiter.eclipticLongitude(at: .now)","print(\"Ecliptic longitude: \\(lon)°\")","","\/\/ Full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"λ: \\(sunPos.longitude)°, β: \\(sunPos.latitude)°\")"],"syntax":"swift"},{"level":3,"text":"Horizontal (HOR)","type":"heading","anchor":"Horizontal-HOR"},{"type":"paragraph","inlineContent":[{"text":"Local sky coordinates for an observer:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Altitude: Height above the horizon"}]}]},{"content":[{"inlineContent":[{"text":"Azimuth: Compass direction from north","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","code":["let observer = Observer(latitude: 40.0, longitude: -74.0)","let hor = try CelestialBody.venus.horizon(at: .now, from: observer)","print(\"Alt: \\(hor.altitude)°, Az: \\(hor.azimuth)°\")"],"syntax":"swift"},{"level":3,"text":"Galactic (GAL)","type":"heading","anchor":"Galactic-GAL"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Referenced to the Milky Way:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Fundamental plane: Galactic plane","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Primary direction: Galactic center"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Available via rotation matrices (see below).","type":"text"}]},{"level":2,"text":"Rotation Matrices","type":"heading","anchor":"Rotation-Matrices"},{"level":3,"text":"Creating Rotation Matrices","type":"heading","anchor":"Creating-Rotation-Matrices"},{"type":"codeListing","code":["\/\/ Equatorial J2000 to Ecliptic","let eqjToEcl = try RotationMatrix.equatorialJ2000ToEcliptic()","","\/\/ Ecliptic to Equatorial J2000","let eclToEqj = try RotationMatrix.eclipticToEquatorialJ2000()","","\/\/ Equatorial J2000 to Galactic","let eqjToGal = try RotationMatrix.equatorialJ2000ToGalactic()"],"syntax":"swift"},{"level":3,"text":"Time-Dependent Rotations","type":"heading","anchor":"Time-Dependent-Rotations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some transformations require a time for precession\/nutation:"}]},{"type":"codeListing","code":["\/\/ Equatorial J2000 to Equatorial of Date","let time = AstroTime.now","let eqjToEqd = try RotationMatrix.equatorialJ2000ToEquatorialOfDate(at: time)","","\/\/ Equatorial to Horizontal (requires time and observer)","let observer = Observer.greenwich","let eqjToHor = try RotationMatrix.equatorialJ2000ToHorizon(at: time, from: observer)"],"syntax":"swift"},{"level":3,"text":"Applying Rotations","type":"heading","anchor":"Applying-Rotations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transform a vector using a rotation matrix:"}]},{"type":"codeListing","code":["let position = try CelestialBody.mars.geoPosition(at: .now)","let rotation = try RotationMatrix.equatorialJ2000ToEcliptic()","let eclipticPosition = position.rotated(by: rotation)"],"syntax":"swift"},{"level":3,"text":"Matrix Operations","type":"heading","anchor":"Matrix-Operations"},{"type":"codeListing","code":["\/\/ Identity (no rotation)","let identity = RotationMatrix.identity","","\/\/ Inverse (reverse rotation)","let forward = try RotationMatrix.equatorialJ2000ToEcliptic()","let reverse = forward.inverse","","\/\/ Combine rotations","let combined = try forward.combined(with: anotherRotation)","","\/\/ Pivot around an axis","let rotated = try RotationMatrix.pivot(axis: 2, angle: 45.0)  \/\/ 45° around Z"],"syntax":"swift"},{"level":2,"text":"Vector Types","type":"heading","anchor":"Vector-Types"},{"level":3,"text":"Vector3D","type":"heading","anchor":"Vector3D"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A 3D Cartesian position vector:"}]},{"type":"codeListing","code":["let pos = try CelestialBody.jupiter.geoPosition(at: .now)","print(\"X: \\(pos.x) AU\")","print(\"Y: \\(pos.y) AU\")","print(\"Z: \\(pos.z) AU\")","print(\"Magnitude: \\(pos.magnitude) AU\")","","\/\/ Normalize to unit vector","let direction = pos.normalized"],"syntax":"swift"},{"level":3,"text":"StateVector","type":"heading","anchor":"StateVector"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Position and velocity together:"}]},{"type":"codeListing","code":["let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")  \/\/ AU\/day"],"syntax":"swift"},{"level":2,"text":"Spherical Coordinates","type":"heading","anchor":"Spherical-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Used for Moon’s ecliptic position:"}]},{"type":"codeListing","code":["let moonPos = try Moon.eclipticPosition(at: .now)","print(\"Longitude: \\(moonPos.longitude)°\")","print(\"Latitude: \\(moonPos.latitude)°\")","print(\"Distance: \\(moonPos.distance) AU\")"],"syntax":"swift"},{"level":2,"text":"Atmospheric Effects","type":"heading","anchor":"Atmospheric-Effects"},{"le