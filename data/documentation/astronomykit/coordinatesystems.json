ext","text":"Primary direction: Vernal equinox at J2000.0"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .j2000)","print(\"RA: \\(eq.rightAscension)h, Dec: \\(eq.declination)°\")"]},{"type":"heading","text":"Equatorial of Date (EQD)","anchor":"Equatorial-of-Date-EQD","level":3},{"inlineContent":[{"text":"Accounts for precession of Earth’s axis:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Same as EQJ but referenced to the current date","type":"text"}]}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .ofDate)"]},{"type":"heading","text":"Ecliptic (ECL)","anchor":"Ecliptic-ECL","level":3},{"inlineContent":[{"type":"text","text":"Referenced to the plane of Earth’s orbit:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Fundamental plane: Ecliptic (Earth’s orbital plane)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Primary direction: Vernal equinox","type":"text"}]}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["let lon = try CelestialBody.jupiter.eclipticLongitude(at: .now)","print(\"Ecliptic longitude: \\(lon)°\")","","\/\/ Full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"λ: \\(sunPos.longitude)°, β: \\(sunPos.latitude)°\")"]},{"type":"heading","level":3,"text":"Horizontal (HOR)","anchor":"Horizontal-HOR"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Local sky coordinates for an observer:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Altitude: Height above the horizon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Azimuth: Compass direction from north","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["let observer = Observer(latitude: 40.0, longitude: -74.0)","let hor = try CelestialBody.venus.horizon(at: .now, from: observer)","print(\"Alt: \\(hor.altitude)°, Az: \\(hor.azimuth)°\")"]},{"type":"heading","level":3,"text":"Galactic (GAL)","anchor":"Galactic-GAL"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Referenced to the Milky Way:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Fundamental plane: Galactic plane","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Primary direction: Galactic center","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Available via rotation matrices (see below)."}]},{"type":"heading","anchor":"Rotation-Matrices","level":2,"text":"Rotation Matrices"},{"type":"heading","anchor":"Creating-Rotation-Matrices","level":3,"text":"Creating Rotation Matrices"},{"type":"codeListing","syntax":"swift","code":["\/\/ Equatorial J2000 to Ecliptic","let eqjToEcl = try RotationMatrix.equatorialJ2000ToEcliptic()","","\/\/ Ecliptic to Equatorial J2000","let eclToEqj = try RotationMatrix.eclipticToEquatorialJ2000()","","\/\/ Equatorial J2000 to Galactic","let eqjToGal = try RotationMatrix.equatorialJ2000ToGalactic()"]},{"type":"heading","level":3,"text":"Time-Dependent Rotations","anchor":"Time-Dependent-Rotations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some transformations require a time for precession\/nutation:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Equatorial J2000 to Equatorial of Date","let time = AstroTime.now","let eqjToEqd = try RotationMatrix.equatorialJ2000ToEquatorialOfDate(at: time)","","\/\/ Equatorial to Horizontal (requires time and observer)","let observer = Observer.greenwich","let eqjToHor = try RotationMatrix.equatorialJ2000ToHorizon(at: time, from: observer)"]},{"type":"heading","text":"Applying Rotations","anchor":"Applying-Rotations","level":3},{"inlineContent":[{"text":"Transform a vector using a rotation matrix:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let position = try CelestialBody.mars.geocentricPosition(at: .now)","let rotation = try RotationMatrix.equatorialJ2000ToEcliptic()","let eclipticPosition = position.rotated(by: rotation)"]},{"type":"heading","text":"Matrix Operations","anchor":"Matrix-Operations","level":3},{"syntax":"swift","type":"codeListing","code":["\/\/ Identity (no rotation)","let identity = RotationMatrix.identity","","\/\/ Inverse (reverse rotation)","let forward = try RotationMatrix.equatorialJ2000ToEcliptic()","let reverse = forward.inverse","","\/\/ Combine rotations","let combined = try forward.combined(with: anotherRotation)","","\/\/ Pivot around an axis","let rotated = try RotationMatrix.pivot(axis: 2, angle: 45.0)  \/\/ 45° around Z"]},{"type":"heading","text":"Vector Types","anchor":"Vector-Types","level":2},{"type":"heading","text":"Vector3D","anchor":"Vector3D","level":3},{"inlineContent":[{"type":"text","text":"A 3D Cartesian position vector:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let pos = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"X: \\(pos.x) AU\")","print(\"Y: \\(pos.y) AU\")","print(\"Z: \\(pos.z) AU\")","print(\"Magnitude: \\(pos.magnitude) AU\")","","\/\/ Normalize to unit vector","let direction = pos.normalized"]},{"type":"heading","text":"StateVector","anchor":"StateVector","level":3},{"inlineContent":[{"type":"text","text":"Position and velocity together:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")  \/\/ AU\/day"]},{"type":"heading","text":"Spherical Coordinates","anchor":"Spherical-Coordinates","level":2},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Spherical"},{"type":"text","text":" type (latitude, longitude, distance) is produced by converting"},{"type":"text","text":" "},{"type":"text","text":"a position vector:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let vector = try CelestialBody.mars.geocentricPosition(at: .now)","let spherical = vector.toSpherical()","print(\"Longitude: \\(spherical.longitude)°\")","print(\"Latitude: \\(spherical.latitude)°\")","print(\"Distance: \\(spherical.distance) AU\")"]},{"type":"heading","text":"Atmospheric Effects","anchor":"Atmospheric-Effects","level":2},{"type":"heading","text":"Refraction","anchor":"Refraction","level":3},{"inlineContent":[{"type":"text","text":"Atmospheric refraction bends light, affecting apparent altitude:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Normal refraction correction (default)","let apparent = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction (geometric position)","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons refraction model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"]},{"type":"heading","text":"Computing Refraction Directly","anchor":"Computing-Refraction-Directly","level":3},{"inlineContent":[{"type":"text","text":"Calculate refraction angles independently of a coordinate conversion:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ How much does refraction raise an object at 5° geometric altitude?","let offset = Refraction.normal.refractionAngle(at: 5.0)","print(\"Refraction at 5°: +\\(offset)°\")","","\/\/ Given an apparent altitude of 5°, what was the geometric altitude?","let inverse = Refraction.normal.inverseRefractionAngle(at: 5.0)","let geometric = 5.0 - inverse"]},{"type":"heading","text":"Aberration","anchor":"Aberration","level":3},{"inlineContent":[{"type":"text","text":"Light-time and stellar aberration affect apparent positions:"}],