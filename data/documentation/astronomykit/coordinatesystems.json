{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"AstronomyKit supports multiple coordinate systems and provides rotation matrices for transforming between them. Understanding these systems is essential for precise astronomical work."}],"type":"paragraph"},{"anchor":"Coordinate-Systems","text":"Coordinate Systems","type":"heading","level":2},{"anchor":"Equatorial-J2000-EQJ","text":"Equatorial J2000 (EQJ)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The standard reference frame used by most star catalogs:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Origin: Earth’s center","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Fundamental plane: Earth’s equator at J2000.0 epoch","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Primary direction: Vernal equinox at J2000.0","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .j2000)","print(\"RA: \\(eq.rightAscension)h, Dec: \\(eq.declination)°\")"]},{"anchor":"Equatorial-of-Date-EQD","text":"Equatorial of Date (EQD)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Accounts for precession of Earth’s axis:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Same as EQJ but referenced to the current date","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["let eq = try CelestialBody.mars.equatorial(at: .now, equatorDate: .ofDate)"]},{"anchor":"Ecliptic-ECL","text":"Ecliptic (ECL)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Referenced to the plane of Earth’s orbit:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Fundamental plane: Ecliptic (Earth’s orbital plane)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Primary direction: Vernal equinox","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["let lon = try CelestialBody.jupiter.eclipticLongitude(at: .now)","print(\"Ecliptic longitude: \\(lon)°\")","","\/\/ Full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"λ: \\(sunPos.longitude)°, β: \\(sunPos.latitude)°\")"]},{"anchor":"Horizontal-HOR","text":"Horizontal (HOR)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Local sky coordinates for an observer:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Altitude: Height above the horizon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Azimuth: Compass direction from north","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["let observer = Observer(latitude: 40.0, longitude: -74.0)","let hor = try CelestialBody.venus.horizon(at: .now, from: observer)","print(\"Alt: \\(hor.altitude)°, Az: \\(hor.azimuth)°\")"]},{"anchor":"Galactic-GAL","text":"Galactic (GAL)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Referenced to the Milky Way:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Fundamental plane: Galactic plane","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Primary direction: Galactic center","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Available via rotation matrices (see below)."}],"type":"paragraph"},{"anchor":"Rotation-Matrices","text":"Rotation Matrices","type":"heading","level":2},{"anchor":"Creating-Rotation-Matrices","text":"Creating Rotation Matrices","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["\/\/ Equatorial J2000 to Ecliptic","let eqjToEcl = try RotationMatrix.equatorialJ2000ToEcliptic()","","\/\/ Ecliptic to Equatorial J2000","let eclToEqj = try RotationMatrix.eclipticToEquatorialJ2000()","","\/\/ Equatorial J2000 to Galactic","let eqjToGal = try RotationMatrix.equatorialJ2000ToGalactic()"]},{"anchor":"Time-Dependent-Rotations","text":"Time-Dependent Rotations","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Some transformations require a time for precession\/nutation:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Equatorial J2000 to Equatorial of Date","let time = AstroTime.now","let eqjToEqd = try RotationMatrix.equatorialJ2000ToEquatorialOfDate(at: time)","","\/\/ Equatorial to Horizontal (requires time and observer)","let observer = Observer.greenwich","let eqjToHor = try RotationMatrix.equatorialJ2000ToHorizon(at: time, from: observer)"]},{"anchor":"Applying-Rotations","text":"Applying Rotations","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Transform a vector using a rotation matrix:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let position = try CelestialBody.mars.geocentricPosition(at: .now)","let rotation = try RotationMatrix.equatorialJ2000ToEcliptic()","let eclipticPosition = position.rotated(by: rotation)"]},{"anchor":"Matrix-Operations","text":"Matrix Operations","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["\/\/ Identity (no rotation)","let identity = RotationMatrix.identity","","\/\/ Inverse (reverse rotation)","let forward = try RotationMatrix.equatorialJ2000ToEcliptic()","let reverse = forward.inverse","","\/\/ Combine rotations","let combined = try forward.combined(with: anotherRotation)","","\/\/ Pivot around an axis","let rotated = try RotationMatrix.pivot(axis: 2, angle: 45.0)  \/\/ 45° around Z"]},{"anchor":"Vector-Types","text":"Vector Types","type":"heading","level":2},{"anchor":"Vector3D","text":"Vector3D","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"A 3D Cartesian position vector:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let pos = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"X: \\(pos.x) AU\")","print(\"Y: \\(pos.y) AU\")","print(\"Z: \\(pos.z) AU\")","print(\"Magnitude: \\(pos.magnitude) AU\")","","\/\/ Normalize to unit vector","let direction = pos.normalized"]},{"anchor":"StateVector","text":"StateVector","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Position and velocity together:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let state = try observer.state(at: .now)","print(\"Position: \\(state.position)\")","print(\"Velocity: \\(state.velocity)\")  \/\/ AU\/day"]},{"anchor":"Spherical-Coordinates","text":"Spherical Coordinates","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"code":"Spherical","type":"codeVoice"},{"type":"text","text":" type (latitude, longitude, distance) is produced by converting"},{"type":"text","text":" "},{"type":"text","text":"a position vector:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let vector = try CelestialBody.mars.geocentricPosition(at: .now)","let spherical = vector.toSpherical()","print(\"Longitude: \\(spherical.longitude)°\")","print(\"Latitude: \\(spherical.latitude)°\")","print(\"Distance: \\(spherical.distance) AU\")"]},{"anchor":"Atmospheric-Effects","text":"Atmospheric Effects","type":"heading","level":2},{"anchor":"Refraction","text":"Refraction","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Atmospheric refraction bends light, affecting apparent altitude:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Normal refraction correction (default)","let apparent = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction (geometric position)","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons refraction model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"]},{"anchor":"Computing-Refraction-Directly","text":"Computing Refraction Directly","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Calculate refraction angles independently of a coordinate conversion:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ How much does refraction raise an object at 5° geometric altitude?","let offset = Refraction.normal.refractionAngle(at: 5.0)","print(\"Refraction at 5°: +\\(offset)°\")","","\/\/ Given an apparent altitude of 5°, what was the geometric altitude?","let inverse = Refraction.normal.inverseRefractionAngle(at: 5.0)","let geometric = 5.0 - inverse"]},{"anchor":"Aberration","text":"Aberration","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Light-time and stellar aberration affect apparent positions:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ With aberration correction (default) - what you actually see","let apparent = try body.geocentricPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geocentricPosition(at: .now, aberration: .none)"]},{"anchor":"Available-Rotations","text":"Available Rotations","type":"heading","level":2},{"header":"row","rows":[[[{"inlineContent":[{"text":"From","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"To","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Method","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ECL","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"equatorialJ2000ToEcliptic()"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"ECL","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"EQJ","type":"text"}],"type":"paragraph