{"metadata":{"roleHeading":"Article","title":"Seasons and Events","role":"article","modules":[{"name":"AstronomyKit"}]},"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Calculate equinoxes, solstices, planetary apsides, elongations, and transits."}],"seeAlsoSections":[{"anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse"],"generated":true,"title":"Events"}],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit provides calculations for seasonal events (equinoxes and solstices), planetary orbital events (apsides), elongation and visibility, and rare transits of Mercury and Venus.","type":"text"}]},{"anchor":"Equinoxes-and-Solstices","type":"heading","text":"Equinoxes and Solstices","level":2},{"anchor":"Get-All-Seasons-for-a-Year","type":"heading","text":"Get All Seasons for a Year","level":3},{"code":["let seasons = try Seasons.forYear(2025)","","print(\"🌸 Spring: \\(seasons.marchEquinox)\")","print(\"☀️ Summer: \\(seasons.juneSolstice)\")","print(\"🍂 Autumn: \\(seasons.septemberEquinox)\")","print(\"❄️ Winter: \\(seasons.decemberSolstice)\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Iterate-Over-Events","type":"heading","text":"Iterate Over Events","level":3},{"code":["let seasons = try Seasons.forYear(2025)","","for (name, time) in seasons.allEvents {","    print(\"\\(name): \\(time)\")","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Planetary-Apsides","type":"heading","text":"Planetary Apsides","level":2},{"type":"paragraph","inlineContent":[{"text":"Apsides are the closest (perihelion) and farthest (aphelion) points in a planet’s orbit around the Sun.","type":"text"}]},{"anchor":"Find-Next-Planetary-Apsis","type":"heading","text":"Find Next Planetary Apsis","level":3},{"code":["let apsis = try CelestialBody.mars.searchApsis(after: .now)","print(\"\\(apsis.kind.solarName) at \\(apsis.time)\")","print(\"Distance: \\(apsis.distanceAU) AU\")"],"syntax":"swift","type":"codeListing"},{"anchor":"All-Apsides-in-a-Range","type":"heading","text":"All Apsides in a Range","level":3},{"code":["let apsides = try CelestialBody.earth.apsides(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2030, month: 1, day: 1)",")","","for apsis in apsides {","    print(\"\\(apsis.kind.solarName): \\(apsis.time)\")","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Elongation-and-Visibility","type":"heading","text":"Elongation and Visibility","level":2},{"type":"paragraph","inlineContent":[{"text":"Elongation is the angular separation between a planet and the Sun. This determines when planets are best visible.","type":"text"}]},{"anchor":"Current-Elongation","type":"heading","text":"Current Elongation","level":3},{"code":["let elong = try CelestialBody.venus.elongation(at: .now)","print(\"Venus is \\(elong.angle)° from the Sun\")","print(\"Visibility: \\(elong.visibility.name) star\")","","if elong.visibility == .evening {","    print(\"Look for Venus after sunset\")","} else {","    print(\"Look for Venus before sunrise\")","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Maximum-Elongation","type":"heading","text":"Maximum Elongation","level":3},{"type":"paragraph","inlineContent":[{"text":"Find when a planet reaches greatest separation from the Sun:","type":"text"}]},{"code":["let maxElong = try CelestialBody.mercury.searchMaxElongation(after: .now)","print(\"Mercury max elongation: \\(maxElong.angle)°\")","print(\"Date: \\(maxElong.time)\")","print(\"\\(maxElong.visibility.name) star\")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is especially useful for Mercury and Venus, which are never far from the Sun."}]},{"anchor":"Illumination-and-Magnitude","type":"heading","text":"Illumination and Magnitude","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate the visual brightness and illumination of planets."}]},{"anchor":"Current-Illumination","type":"heading","text":"Current Illumination","level":3},{"code":["let illum = try CelestialBody.venus.illumination(at: .now)","print(\"Magnitude: \\(illum.magnitude)\")","print(\"Phase: \\(Int(illum.phaseFraction * 100))% illuminated\")","print(\"Distance from Sun: \\(illum.helioDistance) AU\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Saturns-Rings","type":"heading","text":"Saturn’s Rings","level":3},{"type":"paragraph","inlineContent":[{"text":"For Saturn, illumination includes ring tilt:","type":"text"}]},{"code":["let saturn = try CelestialBody.saturn.illumination(at: .now)","print(\"Ring tilt: \\(saturn.ringTilt)°\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Peak-Magnitude","type":"heading","text":"Peak Magnitude","level":3},{"type":"paragraph","inlineContent":[{"text":"Find when a planet reaches maximum brightness:","type":"text"}]},{"code":["let peak = try CelestialBody.venus.searchPeakMagnitude(after: .now)","print(\"Venus brightest at \\(peak.time)\")","print(\"Magnitude: \\(peak.magnitude)\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Planetary-Transits","type":"heading","text":"Planetary Transits","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transits occur when Mercury or Venus passes between Earth and the Sun."}]},{"content":[{"inlineContent":[{"type":"text","text":"Transits are rare events. Mercury transits occur about 13 times per century, while Venus transits occur in pairs separated by over a century."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"anchor":"Find-Next-Transit","type":"heading","text":"Find Next Transit","level":3},{"code":["let transit = try Transit.search(body: .mercury, after: .now)","print(\"Transit date: \\(transit.peak)\")","print(\"Duration: \\(transit.duration \/ 60) minutes\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Transit-Timing","type":"heading","text":"Transit Timing","level":3},{"code":["print(\"Start (first contact): \\(transit.start)\")","print(\"Peak (mid-transit): \\(transit.peak)\")","print(\"End (last contact): \\(transit.finish)\")","print(\"Minimum separation: \\(transit.separation) arcmin\")"],"syntax":"swift","type":"codeListing"},{"anchor":"All-Transits-in-a-Range","type":"heading","text":"All Transits in a Range","level":3},{"code":["\/\/ Find all Mercury transits in the next 50 years","let transits = try Transit.transits(","    body: .mercury,","    from: .now,","    to: .now.addingDays(365 * 50)",")","","for transit in transits {","    print(\"\\(transit.body.name) transit: \\(transit.peak)\")","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Angular-Separation","type":"heading","text":"Angular Separation","level":2},{"type":"paragraph","inlineContent":[{"text":"Calculate the angle between a body and the Sun:","type":"text"}]},{"syntax":"swift","code":["let angle = try CelestialBody.jupiter.angleFromSun(at: .now)","print(\"Jupiter is \\(angle)° from the Sun\")","","\/\/ Opposition occurs when angle ≈ 180°","if angle > 170 {","    print(\"Jupiter is near opposition!\")","}"],"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/astronomykit\/seasonsandevents"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"https://github.com/cosinekitty/astronomy":{"title":"Astronomy Engine","url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}]},"doc://AstronomyKit/documentation/AstronomyKit/RiseSetTimes":{"type":"topic","abstract":[{"text":"Calculate when celestial bodies rise, set, and reach their highest point.","type":"text"}],"kind":"article","role":"article","title":"Rise and Set Times","url":"\/documentation\/astronomykit\/risesettimes","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes"},"doc://AstronomyKit/documentation/AstronomyKit/Eclipses":{"role":"article","title":"Eclipses","abstract":[{"type":"text","text":"Predict lunar and solar eclipses with detailed timing information."}],"kind":"article","type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","url":"\/documentation\/astronomykit\/eclipses"},"doc://AstronomyKit/documentation/AstronomyKit":{"role":"collection","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"text":" library.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol","type":"topic","title":"AstronomyKit"},"doc://AstronomyKit/documentation/AstronomyKit/GlobalSolarEclipse":{"abstract":[{"text":"Information about a solar eclipse as seen globally.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GlobalSolarEclipse"}],"navigatorTitle":[{"kind":"identifier","text":"GlobalSolarEclipse"}],"url":"\/documentation\/astronomykit\/globalsolareclipse","type":"topic","kind":"symbol","title":"GlobalSolarEclipse","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse"},"doc://AstronomyKit/documentation/AstronomyKit/Seasons":{"type":"topic","abstract":[{"text":"The four seasonal events (equinoxes and solstices) for a calendar year.","type":"text"}],"title":"Seasons","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Seasons","kind":"identifier"}],"url":"\/documentation\/astronomykit\/seasons","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","kind":"symbol","navigatorTitle":[{"text":"Seasons","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit/LocalSolarEclipse":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LocalSolarEclipse"}],"abstract":[{"text":"Information about a solar eclipse as seen from a specific location.","type":"text"}],"type":"topic","url":"\/documentation\/astronomykit\/localsolareclipse","title":"LocalSolarEclipse","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LocalSolarEclipse"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/LunarEclipse":{"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LunarEclipse","kind":"identifier"}],"abstract":[{"text":"Information about a lunar eclipse.","type":"text"}],"type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","title":"LunarEclipse","url":"\/documentation\/astronomykit\/lunareclipse","navigatorTitle":[{"text":"LunarEclipse","kind":"identifier"}]}}}