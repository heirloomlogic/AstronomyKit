{"sections":[],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"AstronomyKit provides calculations for seasonal events (equinoxes and solstices), planetary orbital events (apsides), elongation and visibility, and rare transits of Mercury and Venus."}],"type":"paragraph"},{"level":2,"anchor":"Equinoxes-and-Solstices","text":"Equinoxes and Solstices","type":"heading"},{"level":3,"anchor":"Get-All-Seasons-for-a-Year","text":"Get All Seasons for a Year","type":"heading"},{"code":["let seasons = try Seasons.forYear(2025)","","print(\"🌸 Spring: \\(seasons.marchEquinox)\")","print(\"☀️ Summer: \\(seasons.juneSolstice)\")","print(\"🍂 Autumn: \\(seasons.septemberEquinox)\")","print(\"❄️ Winter: \\(seasons.decemberSolstice)\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Iterate-Over-Events","text":"Iterate Over Events","type":"heading"},{"code":["let seasons = try Seasons.forYear(2025)","","for (name, time) in seasons.allEvents {","    print(\"\\(name): \\(time)\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Planetary-Apsides","text":"Planetary Apsides","type":"heading"},{"inlineContent":[{"text":"Apsides are the closest (perihelion) and farthest (aphelion) points in a planet’s orbit around the Sun.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Find-Next-Planetary-Apsis","text":"Find Next Planetary Apsis","type":"heading"},{"code":["let apsis = try CelestialBody.mars.searchApsis(after: .now)","print(\"\\(apsis.kind.solarName) at \\(apsis.time)\")","print(\"Distance: \\(apsis.distanceAU) AU\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"All-Apsides-in-a-Range","text":"All Apsides in a Range","type":"heading"},{"code":["let apsides = try CelestialBody.earth.apsides(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2030, month: 1, day: 1)",")","","for apsis in apsides {","    print(\"\\(apsis.kind.solarName): \\(apsis.time)\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Elongation-and-Visibility","text":"Elongation and Visibility","type":"heading"},{"inlineContent":[{"type":"text","text":"Elongation is the angular separation between a planet and the Sun. This determines when planets are best visible."}],"type":"paragraph"},{"level":3,"anchor":"Current-Elongation","text":"Current Elongation","type":"heading"},{"code":["let elong = try CelestialBody.venus.elongation(at: .now)","print(\"Venus is \\(elong.angle)° from the Sun\")","print(\"Visibility: \\(elong.visibility.name) star\")","","if elong.visibility == .evening {","    print(\"Look for Venus after sunset\")","} else {","    print(\"Look for Venus before sunrise\")","}"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Maximum-Elongation","text":"Maximum Elongation","type":"heading"},{"inlineContent":[{"type":"text","text":"Find when a planet reaches greatest separation from the Sun:"}],"type":"paragraph"},{"code":["let maxElong = try CelestialBody.mercury.searchMaxElongation(after: .now)","print(\"Mercury max elongation: \\(maxElong.angle)°\")","print(\"Date: \\(maxElong.time)\")","print(\"\\(maxElong.visibility.name) star\")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This is especially useful for Mercury and Venus, which are never far from the Sun.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Illumination-and-Magnitude","text":"Illumination and Magnitude","type":"heading"},{"inlineContent":[{"type":"text","text":"Calculate the visual brightness and illumination of planets."}],"type":"paragraph"},{"level":3,"anchor":"Current-Illumination","text":"Current Illumination","type":"heading"},{"code":["let illum = try CelestialBody.venus.illumination(at: .now)","print(\"Magnitude: \\(illum.magnitude)\")","print(\"Phase: \\(Int(illum.phaseFraction * 100))% illuminated\")","print(\"Distance from Sun: \\(illum.helioDistance) AU\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Saturns-Rings","text":"Saturn’s Rings","type":"heading"},{"inlineContent":[{"text":"For Saturn, illumination includes ring tilt:","type":"text"}],"type":"paragraph"},{"code":["let saturn = try CelestialBody.saturn.illumination(at: .now)","print(\"Ring tilt: \\(saturn.ringTilt)°\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Peak-Magnitude","text":"Peak Magnitude","type":"heading"},{"inlineContent":[{"type":"text","text":"Find when a planet reaches maximum brightness:"}],"type":"paragraph"},{"code":["let peak = try CelestialBody.venus.searchPeakMagnitude(after: .now)","print(\"Venus brightest at \\(peak.time)\")","print(\"Magnitude: \\(peak.magnitude)\")"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Planetary-Transits","text":"Planetary Transits","type":"heading"},{"inlineContent":[{"text":"Transits occur when Mercury or Venus passes between Earth and the Sun.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Transits are rare events. Mercury transits occur about 13 times per century, while Venus transits occur in pairs separated by over a century."}]}],"style":"note","name":"Note","type":"aside"},{"level":3,"anchor":"Find-Next-Transit","text":"Find Next Transit","type":"heading"},{"code":["let transit = try Transit.search(body: .mercury, after: .now)","print(\"Transit date: \\(transit.peak)\")","print(\"Duration: \\(transit.duration \/ 60) minutes\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Transit-Timing","text":"Transit Timing","type":"heading"},{"code":["print(\"Start (first contact): \\(transit.start)\")","print(\"Peak (mid-transit): \\(transit.peak)\")","print(\"End (last contact): \\(transit.finish)\")","print(\"Minimum separation: \\(transit.separation) arcmin\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"All-Transits-in-a-Range","text":"All Transits in a Range","type":"heading"},{"code":["\/\/ Find all Mercury transits in the next 50 years","let transits = try Transit.transits(","    body: .mercury,","    from: .now,","    to: .now.addingDays(365 * 50)",")","","for transit in transits {","    print(\"\\(transit.body.name) transit: \\(transit.peak)\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Angular-Separation","text":"Angular Separation","type":"heading"},{"inlineContent":[{"type":"text","text":"Calculate the angle between a body and the Sun:"}],"type":"paragraph"},{"code":["let angle = try CelestialBody.jupiter.angleFromSun(at: .now)","print(\"Jupiter is \\(angle)° from the Sun\")","","\/\/ Opposition occurs when angle ≈ 180°","if angle > 170 {","    print(\"Jupiter is near opposition!\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Conjunctions-and-Oppositions","text":"Conjunctions and Oppositions","type":"heading"},{"inlineContent":[{"text":"Search for when a planet reaches a specific angular relationship with the Sun:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Find the next Mars opposition (closest to Earth)","let opposition = try CelestialBody.mars.searchOpposition(after: .now)","print(\"Mars opposition: \\(opposition.date)\")","","\/\/ Find the next Jupiter superior conjunction (behind the Sun)","let conjunction = try CelestialBody.jupiter.searchSuperiorConjunction(after: .now)","print(\"Jupiter conjunction: \\(conjunction.date)\")","","\/\/ Measure the relative ecliptic longitude between two bodies","let angle = try CelestialBody.venus.pairLongitude(with: .mars, at: .now)","print(\"Venus-Mars separation: \\(angle)°\")","","\/\/ Search for an arbitrary relative longitude from the Sun","let result = try CelestialBody.saturn.searchRelativeLongitude(90, after: .now)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The relative longitude convention measures the heliocentric angle between the planet","type":"text"},{"text":" ","type":"text"},{"text":"and Earth. At 0° the planet and Earth are on the same side of the Sun (opposition for","type":"text"},{"text":" ","type":"text"},{"text":"outer planets). At 180° the planet is on the far side of the Sun (superior conjunction).","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/astronomykit\/seasonsandevents"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents"},"metadata":{"modules":[{"name":"AstronomyKit"}],"role":"article","roleHeading":"Article","title":"Seasons and Events"},"abstract":[{"type":"text","text":"Calculate equinoxes, solstices, planetary apsides, elongations, and transits."}],"seeAlsoSections":[{"generated":true,"anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroSearch","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Sun","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseEvent","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Apsis","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/ApsisKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Elongation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Visibility"],"title":"Events"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://AstronomyKit/documentation/Astron