AstronomyKit","kind":"symbol","abstract":[{"type":"text","text":"Swift bindings for Don Cross’ "},{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","type":"reference","isActive":true},{"type":"text","text":" library."}],"role":"collection"}}}