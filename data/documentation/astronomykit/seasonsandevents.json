{"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit provides calculations for seasonal events (equinoxes and solstices), planetary orbital events (apsides), elongation and visibility, and rare transits of Mercury and Venus.","type":"text"}]},{"anchor":"Equinoxes-and-Solstices","level":2,"type":"heading","text":"Equinoxes and Solstices"},{"anchor":"Get-All-Seasons-for-a-Year","level":3,"type":"heading","text":"Get All Seasons for a Year"},{"code":["let seasons = try Seasons.forYear(2025)","","print(\"🌸 Spring: \\(seasons.marchEquinox)\")","print(\"☀️ Summer: \\(seasons.juneSolstice)\")","print(\"🍂 Autumn: \\(seasons.septemberEquinox)\")","print(\"❄️ Winter: \\(seasons.decemberSolstice)\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Iterate-Over-Events","level":3,"type":"heading","text":"Iterate Over Events"},{"code":["let seasons = try Seasons.forYear(2025)","","for (name, time) in seasons.allEvents {","    print(\"\\(name): \\(time)\")","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Planetary-Apsides","level":2,"type":"heading","text":"Planetary Apsides"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apsides are the closest (perihelion) and farthest (aphelion) points in a planet’s orbit around the Sun."}]},{"anchor":"Find-Next-Planetary-Apsis","level":3,"type":"heading","text":"Find Next Planetary Apsis"},{"code":["let apsis = try CelestialBody.mars.searchApsis(after: .now)","print(\"\\(apsis.kind.solarName) at \\(apsis.time)\")","print(\"Distance: \\(apsis.distanceAU) AU\")"],"syntax":"swift","type":"codeListing"},{"text":"All Apsides in a Range","type":"heading","anchor":"All-Apsides-in-a-Range","level":3},{"syntax":"swift","type":"codeListing","code":["let apsides = try CelestialBody.earth.apsides(","    from: AstroTime(year: 2025, month: 1, day: 1),","    to: AstroTime(year: 2030, month: 1, day: 1)",")","","for apsis in apsides {","    print(\"\\(apsis.kind.solarName): \\(apsis.time)\")","}"]},{"text":"Elongation and Visibility","type":"heading","anchor":"Elongation-and-Visibility","level":2},{"type":"paragraph","inlineContent":[{"text":"Elongation is the angular separation between a planet and the Sun. This determines when planets are best visible.","type":"text"}]},{"text":"Current Elongation","type":"heading","anchor":"Current-Elongation","level":3},{"syntax":"swift","type":"codeListing","code":["let elong = try CelestialBody.venus.elongation(at: .now)","print(\"Venus is \\(elong.angle)° from the Sun\")","print(\"Visibility: \\(elong.visibility.name) star\")","","if elong.visibility == .evening {","    print(\"Look for Venus after sunset\")","} else {","    print(\"Look for Venus before sunrise\")","}"]},{"text":"Maximum Elongation","type":"heading","anchor":"Maximum-Elongation","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find when a planet reaches greatest separation from the Sun:"}]},{"syntax":"swift","type":"codeListing","code":["let maxElong = try CelestialBody.mercury.searchMaxElongation(after: .now)","print(\"Mercury max elongation: \\(maxElong.angle)°\")","print(\"Date: \\(maxElong.time)\")","print(\"\\(maxElong.visibility.name) star\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is especially useful for Mercury and Venus, which are never far from the Sun."}]},{"text":"Illumination and Magnitude","type":"heading","anchor":"Illumination-and-Magnitude","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate the visual brightness and illumination of planets."}]},{"text":"Current Illumination","type":"heading","anchor":"Current-Illumination","level":3},{"syntax":"swift","type":"codeListing","code":["let illum = try CelestialBody.venus.illumination(at: .now)","print(\"Magnitude: \\(illum.magnitude)\")","print(\"Phase: \\(Int(illum.phaseFraction * 100))% illuminated\")","print(\"Distance from Sun: \\(illum.helioDistance) AU\")"]},{"text":"Saturn’s Rings","type":"heading","anchor":"Saturns-Rings","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Saturn, illumination includes ring tilt:"}]},{"syntax":"swift","type":"codeListing","code":["let saturn = try CelestialBody.saturn.illumination(at: .now)","print(\"Ring tilt: \\(saturn.ringTilt)°\")"]},{"text":"Peak Magnitude","type":"heading","anchor":"Peak-Magnitude","level":3},{"type":"paragraph","inlineContent":[{"text":"Find when a planet reaches maximum brightness:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let peak = try CelestialBody.venus.searchPeakMagnitude(after: .now)","print(\"Venus brightest at \\(peak.time)\")","print(\"Magnitude: \\(peak.magnitude)\")"]},{"text":"Planetary Transits","type":"heading","anchor":"Planetary-Transits","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transits occur when Mercury or Venus passes between Earth and the Sun."}]},{"content":[{"inlineContent":[{"type":"text","text":"Transits are rare events. Mercury transits occur about 13 times per century, while Venus transits occur in pairs separated by over a century."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"text":"Find Next Transit","type":"heading","anchor":"Find-Next-Transit","level":3},{"syntax":"swift","type":"codeListing","code":["let transit = try Transit.search(body: .mercury, after: .now)","print(\"Transit date: \\(transit.peak)\")","print(\"Duration: \\(transit.duration \/ 60) minutes\")"]},{"text":"Transit Timing","type":"heading","anchor":"Transit-Timing","level":3},{"syntax":"swift","type":"codeListing","code":["print(\"Start (first contact): \\(transit.start)\")","print(\"Peak (mid-transit): \\(transit.peak)\")","print(\"End (last contact): \\(transit.finish)\")","print(\"Minimum separation: \\(transit.separation) arcmin\")"]},{"text":"All Transits in a Range","type":"heading","anchor":"All-Transits-in-a-Range","level":3},{"syntax":"swift","type":"codeListing","code":["\/\/ Find all Mercury transits in the next 50 years","let transits = try Transit.transits(","    body: .mercury,","    from: .now,","    to: .now.addingDays(365 * 50)",")","","for transit in transits {","    print(\"\\(transit.body.name) transit: \\(transit.peak)\")","}"]},{"text":"Angular Separation","type":"heading","anchor":"Angular-Separation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculate the angle between a body and the Sun:"}]},{"syntax":"swift","type":"codeListing","code":["let angle = try CelestialBody.jupiter.angleFromSun(at: .now)","print(\"Jupiter is \\(angle)° from the Sun\")","","\/\/ Opposition occurs when angle ≈ 180°","if angle > 170 {","    print(\"Jupiter is near opposition!\")","}"]}],"kind":"content"}],"seeAlsoSections":[{"generated":true,"title":"Events","anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/seasonsandevents"]}],"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"text":"Calculate equinoxes, solstices, planetary apsides, elongations, and transits.","type":"text"}],"metadata":{"roleHeading":"Article","role":"article","title":"Seasons and Events","modules":[{"name":"AstronomyKit"}]},"sections":[],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","interfaceLanguage":"swift"},"references":{"doc://AstronomyKit/documentation/AstronomyKit/LocalSolarEclipse":{"url":"\/documentation\/astronomykit\/localsolareclipse","role":"symbol","abstract":[{"text":"Information about a solar eclipse as seen from a specific location.","type":"text"}],"navigatorTitle":[{"text":"LocalSolarEclipse","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LocalSolarEclipse","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","kind":"symbol","title":"LocalSolarEclipse"},"doc://AstronomyKit/documentation/AstronomyKit/Seasons":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Seasons"}],"role":"symbol","title":"Seasons","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","abstract":[{"text":"The four seasonal events (equinoxes and solstices) for a calendar year.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Seasons"}],"url":"\/documentation\/astronomykit\/seasons"},"doc://AstronomyKit/documentation/AstronomyKit/RiseSetTimes":{"kind":"article","url":"\/documentation\/astronomykit\/risesettimes","role":"article","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","title":"Rise and Set Times","abstract":[{"type":"text","text":"Calculate when celestial bodies rise, set, and reach their highest point."}],"type":"topic"},"doc://AstronomyKit/documentation/AstronomyKit/GlobalSolarEclipse":{"kind":"symbol","title":"GlobalSolarEclipse","type":"topic","url":"\/documentation\/astronomykit\/globalsolareclipse","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GlobalSolarEclipse","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","navigatorTitle":[{"text":"GlobalSolarEclipse","kind":"identifier"}],"abstract":[{"type":"text","text":"Information about a solar eclipse as seen globally."}]},"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"title":"Astronomy Engine","url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link"},"doc://AstronomyKit/documentation/AstronomyKit/LunarEclipse":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LunarEclipse","kind":"identifier"}],"abstract":[{"text":"Information about a lunar eclipse.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","title":"LunarEclipse","url":"\/documentation\/astronomykit\/lunareclipse","navigatorTitle":[{"text":"LunarEclipse","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit":{"type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol","role":"collection","title":"AstronomyKit","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","type":"reference","isActive":true},{"text":" library.","type":"text"}]},"doc://AstronomyKit/documentation/AstronomyKit/Eclipses":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","kind":"article","role":"article","title":"Eclipses","abstract":[{"type":"text","text":"Predict lunar and solar eclipses with detailed timing information."}],"url":"\/documentation\/astronomykit\/eclipses","type":"topic"}}}