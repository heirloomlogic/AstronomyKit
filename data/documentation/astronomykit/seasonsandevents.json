ype of eclipse.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseKind","kind":"symbol","title":"EclipseKind","navigatorTitle":[{"text":"EclipseKind","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit/RiseSetTimes":{"url":"\/documentation\/astronomykit\/risesettimes","role":"article","kind":"article","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","abstract":[{"type":"text","text":"Calculate when celestial bodies rise, set, and reach their highest point."}],"title":"Rise and Set Times","type":"topic"},"doc://AstronomyKit/documentation/AstronomyKit/LocalSolarEclipse":{"title":"LocalSolarEclipse","navigatorTitle":[{"text":"LocalSolarEclipse","kind":"identifier"}],"abstract":[{"text":"Information about a solar eclipse as seen from a specific location.","type":"text"}],"url":"\/documentation\/astronomykit\/localsolareclipse","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LocalSolarEclipse","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","type":"topic","role":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/Seasons":{"type":"topic","role":"symbol","url":"\/documentation\/astronomykit\/seasons","navigatorTitle":[{"text":"Seasons","kind":"identifier"}],"title":"Seasons","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","abstract":[{"type":"text","text":"The four seasonal events (equinoxes and solstices) for a calendar year."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Seasons","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit/EclipseEvent":{"kind":"symbol","type":"topic","url":"\/documentation\/astronomykit\/eclipseevent","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"EclipseEvent"}],"navigatorTitle":[{"kind":"id