 (which require orbital calculations), fixed stars"},{"type":"text","text":" "},{"type":"text","text":"are defined by their J2000 mean equator coordinates and distance. The library"},{"type":"text","text":" "},{"type":"text","text":"handles precession, nutation, and aberration automatically."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"code":["let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","let longitude = try algol.eclipticLongitude(at: .now)","print(\"Algol is at \\(longitude)°\")"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Coordinate Sources","anchor":"Coordinate-Sources"},{"inlineContent":[{"type":"text","text":"J2000 coordinates can be found from:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"https:\/\/simbad.cds.unistra.fr\/simbad\/","type":"reference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Hipparcos Catalog","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Yale Bright Star Catalog","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Concurrency","anchor":"Concurrency"},{"inlineContent":[{"type":"text","text":"The C library exposes eight user-defined star slots ("},{"type":"codeVoice","code":"BODY_STAR1"},{"type":"text","text":"…"},{"type":"codeVoice","code":"BODY_STAR8"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"each an independent record. Calculations map a star to a slot by a stable hash of"},{"type":"text","text":" "},{"type":"text","text":"its coordinates, so up to eight distinct stars can be computed fully in parallel."},{"type":"text","text":" "},{"type":"text","text":"A slot is only redefined when the star currently loaded in it differs, so repeated"},{"type":"text","text":" "},{"type":"text","text":"calls for the same star skip the redefinition entirely. Stars whose hashes collide"},{"type":"text","text":" "},{"type":"text","text":"on the same slot serialize on that slot’s mutex (correct, just slower)."}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/fixedstar"]}],"references":{"doc://AstronomyKit/SH":{"identifier":"doc:\/\/AstronomyKit\/SH","type":"unresolvable","title":"Swift.Hashable"},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar/equatorial(at:from:equatorDate:)":{"abstract":[{"type":"text","text":"Calculates the star’s equatorial coordinates at a given time."}],"title":"equatorial(at:from:equatorDate:)","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar\/equatorial(at:from:equatorDate:)","url":"\/documentation\/astronomykit\/fixedstar\/equatorial(at:from:equatordate:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"equatorial"},{"kind":"text","text":"("},{"kind":"externalParam","text":"at"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12AstronomyKit9AstroTimeV","text":"AstroTime"},{"kind":"text","text":", "},{"kind":"externalParam","text":"from"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12AstronomyKit8ObserverV","text":"Observer"},{"kind":"text","text":", "},{"kind":"externalParam","text":"equatorDate"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:12AstronomyKit11EquatorDateO","text":"EquatorDate"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12AstronomyKit