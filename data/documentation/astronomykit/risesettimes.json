{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit can find rise times, set times, culmination (transit), and times when bodies reach specific altitudes. These calculations account for atmospheric refraction."}]},{"text":"Basic Rise and Set","type":"heading","level":2,"anchor":"Basic-Rise-and-Set"},{"text":"Sunrise and Sunset","type":"heading","level":3,"anchor":"Sunrise-and-Sunset"},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer) {","    print(\"Sunrise: \\(sunrise.date)\")","}","","if let sunset = try CelestialBody.sun.setTime(after: .now, from: observer) {","    print(\"Sunset: \\(sunset.date)\")","}"],"syntax":"swift"},{"text":"Moonrise and Moonset","type":"heading","level":3,"anchor":"Moonrise-and-Moonset"},{"type":"codeListing","code":["if let moonrise = try CelestialBody.moon.riseTime(after: .now, from: observer) {","    print(\"Moonrise: \\(moonrise)\")","}","","if let moonset = try CelestialBody.moon.setTime(after: .now, from: observer) {","    print(\"Moonset: \\(moonset)\")","}"],"syntax":"swift"},{"text":"Planet Rise and Set","type":"heading","level":3,"anchor":"Planet-Rise-and-Set"},{"type":"codeListing","code":["if let marsRise = try CelestialBody.mars.riseTime(after: .now, from: observer) {","    print(\"Mars rises at \\(marsRise)\")","}"],"syntax":"swift"},{"text":"Culmination (Transit)","type":"heading","level":2,"anchor":"Culmination-Transit"},{"type":"paragraph","inlineContent":[{"text":"Culmination is when a body crosses the meridian and reaches its highest altitude:","type":"text"}]},{"type":"codeListing","code":["let transit = try CelestialBody.sun.culmination(after: .now, from: observer)","print(\"Solar noon: \\(transit.time)\")","print(\"Max altitude: \\(transit.horizon.altitude)°\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is useful for:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Finding solar noon"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Determining the best time to observe a planet"}]}]},{"content":[{"inlineContent":[{"text":"Calculating day length","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Custom Altitude Searches","type":"heading","level":2,"anchor":"Custom-Altitude-Searches"},{"type":"paragraph","inlineContent":[{"text":"Find when a body reaches a specific altitude:","type":"text"}]},{"type":"codeListing","code":["\/\/ Astronomical twilight begins when Sun is 18° below horizon","let twilight = try CelestialBody.sun.searchAltitude(","    -18.0,","    direction: .set,","    after: .now,","    from: observer",")","if let time = twilight {","    print(\"Astronomical twilight begins: \\(time)\")","}"],"syntax":"swift"},{"text":"Civil and Nautical Twilight","type":"heading","level":3,"anchor":"Civil-and-Nautical-Twilight"},{"type":"codeListing","code":["\/\/ Civil twilight: Sun at -6°","let civilTwilight = try CelestialBody.sun.searchAltitude(","    -6.0, direction: .set, after: .now, from: observer",")","","\/\/ Nautical twilight: Sun at -12°","let nauticalTwilight = try CelestialBody.sun.searchAltitude(","    -12.0, direction: .set, after: .now, from: observer",")"],"syntax":"swift"},{"text":"Minimum Observation Altitude","type":"heading","level":3,"anchor":"Minimum-Observation-Altitude"},{"type":"codeListing","code":["\/\/ Find when Mars rises above 20° (good for observation)","let observable = try CelestialBody.mars.searchAltitude(","    20.0,","    direction: .rise,","    after: .now,","    from: observer",")"],"syntax":"swift"},{"text":"Hour Angle Searches","type":"heading","level":2,"anchor":"Hour-Angle-Searches"},{"type":"paragraph","inlineContent":[{"text":"Search for a specific hour angle:","type":"text"}]},{"type":"codeListing","code":["\/\/ Hour angle 0 = culmination (upper transit)","let upperTransit = try CelestialBody.saturn.searchHourAngle(","    0,","    after: .now,","    from: observer",")","","\/\/ Hour angle 12 = lower culmination","let lowerTransit = try CelestialBody.saturn.searchHourAngle(","    12,","    after: .now,","    from: observer",")"],"syntax":"swift"},{"text":"Search Limits","type":"heading","level":2,"anchor":"Search-Limits"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All searches have a time limit (default: 366 days):"}]},{"type":"codeListing","code":["\/\/ Limit search to next 30 days","let sunrise = try CelestialBody.sun.riseTime(","    after: .now,","    from: observer,","    limitDays: 30",")"],"syntax":"swift"},{"text":"Handling “No Result”","type":"heading","level":2,"anchor":"Handling-No-Result"},{"type":"paragraph","inlineContent":[{"text":"Rise\/set searches return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if no event occurs in the search period:","type":"text"}]},{"type":"codeListing","code":["\/\/ In polar regions, the Sun may not rise\/set","let arcticObserver = Observer(latitude: 78.0, longitude: 15.0)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: arcticObserver) {","    print(\"Sunrise: \\(sunrise)\")","} else {","    print(\"Sun does not rise during this period (polar night\/day)\")","}"],"syntax":"swift"},{"text":"Daily Events","type":"heading","level":2,"anchor":"Daily-Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get all events for a single day:"}]},{"type":"codeListing","code":["let events = try CelestialBody.sun.dailyEvents(","    on: .now,","    from: observer",")","","if let rise = events.rise {","    print(\"Rise: \\(rise)\")","}","if let transit = events.culmination {","    print(\"Transit: \\(transit.time) at \\(transit.horizon.altitude)°\")","}","if let set = events.set {","    print(\"Set: \\(set)\")","}","","if events.isVisible {","    print(\"Sun is visible at some point today\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is convenient for building daily almanac displays."}]},{"text":"Time Zones","type":"heading","level":2,"anchor":"Time-Zones"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All returned times are in UTC. Convert for display:"}]},{"type":"codeListing","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise: \\(formatter.string(from: sunrise.date))\")"],"syntax":"swift"}]}],"abstract":[{"type":"text","text":"Calculate when celestial bodies rise, set, and reach their highest point."}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"metadata":{"roleHeading":"Article","modules":[{"name":"AstronomyKit"}],"title":"Rise and Set Times","role":"article"},"sections":[],"seeAlsoSections":[{"anchor":"Events","title":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse"],"generated":true}],"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/RiseSetTimes","interfaceLanguage":"swift"},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/risesettimes"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://AstronomyKit/documentation/AstronomyKit/LocalSolarEclipse":{"kind":"symbol","abstract":[{"text":"Information about a solar eclip