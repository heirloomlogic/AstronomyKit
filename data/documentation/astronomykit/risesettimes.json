{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Rise and Set Times","modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"type":"text","text":"Calculate when celestial bodies rise, set, and reach their highest point."}],"seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroSearch","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Sun","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseEvent","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Apsis","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/ApsisKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Elongation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Visibility"],"anchor":"Events","title":"Events","generated":true}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit can find rise times, set times, culmination (transit), and times when bodies reach specific altitudes. These calculations account for atmospheric refraction.","type":"text"}]},{"text":"Basic Rise and Set","type":"heading","level":2,"anchor":"Basic-Rise-and-Set"},{"text":"Sunrise and Sunset","type":"heading","level":3,"anchor":"Sunrise-and-Sunset"},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer) {","    print(\"Sunrise: \\(sunrise.date)\")","}","","if let sunset = try CelestialBody.sun.setTime(after: .now, from: observer) {","    print(\"Sunset: \\(sunset.date)\")","}"],"syntax":"swift"},{"text":"Moonrise and Moonset","type":"heading","level":3,"anchor":"Moonrise-and-Moonset"},{"type":"codeListing","code":["if let moonrise = try CelestialBody.moon.riseTime(after: .now, from: observer) {","    print(\"Moonrise: \\(moonrise)\")","}","","if let moonset = try CelestialBody.moon.setTime(after: .now, from: observer) {","    print(\"Moonset: \\(moonset)\")","}"],"syntax":"swift"},{"text":"Planet Rise and Set","type":"heading","level":3,"anchor":"Planet-Rise-and-Set"},{"type":"codeListing","code":["if let marsRise = try CelestialBody.mars.riseTime(after: .now, from: observer) {","    print(\"Mars rises at \\(marsRise)\")","}"],"syntax":"swift"},{"text":"Culmination (Transit)","type":"heading","level":2,"anchor":"Culmination-Transit"},{"type":"paragraph","inlineContent":[{"text":"Culmination is when a body crosses the meridian and reaches its highest altitude:","type":"text"}]},{"type":"codeListing","code":["let transit = try CelestialBody.sun.culmination(after: .now, from: observer)","print(\"Solar noon: \\(transit.time)\")","print(\"Max altitude: \\(transit.horizon.altitude)°\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Finding solar noon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Determining the best time to observe a planet"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Calculating day length"}],"type":"paragraph"}]}]},{"text":"Custom Altitude Searches","type":"heading","level":2,"anchor":"Custom-Altitude-Searches"},{"type":"paragraph","inlineContent":[{"text":"Find when a body reaches a specific altitude:","type":"text"}]},{"syntax":"swift","code":["\/\/ Astronomical twilight begins when Sun is 18° below horizon","let twilight = try CelestialBody.sun.searchAltitude(","    -18.0,","    direction: .set,","    after: .now,","    from: observer",")","if let time = twilight {","    print(\"Astronomical twilight begins: \\(time)\")","}"],"type":"codeListing"},{"level":3,"anchor":"Civil-and-Nautical-Twilight","text":"Civil and Nautical Twilight","type":"heading"},{"syntax":"swift","code":["\/\/ Civil twilight: Sun at -6°","let civilTwilight = try CelestialBody.sun.searchAltitude(","    -6.0, direction: .set, after: .now, from: observer",")","","\/\/ Nautical twilight: Sun at -12°","let nauticalTwilight = try CelestialBody.sun.searchAltitude(","    -12.0, direction: .set, after: .now, from: observer",")"],"type":"codeListing"},{"level":3,"anchor":"Minimum-Observation-Altitude","text":"Minimum Observation Altitude","type":"heading"},{"syntax":"swift","code":["\/\/ Find when Mars rises above 20° (good for observation)","let observable = try CelestialBody.mars.searchAltitude(","    20.0,","    direction: .rise,","    after: .now,","    from: observer",")"],"type":"codeListing"},{"level":2,"anchor":"Hour-Angle-Searches","text":"Hour Angle Searches","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Search for a specific hour angle:","type":"text"}]},{"type":"codeListing","code":["\/\/ Hour angle 0 = culmination (upper transit)","let upperTransit = try CelestialBody.saturn.searchHourAngle(","    0,","    after: .now,","    from: observer",")","","\/\/ Hour angle 12 = lower culmination","let lowerTransit = try CelestialBody.saturn.searchHourAngle(","    12,","    after: .now,","    from: observer",")"],"syntax":"swift"},{"text":"Search Limits","type":"heading","level":2,"anchor":"Search-Limits"},{"inlineContent":[{"text":"All searches have a time limit (default: 366 days):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Limit search to next 30 days","let sunrise = try CelestialBody.sun.riseTime(","    after: .now,","    from: observer,","    limitDays: 30",")"],"type":"codeListing"},{"level":2,"anchor":"Handling-No-Result","text":"Handling “No Result”","type":"heading"},{"inlineContent":[{"type":"text","text":"Rise\/set searches return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if no event occurs in the search period:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ In polar regions, the Sun may not rise\/set","let arcticObserver = Observer(latitude: 78.0, longitude: 15.0)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: arcticObserver) {","    print(\"Sunrise: \\(sunrise)\")","} else {","    print(\"Sun does not rise during this period (polar night\/day)\")","}"],"type":"codeListing"},{"level":2,"anchor":"Daily-Events","text":"Daily Events","type":"heading"},{"inlineContent":[{"type":"text","text":"Get all events for a single day:"}],"type":"paragraph"},{"syntax":"swift","code":["let events = try DailyEvents(","    body: .sun,","    date: .now,","    from: observer",")","","if let rise = events.rise {","    print(\"Rise: \\(rise)\")","}","if let transit = events.culmination {","    print(\"Transit: \\(transit.time) at \\(transit.horizon.altitude)°\")","}","if let set = events.set {","    print(\"Set: \\(set)\")","}","","if events.isVisible {","    print(\"Sun is visible at some point today\")","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is convenient for building daily almanac displays."}],"type":"paragraph"},{"level":2,"anchor":"Time-Zones","text":"Time Zones","type":"heading"},{"inlineContent":[{"type":"text","text":"All returned times are in UTC. Convert for display:"}],"type":"paragraph"},{"syntax":"swift","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"