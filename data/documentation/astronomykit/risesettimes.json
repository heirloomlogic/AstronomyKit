{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"AstronomyKit can find rise times, set times, culmination (transit), and times when bodies reach specific altitudes. These calculations account for atmospheric refraction."}],"type":"paragraph"},{"anchor":"Basic-Rise-and-Set","type":"heading","level":2,"text":"Basic Rise and Set"},{"anchor":"Sunrise-and-Sunset","type":"heading","level":3,"text":"Sunrise and Sunset"},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer) {","    print(\"Sunrise: \\(sunrise.date)\")","}","","if let sunset = try CelestialBody.sun.setTime(after: .now, from: observer) {","    print(\"Sunset: \\(sunset.date)\")","}"],"syntax":"swift"},{"anchor":"Moonrise-and-Moonset","type":"heading","level":3,"text":"Moonrise and Moonset"},{"type":"codeListing","code":["if let moonrise = try CelestialBody.moon.riseTime(after: .now, from: observer) {","    print(\"Moonrise: \\(moonrise)\")","}","","if let moonset = try CelestialBody.moon.setTime(after: .now, from: observer) {","    print(\"Moonset: \\(moonset)\")","}"],"syntax":"swift"},{"anchor":"Planet-Rise-and-Set","type":"heading","level":3,"text":"Planet Rise and Set"},{"type":"codeListing","code":["if let marsRise = try CelestialBody.mars.riseTime(after: .now, from: observer) {","    print(\"Mars rises at \\(marsRise)\")","}"],"syntax":"swift"},{"anchor":"Culmination-Transit","type":"heading","level":2,"text":"Culmination (Transit)"},{"inlineContent":[{"type":"text","text":"Culmination is when a body crosses the meridian and reaches its highest altitude:"}],"type":"paragraph"},{"type":"codeListing","code":["let transit = try CelestialBody.sun.culmination(after: .now, from: observer)","print(\"Solar noon: \\(transit.time)\")","print(\"Max altitude: \\(transit.horizon.altitude)°\")"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"This is useful for:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Finding solar noon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Determining the best time to observe a planet","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Calculating day length","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Custom-Altitude-Searches","type":"heading","level":2,"text":"Custom Altitude Searches"},{"inlineContent":[{"type":"text","text":"Find when a body reaches a specific altitude:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Astronomical twilight begins when Sun is 18° below horizon","let twilight = try CelestialBody.sun.searchAltitude(","    -18.0,","    direction: .set,","    after: .now,","    from: observer",")","if let time = twilight {","    print(\"Astronomical twilight begins: \\(time)\")","}"],"syntax":"swift"},{"anchor":"Civil-and-Nautical-Twilight","type":"heading","level":3,"text":"Civil and Nautical Twilight"},{"type":"codeListing","code":["\/\/ Civil twilight: Sun at -6°","let civilTwilight = try CelestialBody.sun.searchAltitude(","    -6.0, direction: .set, after: .now, from: observer",")","","\/\/ Nautical twilight: Sun at -12°","let nauticalTwilight = try CelestialBody.sun.searchAltitude(","    -12.0, direction: .set, after: .now, from: observer",")"],"syntax":"swift"},{"anchor":"Minimum-Observation-Altitude","type":"heading","level":3,"text":"Minimum Observation Altitude"},{"type":"codeListing","code":["\/\/ Find when Mars rises above 20° (good for observation)","let observable = try CelestialBody.mars.searchAltitude(","    20.0,","    direction: .rise,","    after: .now,","    from: observer",")"],"syntax":"swift"},{"anchor":"Hour-Angle-Searches","type":"heading","level":2,"text":"Hour Angle Searches"},{"inlineContent":[{"type":"text","text":"Search for a specific hour angle:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Hour angle 0 = culmination (upper transit)","let upperTransit = try CelestialBody.saturn.searchHourAngle(","    0,","    after: .now,","    from: observer",")","","\/\/ Hour angle 12 = lower culmination","let lowerTransit = try CelestialBody.saturn.searchHourAngle(","    12,","    after: .now,","    from: observer",")"],"syntax":"swift"},{"anchor":"Search-Limits","type":"heading","level":2,"text":"Search Limits"},{"inlineContent":[{"type":"text","text":"All searches have a time limit (default: 366 days):"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Limit search to next 30 days","let sunrise = try CelestialBody.sun.riseTime(","    after: .now,","    from: observer,","    limitDays: 30",")"],"syntax":"swift"},{"anchor":"Handling-No-Result","type":"heading","level":2,"text":"Handling “No Result”"},{"inlineContent":[{"type":"text","text":"Rise\/set searches return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if no event occurs in the search period:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ In polar regions, the Sun may not rise\/set","let arcticObserver = Observer(latitude: 78.0, longitude: 15.0)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: arcticObserver) {","    print(\"Sunrise: \\(sunrise)\")","} else {","    print(\"Sun does not rise during this period (polar night\/day)\")","}"],"syntax":"swift"},{"anchor":"Daily-Events","type":"heading","level":2,"text":"Daily Events"},{"inlineContent":[{"type":"text","text":"Get all events for a single day:"}],"type":"paragraph"},{"type":"codeListing","code":["let events = try DailyEvents(","    body: .sun,","    date: .now,","    from: observer",")","","if let rise = events.rise {","    print(\"Rise: \\(rise)\")","}","if let transit = events.culmination {","    print(\"Transit: \\(transit.time) at \\(transit.horizon.altitude)°\")","}","if let set = events.set {","    print(\"Set: \\(set)\")","}","","if events.isVisible {","    print(\"Sun is visible at some point today\")","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"This is convenient for building daily almanac displays."}],"type":"paragraph"},{"anchor":"Time-Zones","type":"heading","level":2,"text":"Time Zones"},{"inlineContent":[{"type":"text","text":"All returned times are in UTC. Convert for display:"}],"type":"paragraph"},{"type":"codeListing","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise: \\(formatter.string(from: sunrise.date))\")"],"syntax":"swift"}],"kind":"content"}],"sections":[],"seeAlsoSections":[{"title":"Events","anchor":"Events","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipses","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/SeasonsAndEvents","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroSearch","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Seasons","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Sun","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Eclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LunarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GlobalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/LocalSolarEclipse","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseEvent","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EclipseKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Apsis","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/ApsisKind","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Elongation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Visibility"],"generated":true}],"variants":[{"paths":["\/documentation\/astronomykit\/risesettimes"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKi