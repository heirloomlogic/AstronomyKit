)\")","}"]},{"type":"heading","text":"Moonrise and Moonset","level":3,"anchor":"Moonrise-and-Moonset"},{"type":"codeListing","syntax":"swift","code":["if let moonrise = try CelestialBody.moon.riseTime(after: .now, from: observer) {","    print(\"Moonrise: \\(moonrise)\")","}","","if let moonset = try CelestialBody.moon.setTime(after: .now, from: observer) {","    print(\"Moonset: \\(moonset)\")","}"]},{"type":"heading","text":"Planet Rise and Set","level":3,"anchor":"Planet-Rise-and-Set"},{"type":"codeListing","syntax":"swift","code":["if let marsRise = try CelestialBody.mars.riseTime(after: .now, from: observer) {","    print(\"Mars rises at \\(marsRise)\")","}"]},{"type":"heading","text":"Culmination (Transit)","level":2,"anchor":"Culmination-Transit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Culmination is when a body crosses the meridian and reaches its highest altitude:"}]},{"type":"codeListing","syntax":"swift","code":["let transit = try CelestialBody.sun.culmination(after: .now, from: observer)","print(\"Solar noon: \\(transit.time)\")","print(\"Max altitude: \\(transit.horizon.altitude)°\")"]},{"type":"paragraph","inlineContent":[{"text":"This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finding solar noon"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Determining the best time to observe a planet"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Calculating day length","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Custom Altitude Searches","level":2,"anchor":"Custom-Altitude-Searches"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find when a body reaches a specific altitude:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Astronomical twilight begins when Sun is 18° below horizon","let twilight = try CelestialBody.sun.searchAltitude(","    -18.0,","    direction: .set,","    after: .now,","    from: observer",")","if let time = twilight {","    print(\"Astronomical twilight begins: \\(time)\")","}"]},{"type":"heading","text":"Civil and Nautical Twilight","level":3,"anchor":"Civil-and-Nautical-Twilight"},{"type":"codeListing","syntax":"swift","code":["\/\/ Civil twilight: Sun at -6°","let civilTwilight = try CelestialBody.sun.searchAltitude(","    -6.0, direction: .set, after: .now, from: observer",")","","\/\/ Nautical twilight: Sun at -12°","let nauticalTwilight = try CelestialBody.sun.searchAltitude(","    -12.0, direction: .set, after: .now, from: observer",")"]},{"type":"heading","text":"Minimum Observation Altitude","level":3,"anchor":"Minimum-Observation-Altitude"},{"type":"codeListing","syntax":"swift","code":["\/\/ Find when Mars rises above 20° (good for observation)","let observable = try CelestialBody.mars.searchAltitude(","    20.0,","    direction: .rise,","    after: .now,","    from: observer",")"]},{"type":"heading","text":"Hour Angle Searches","level":2,"anchor":"Hour-Angle-Searches"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Search for a specific hour angle:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Hour angle 0 = culmination (upper transit)","let upperTransit = try CelestialBody.saturn.searchHourAngle(","    0,","    after: .now,","    from: observer",")","","\/\/ Hour angle 12 = lower culmination","let lowerTransit = try CelestialBody.saturn.searchHourAngle(","    12,","    after: .now,","    from: observer",")"]},{"type":"heading","text":"Search Limits","level":2,"anchor":"Search-Limits"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All searches have a time limit (default: 366 days):"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Limit search to next 30 days","let sunrise = try CelestialBody.sun.riseTime(","    after: .now,","    from: observer,","    limitDays: 30",")"]},{"type":"heading","text":"Handling “No Result”","level":2,"anchor":"Handling-No-Result"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise\/set searches return "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if no event occurs in the search period:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ In polar regions, the Sun may not rise\/set","let arcticObserver = Observer(latitude: 78.0, longitude: 15.0)","","if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: arcticObserver) {","    print(\"Sunrise: \\(sunrise)\")","} else {","    print(\"Sun does not rise during this period (polar night\/day)\")","}"]},{"type":"heading","text":"Daily Events","level":2,"anchor":"Daily-Events"},{"type":"paragraph","inlineContent":[{"text":"Get all events for a single day:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let events = try CelestialBody.sun.dailyEvents(","    on: .now,","    from: observer",")","","if let rise = events.rise {","    print(\"Rise: \\(rise)\")","}","if let transit = events.culmination {","    print(\"Transit: \\(transit.time) at \\(transit.horizon.altitude)°\")","}","if let set = events.set {","    print(\"Set: \\(set)\")","}","","if events.isVisible {","    print(\"Sun is visible at some point today\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is convenient for building daily almanac displays."}]},{"type":"heading","text":"Time Zones","level":2,"anchor":"Time-Zones"},{"type":"paragraph","inlineContent":[{"text":"All returned times are in UTC. Convert for display:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer)!","","let formatter = DateFormatter()","formatter.timeZone = TimeZone(identifier: \"America\/New_York\")","formatter.timeStyle = .short","print(\"Sunrise: \\(formatter.string(from: sunrise.date))\")"]}]}],"references":{"doc://AstronomyKit/documentation/AstronomyKit/LocalSolarEclipse":{"url":"\/documentation\/astronomykit\/localsolareclipse","role":"sym