"syntax":"swift","code":["\/\/ Astronomical twilight begins when Sun is 18° below horizon","let twilight = try CelestialBody.sun.searchAltitude(","    -18.0,","    direction: .set,","    after: .now,","    from: observer",")","if let time = twilight {","    print(\"Astronomical twilight begins: \\(time)\")","}"],"type":"codeListing"},{"text":"Civil and Nautical Twilight","anchor":"Civil-and-Nautical-Twilight","level":3,"type":"heading"},{"syntax":"swift","code":["\/\/ Civil twilight: Sun at -6°","let civilTwilight = try CelestialBody.sun.searchAltitude(","    -6.0, direction: .set, after: .now, from: observer",")","","\/\/ Nautical twilight: Sun at -12°","let nauticalTwilight = try CelestialBody.sun.searchAltitude(","    -12.0, direction: .set, after: .now, from: observer",")"],"type":"codeListing"},{"text":"Minimum Observation Altitude","anchor":"Minimum-Observation-Altitude","level":3,"type":"heading"},{"syntax":"swift","code":["\/\/ Find when Mars rises above 20° (good for observation)","let observable = try CelestialBody.mars.searchAltitude(","    20.0,","    direction: .rise,","    after: .now,","    from: observer",")"],"type":"codeListing"},{"type":"heading","level":2,"text":"Hour Angle Searches","anchor":"Hour-Angle-Searches"},{"type":"paragraph","inlineContent":[{"text":"Search for a specific hour angle:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Hour angle 0 = culmination (upper transit)","let upperTransit = try CelestialBody.saturn.searchHourAngle(","    0,","    after: .now,","    from: observer",")","","\/\/ Hour angle 12 = lower culmination","let lowerTransit = try CelestialBody.saturn.searchHourAngle(","    12,","    after: .now,","    from: observer",")"]},{"type":"heading","level":2,"text":"Search Limits","anchor":"Search-Limits"},{"type":"paragraph","inlineContent":[{"text":"All searches have a time limit (default: 366 days):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Limit search to next 30 d