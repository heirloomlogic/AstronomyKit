{"abstract":[{"type":"text","text":"Calculate the positions of celestial bodies in various coordinate systems."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"title":"Position Calculations","anchor":"Position-Calculations","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Constellation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Aberration","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EquatorDate"],"generated":true}],"kind":"article","variants":[{"paths":["\/documentation\/astronomykit\/celestialpositions"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions"},"metadata":{"modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article","title":"Celestial Positions"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems.","type":"text"}]},{"text":"Celestial Bodies","anchor":"Celestial-Bodies","type":"heading","level":2},{"text":"Available Bodies","anchor":"Available-Bodies","type":"heading","level":3},{"type":"codeListing","code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"],"syntax":"swift"},{"text":"Body Properties","anchor":"Body-Properties","type":"heading","level":3},{"type":"codeListing","code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"],"syntax":"swift"},{"text":"Looking Up Bodies by Name","anchor":"Looking-Up-Bodies-by-Name","type":"heading","level":3},{"type":"codeListing","code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"],"syntax":"swift"},{"text":"Horizon Coordinates","anchor":"Horizon-Coordinates","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where does a body appear in your local sky?"}]},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"],"syntax":"swift"},{"text":"Equatorial Coordinates","anchor":"Equatorial-Coordinates","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Right ascension and declination on the celestial sphere:","type":"text"}]},{"type":"codeListing","code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""],"syntax":"swift"},{"text":"Equator Date Options","anchor":"Equator-Date-Options","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Choose the reference equinox:","type":"text"}]},{"type":"codeListing","code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift"},{"text":"Ecliptic Coordinates","anchor":"Ecliptic-Coordinates","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Position relative to the ecliptic plane:","type":"text"}]},{"type":"codeListing","code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"],"syntax":"swift"},{"text":"Position Vectors","anchor":"Position-Vectors","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cartesian coordinates in 3D space:"}]},{"type":"codeListing","code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.heliocentricPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"],"syntax":"swift"},{"text":"Distance Calculations","anchor":"Distance-Calculations","type":"heading","level":2},{"type":"codeListing","code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"],"syntax":"swift"},{"text":"Constellation Identification","anchor":"Constellation-Identification","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Find which constellation contains a body:","type":"text"}]},{"type":"codeListing","code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(rightAscension: 5.9195, declination: 7.4071)","print(orion.name)  \/\/ \"Orion\""],"syntax":"swift"},{"text":"Fixed Stars","anchor":"Fixed-Stars","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates using "},{"type":"reference","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog.","type":"text"}]},{"text":"Aberration Correction","anchor":"Aberration-Correction","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Control light-time and aberration corrections:","type":"text"}]},{"type":"codeListing","code":["\/\/ With correction (default) - apparent position","let apparent = try body.geocentricPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geocentricPosition(at: .now, aberration: .none)"],"syntax":"swift"},{"text":"Refraction Correction","anchor":"Refraction-Correction","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Atmospheric refraction affects horizon coordinates:"}]},{"type":"codeListing","code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"],"syntax":"swift"}]}],"references":{"doc://AstronomyKit/documentation/AstronomyKit/CoordinateSystems":{"kind":"article","title":"Coordinate Systems","url":"\/documentation\/astronomykit\/coordinatesystems","type":"topic","role":"article","abstract":[{"text":"Transform positions between different astronomical coordinate systems.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems"},"https://github.com/cosinekitty/astronomy":{"type":"link","title":"Astronomy Engine","titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy","identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"url":"\/documentation\/astronomykit\/observer","title":"Observer","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Observer","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"Observer","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","type":"topic","abstract":[{"type":"text","text":"A geographic location for observing celestial objects."}]},"doc://AstronomyKit/documentation/AstronomyKit/EquatorDate":{"role":"symbol","type":"topic","titl