{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/celestialpositions"]}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"kind":"article","abstract":[{"text":"Calculate the positions of celestial bodies in various coordinate systems.","type":"text"}],"metadata":{"roleHeading":"Article","role":"article","title":"Celestial Positions","modules":[{"name":"AstronomyKit"}]},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems.","type":"text"}],"type":"paragraph"},{"text":"Celestial Bodies","anchor":"Celestial-Bodies","type":"heading","level":2},{"text":"Available Bodies","anchor":"Available-Bodies","type":"heading","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"]},{"text":"Body Properties","anchor":"Body-Properties","type":"heading","level":3},{"type":"codeListing","syntax":"swift","code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"]},{"text":"Looking Up Bodies by Name","anchor":"Looking-Up-Bodies-by-Name","type":"heading","level":3},{"type":"codeListing","syntax":"swift","code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"]},{"text":"Horizon Coordinates","anchor":"Horizon-Coordinates","type":"heading","level":2},{"inlineContent":[{"text":"Where does a body appear in your local sky?","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"],"syntax":"swift"},{"text":"Equatorial Coordinates","type":"heading","anchor":"Equatorial-Coordinates","level":2},{"type":"paragraph","inlineContent":[{"text":"Right ascension and declination on the celestial sphere:","type":"text"}]},{"type":"codeListing","code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""],"syntax":"swift"},{"text":"Equator Date Options","type":"heading","anchor":"Equator-Date-Options","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose the reference equinox:"}]},{"type":"codeListing","code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift"},{"text":"Ecliptic Coordinates","type":"heading","anchor":"Ecliptic-Coordinates","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Position relative to the ecliptic plane:"}]},{"type":"codeListing","code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"],"syntax":"swift"},{"anchor":"Position-Vectors","type":"heading","text":"Position Vectors","level":2},{"type":"paragraph","inlineContent":[{"text":"Cartesian coordinates in 3D space:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geoPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.helioPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"]},{"anchor":"Distance-Calculations","type":"heading","text":"Distance Calculations","level":2},{"syntax":"swift","type":"codeListing","code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"]},{"anchor":"Constellation-Identification","type":"heading","text":"Constellation Identification","level":2},{"type":"paragraph","inlineContent":[{"text":"Find which constellation contains a body:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(ra: 5.9195, dec: 7.4071)","print(orion.name)  \/\/ \"Orion\""]},{"anchor":"Fixed-Stars","type":"heading","text":"Fixed Stars","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates using "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    ra: 3.136148,      \/\/ J2000 RA in hours","    dec: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog."}]},{"anchor":"Aberration-Correction","type":"heading","text":"Aberration Correction","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control light-time and aberration corrections:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ With correction (default) - apparent position","let apparent = try body.geoPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geoPosition(at: .now, aberration: .none)"]},{"anchor":"Refraction-Correction","type":"heading","text":"Refraction Correction","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Atmospheric refraction affects horizon coordinates:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"]}],"kind":"content"}],"seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer"],"title":"Position Calculations","generated":true,"anchor":"Position-Calculations"}],"references":{"doc://AstronomyKit/documentation/AstronomyKit":{"url":"\/documentation\/astronomykit","type":"topic","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"text":" library.","type":"text"}],"title":"AstronomyKit","kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","role":"collection"},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"navigatorTitle":[{"kind":"identifier","text":"Observer"}],"title":"Observer","url":"\/documentation\/astronomykit\/observer","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observer"}],"abstract":[{"type":"text","text":"A geographic location for observing celestial objects."}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","type":"topic"},"https://github.com/cosinekitty/astronomy":{"url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link","title":"Astronomy Engine","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},"doc://AstronomyKit/documentation/AstronomyKit/CelestialBody":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","title":"CelestialBody","abstract":[{"text":"A celestial body in the solar system.","type":"text"}],"role":"symbol","url":"\/documentation\/astronomykit\/celestialbody","navigatorTitle":[{"text":"CelestialBody","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CelestialBody","kind":"identifier"}],"type":"topic"},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar":{"type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","url":"\/documentation\/astronomykit\/fixedstar","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"FixedStar"}],"role":"symbol","title":"FixedStar","abstract":[{"type":"text","text":"A fixed star defined by its J2000 equatorial coordinates."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FixedStar"}]},"doc://AstronomyKit/documentation/AstronomyKit/CoordinateSystems":{"type":"topic","kind":"article","url":"\/documentation\/astronomykit\/coordinatesystems","role":"article","title":"Coordinate Systems","abstract":[{"type":"text","text":"Transform positions between different astronomical coordinate systems."}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems"}}}