{"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems."}]},{"text":"Celestial Bodies","type":"heading","anchor":"Celestial-Bodies","level":2},{"text":"Available Bodies","type":"heading","anchor":"Available-Bodies","level":3},{"code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"],"type":"codeListing","syntax":"swift"},{"text":"Body Properties","type":"heading","anchor":"Body-Properties","level":3},{"code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"],"type":"codeListing","syntax":"swift"},{"text":"Looking Up Bodies by Name","type":"heading","anchor":"Looking-Up-Bodies-by-Name","level":3},{"code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"],"type":"codeListing","syntax":"swift"},{"text":"Horizon Coordinates","type":"heading","anchor":"Horizon-Coordinates","level":2},{"type":"paragraph","inlineContent":[{"text":"Where does a body appear in your local sky?","type":"text"}]},{"code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"],"type":"codeListing","syntax":"swift"},{"text":"Equatorial Coordinates","type":"heading","anchor":"Equatorial-Coordinates","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Right ascension and declination on the celestial sphere:"}]},{"code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""],"type":"codeListing","syntax":"swift"},{"text":"Equator Date Options","type":"heading","anchor":"Equator-Date-Options","level":3},{"type":"paragraph","inlineContent":[{"text":"Choose the reference equinox:","type":"text"}]},{"code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"],"type":"codeListing","syntax":"swift"},{"text":"Ecliptic Coordinates","type":"heading","anchor":"Ecliptic-Coordinates","level":2},{"type":"paragraph","inlineContent":[{"text":"Position relative to the ecliptic plane:","type":"text"}]},{"code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"],"type":"codeListing","syntax":"swift"},{"text":"Position Vectors","type":"heading","anchor":"Position-Vectors","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cartesian coordinates in 3D space:"}]},{"code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geoPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.helioPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"],"type":"codeListing","syntax":"swift"},{"text":"Distance Calculations","type":"heading","anchor":"Distance-Calculations","level":2},{"code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"],"type":"codeListing","syntax":"swift"},{"text":"Constellation Identification","type":"heading","anchor":"Constellation-Identification","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find which constellation contains a body:"}]},{"code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(ra: 5.9195, dec: 7.4071)","print(orion.name)  \/\/ \"Orion\""],"type":"codeListing","syntax":"swift"},{"text":"Fixed Stars","type":"heading","anchor":"Fixed-Stars","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates using "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    ra: 3.136148,      \/\/ J2000 RA in hours","    dec: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog."}]},{"text":"Aberration Correction","type":"heading","anchor":"Aberration-Correction","level":2},{"type":"paragraph","inlineContent":[{"text":"Control light-time and aberration corrections:","type":"text"}]},{"code":["\/\/ With correction (default) - apparent position","let apparent = try body.geoPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geoPosition(at: .now, aberration: .none)"],"type":"codeListing","syntax":"swift"},{"text":"Refraction Correction","type":"heading","anchor":"Refraction-Correction","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Atmospheric refraction affects horizon coordinates:"}]},{"code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/celestialpositions"]}],"metadata":{"modules":[{"name":"AstronomyKit"}],"role":"article","roleHeading":"Article","title":"Celestial Positions"},"kind":"article","identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Position-Calculations","title":"Position Calculations","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer"],"generated":true}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"text":"Calculate the positions of celestial bodies in various coordinate systems.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://AstronomyKit/documentation/AstronomyKit/CoordinateSystems":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","title":"Coordinate Systems","role":"article","url":"\/documentation\/astronomykit\/coordinatesystems","kind":"article","type":"topic","abstract":[{"type":"text","text":"Transform positions between different astronomical coordinate systems."}]},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"title":"Observer","url":"\/documentation\/astronomykit\/observer","kind":"symbol","abstract":[{"text":"A geographic location for observing celestial objects.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observer"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Observer"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer"},"doc://AstronomyKit/documentation/AstronomyKit":{"role":"collection","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"text":" library.","type":"text"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol","type":"topic","title":"AstronomyKit"},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","abstract":[{"text":"A fixed star defined by its J2000 equatorial coordinates.","type":"text"}],"url":"\/documentation\/astronomykit\/fixedstar","kind":"symbol","role":"symbol","title":"FixedStar","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FixedStar","kind":"identifier"}],"navigatorTitle":[{"text":"FixedStar","kind":"identifier"}],"type":"topic"},"https://github.com/cosinekitty/astronomy":{"titleInlineContent":[{"text":"Astronomy Engine","type":"text"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine"},"doc://AstronomyKit/documentation/AstronomyKit/CelestialBody":{"abstract":[{"text":"A celestial body in the solar system.","type":"text"}],"kind":"symbol","title":"CelestialBody","role":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","type":"topic","navigatorTitle":[{"text":"CelestialBody","kind":"identifier"}],"url":"\/documentation\/astronomykit\/celestialbody","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CelestialBody","kind":"identifier"}]}}}