{"seeAlsoSections":[{"generated":true,"anchor":"Position-Calculations","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Constellation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Aberration","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EquatorDate"],"title":"Position Calculations"}],"metadata":{"modules":[{"name":"AstronomyKit"}],"role":"article","title":"Celestial Positions","roleHeading":"Article"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Celestial Bodies","anchor":"Celestial-Bodies"},{"level":3,"type":"heading","text":"Available Bodies","anchor":"Available-Bodies"},{"code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Body Properties","anchor":"Body-Properties"},{"code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Looking Up Bodies by Name","anchor":"Looking-Up-Bodies-by-Name"},{"code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Horizon Coordinates","anchor":"Horizon-Coordinates"},{"inlineContent":[{"type":"text","text":"Where does a body appear in your local sky?"}],"type":"paragraph"},{"code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Equatorial Coordinates","anchor":"Equatorial-Coordinates"},{"inlineContent":[{"type":"text","text":"Right ascension and declination on the celestial sphere:"}],"type":"paragraph"},{"code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Equator Date Options","anchor":"Equator-Date-Options"},{"inlineContent":[{"type":"text","text":"Choose the reference equinox:"}],"type":"paragraph"},{"code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Ecliptic Coordinates","anchor":"Ecliptic-Coordinates"},{"inlineContent":[{"type":"text","text":"Position relative to the ecliptic plane:"}],"type":"paragraph"},{"code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Position Vectors","anchor":"Position-Vectors"},{"inlineContent":[{"type":"text","text":"Cartesian coordinates in 3D space:"}],"type":"paragraph"},{"code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.heliocentricPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Distance-Calculations","type":"heading","level":2,"text":"Distance Calculations"},{"type":"codeListing","code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"],"syntax":"swift"},{"anchor":"Constellation-Identification","type":"heading","level":2,"text":"Constellation Identification"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find which constellation contains a body:"}]},{"type":"codeListing","syntax":"swift","code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(rightAscension: 5.9195, declination: 7.4071)","print(orion.name)  \/\/ \"Orion\""]},{"text":"Fixed Stars","type":"heading","anchor":"Fixed-Stars","level":2},{"type":"paragraph","inlineContent":[{"text":"Define and track fixed stars by their J2000 catalog coordinates using ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog."}],"type":"paragraph"},{"text":"Aberration Correction","anchor":"Aberration-Correction","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Control light-time and aberration corrections:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ With correction (default) - apparent position","let apparent = try body.geocentricPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geocentricPosition(at: .now, aberration: .none)"],"type":"codeListing"},{"text":"Refraction Correction","anchor":"Refraction-Correction","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Atmospheric refraction affects horizon coordinates:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"],"type":"codeListing"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions"},"kind":"article","hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"abstract":[{"type":"text","text":"Calculate the positions of celestial bodies in various coordinate systems."}],"variants":[{"paths":["\/documentation\/astronomykit\/celestialpositions"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://AstronomyKit/documentation/AstronomyKit/EquatorDate":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EquatorDate","type":"topic","role":"symbol","url":"\/documentation\/astronomykit\/equatordate","navigatorTitle":[{"kind":"identifier","text":"EquatorDate"}],"kind":"symbol","title":"EquatorDate","abstract":[{"text":"The equinox reference for equatorial coordinates.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"EquatorDate"}]},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FixedStar"}],"url":"\/documentation\/astronomykit\/fixedstar","title":"FixedStar","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","kind":"symbol","abstract":[{"type":"text","text":"A fixed star defined by its J2000 equatorial coordinates."}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FixedStar"}]},"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine","url":"https:\/\/github.com\/cosinekitty\/astronomy","titleInlineContent":[{"type":"text",