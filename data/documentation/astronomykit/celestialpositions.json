:[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Aberration","kind":"identifier"}],"navigatorTitle":[{"text":"Aberration","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Aberration","url":"\/documentation\/astronomykit\/aberration","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Light aberration correction mode."}],"title":"Aberration"},"doc://AstronomyKit/documentation/AstronomyKit/CelestialBody":{"role":"symbol","navigatorTitle":[{"text":"CelestialBody","kind":"identifier"}],"url":"\/documentation\/astronomykit\/celestialbody","abstract":[{"type":"text","text":"A celestial body in the solar system."}],"kind":"symbol","type":"topic","title":"CelestialBody","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CelestialBody","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody"}}}