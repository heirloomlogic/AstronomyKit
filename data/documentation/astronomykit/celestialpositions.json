{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems.","type":"text"}]},{"level":2,"text":"Celestial Bodies","type":"heading","anchor":"Celestial-Bodies"},{"level":3,"text":"Available Bodies","type":"heading","anchor":"Available-Bodies"},{"type":"codeListing","code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"],"syntax":"swift"},{"level":3,"text":"Body Properties","type":"heading","anchor":"Body-Properties"},{"type":"codeListing","code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"],"syntax":"swift"},{"level":3,"text":"Looking Up Bodies by Name","type":"heading","anchor":"Looking-Up-Bodies-by-Name"},{"type":"codeListing","code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"],"syntax":"swift"},{"level":2,"text":"Horizon Coordinates","type":"heading","anchor":"Horizon-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where does a body appear in your local sky?"}]},{"type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"],"syntax":"swift"},{"level":2,"text":"Equatorial Coordinates","type":"heading","anchor":"Equatorial-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Right ascension and declination on the celestial sphere:"}]},{"type":"codeListing","code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""],"syntax":"swift"},{"level":3,"text":"Equator Date Options","type":"heading","anchor":"Equator-Date-Options"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose the reference equinox:"}]},{"type":"codeListing","code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"],"syntax":"swift"},{"level":2,"text":"Ecliptic Coordinates","type":"heading","anchor":"Ecliptic-Coordinates"},{"type":"paragraph","inlineContent":[{"text":"Position relative to the ecliptic plane:","type":"text"}]},{"type":"codeListing","code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"],"syntax":"swift"},{"level":2,"text":"Position Vectors","type":"heading","anchor":"Position-Vectors"},{"type":"paragraph","inlineContent":[{"text":"Cartesian coordinates in 3D space:","type":"text"}]},{"type":"codeListing","code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geoPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.helioPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"],"syntax":"swift"},{"level":2,"text":"Distance Calculations","type":"heading","anchor":"Distance-Calculations"},{"type":"codeListing","code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"],"syntax":"swift"},{"level":2,"text":"Constellation Identification","type":"heading","anchor":"Constellation-Identification"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find which constellation contains a body:"}]},{"type":"codeListing","code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(ra: 5.9195, dec: 7.4071)","print(orion.name)  \/\/ \"Orion\""],"syntax":"swift"},{"level":2,"text":"Fixed Stars","type":"heading","anchor":"Fixed-Stars"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates using "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","type":"reference","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    ra: 3.136148,      \/\/ J2000 RA in hours","    dec: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog.","type":"text"}]},{"level":2,"text":"Aberration Correction","type":"heading","anchor":"Aberration-Correction"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control light-time and aberration corrections:"}]},{"type":"codeListing","code":["\/\/ With correction (default) - apparent position","let apparent = try body.geoPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geoPosition(at: .now, aberration: .none)"],"syntax":"swift"},{"level":2,"text":"Refraction Correction","type":"heading","anchor":"Refraction-Correction"},{"type":"paragraph","inlineContent":[{"text":"Atmospheric refraction affects horizon coordinates:","type":"text"}]},{"type":"codeListing","code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"],"syntax":"swift"}]}],"abstract":[{"text":"Calculate the positions of celestial bodies in various coordinate systems.","type":"text"}],"metadata":{"title":"Celestial Positions","modules":[{"name":"AstronomyKit"}],"roleHeading":"Article","role":"article"},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer"],"title":"Position Calculations","anchor":"Position-Calculations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/celestialpositions"]}],"sections":[],"kind":"article","references":{"https://github.com/cosinekitty/astronomy":{"titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"type":"link","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","url":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine"},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","navigatorTitle":[{"kind":"identifier","text":"Observer"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observer"}],"url":"\/documentation\/astronomykit\/observer","abstract":[{"type":"text","text":"A geographic location for observing celestial objects."}],"kind":"symbol","title":"Observer","role":"symbol","type":"topic"},"doc://AstronomyKit/documentation/AstronomyKit":{"type":"topic","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol","role":"collection","title":"AstronomyKit","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","type":"reference","isActive":true},{"text":" library.","type":"text"}]},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar":{"kind":"symbol","abstract":[{"type":"text","text":"A fixed star defined by its J2000 equatorial coordinates."}],"url":"\/documentation\/astronomykit\/fixedstar","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FixedStar"}],"title":"FixedStar","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"FixedStar"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","type":"topic"},"doc://AstronomyKit/documentation/AstronomyKit/CoordinateSystems":{"title":"Coordinate Systems","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","type":"topic","abstract":[{"text":"Transform positions between different astronomical coordinate systems.","type":"text"}],"role":"article","url":"\/documentation\/astronomykit\/coordinatesystems","kind":"article"},"doc://AstronomyKit/documentation/AstronomyKit/CelestialBody":{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","navigatorTitle":[{"text":"CelestialBody","kind":"identifier"}],"title":"CelestialBody","kind":"symbol","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CelestialBody","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A celestial body in the solar system."}],"url":"\/documentation\/astronomykit\/celestialbody"}}}