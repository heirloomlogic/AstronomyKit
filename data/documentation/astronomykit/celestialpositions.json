{"kind":"article","metadata":{"modules":[{"name":"AstronomyKit"}],"title":"Celestial Positions","roleHeading":"Article","role":"article"},"abstract":[{"type":"text","text":"Calculate the positions of celestial bodies in various coordinate systems."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/celestialpositions"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions"},"seeAlsoSections":[{"generated":true,"anchor":"Position-Calculations","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Constellation","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Aberration","doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EquatorDate"],"title":"Position Calculations"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit can calculate positions for the Sun, Moon, planets, Jupiter’s moons, and fixed stars. Positions can be expressed in multiple coordinate systems."}]},{"type":"heading","level":2,"text":"Celestial Bodies","anchor":"Celestial-Bodies"},{"type":"heading","level":3,"text":"Available Bodies","anchor":"Available-Bodies"},{"syntax":"swift","type":"codeListing","code":["\/\/ Major bodies","let sun = CelestialBody.sun","let moon = CelestialBody.moon","let mars = CelestialBody.mars","","\/\/ All planets (Mercury through Neptune)","for planet in CelestialBody.planets {","    print(planet.name)","}","","\/\/ Jupiter's Galilean moons","for moon in CelestialBody.galileanMoons {","    print(moon.name)  \/\/ Io, Europa, Ganymede, Callisto","}"]},{"type":"heading","level":3,"text":"Body Properties","anchor":"Body-Properties"},{"syntax":"swift","type":"codeListing","code":["let mars = CelestialBody.mars","","print(mars.name)           \/\/ \"Mars\"","print(mars.orbitalPeriod)  \/\/ ~686 days","print(mars.massProduct)    \/\/ Mass × G in AU³\/day²","print(mars.isPlanet)       \/\/ true","print(mars.isNakedEyeVisible)  \/\/ true"]},{"type":"heading","level":3,"text":"Looking Up Bodies by Name","anchor":"Looking-Up-Bodies-by-Name"},{"syntax":"swift","type":"codeListing","code":["if let body = CelestialBody(name: \"Jupiter\") {","    print(\"Found: \\(body)\")","}"]},{"type":"heading","level":2,"text":"Horizon Coordinates","anchor":"Horizon-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where does a body appear in your local sky?"}]},{"syntax":"swift","type":"codeListing","code":["let observer = Observer(latitude: 40.7128, longitude: -74.0060)","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Azimuth: \\(mars.azimuth)°\")       \/\/ Compass bearing","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, SE, etc.","","if mars.isAboveHorizon {","    print(\"Mars is visible!\")","}"]},{"type":"heading","level":2,"text":"Equatorial Coordinates","anchor":"Equatorial-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Right ascension and declination on the celestial sphere:"}]},{"syntax":"swift","type":"codeListing","code":["let eq = try CelestialBody.saturn.equatorial(at: .now)","","print(\"RA: \\(eq.rightAscension) hours\")","print(\"Dec: \\(eq.declination)°\")","print(\"Distance: \\(eq.distance) AU\")","","\/\/ Formatted output","print(eq.rightAscensionFormatted)   \/\/ \"02h 15m 30.2s\"","print(eq.declinationFormatted)      \/\/ \"+12° 34' 56.7\"\""]},{"type":"heading","level":3,"text":"Equator Date Options","anchor":"Equator-Date-Options"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose the reference equinox:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ J2000 coordinates (default) - standard reference epoch","let j2000 = try body.equatorial(at: .now, equatorDate: .j2000)","","\/\/ Coordinates of the observation date - accounts for precession","let ofDate = try body.equatorial(at: .now, equatorDate: .ofDate)"]},{"type":"heading","level":2,"text":"Ecliptic Coordinates","anchor":"Ecliptic-Coordinates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Position relative to the ecliptic plane:"}]},{"syntax":"swift","type":"codeListing","code":["let longitude = try CelestialBody.venus.eclipticLongitude(at: .now)","print(\"Venus ecliptic longitude: \\(longitude)°\")","","\/\/ Sun's full ecliptic position","let sunPos = try Sun.position(at: .now)","print(\"Sun: λ=\\(sunPos.longitude)°, β=\\(sunPos.latitude)°\")"]},{"type":"heading","level":2,"text":"Position Vectors","anchor":"Position-Vectors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Cartesian coordinates in 3D space:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Geocentric (from Earth's center)","let geo = try CelestialBody.jupiter.geocentricPosition(at: .now)","print(\"Distance from Earth: \\(geo.magnitude) AU\")","","\/\/ Heliocentric (from Sun's center)","let helio = try CelestialBody.mars.heliocentricPosition(at: .now)","print(\"Distance from Sun: \\(helio.magnitude) AU\")"]},{"type":"heading","level":2,"text":"Distance Calculations","anchor":"Distance-Calculations"},{"syntax":"swift","type":"codeListing","code":["\/\/ Distance from Sun","let auFromSun = try CelestialBody.mars.distanceFromSun(at: .now)","print(\"Mars is \\(auFromSun) AU from the Sun\")","","\/\/ Angular separation from Sun","let angle = try CelestialBody.venus.angleFromSun(at: .now)","print(\"Venus is \\(angle)° from the Sun\")"]},{"type":"heading","level":2,"text":"Constellation Identification","anchor":"Constellation-Identification"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find which constellation contains a body:"}]},{"syntax":"swift","type":"codeListing","code":["let constellation = try CelestialBody.mars.constellation(at: .now)","print(\"\\(constellation.symbol) - \\(constellation.name)\")","\/\/ Output: \"Tau - Taurus\"","","\/\/ Or from raw coordinates","let orion = try Constellation.find(rightAscension: 5.9195, declination: 7.4071)","print(orion.name)  \/\/ \"Orion\""]},{"type":"heading","level":2,"text":"Fixed Stars","anchor":"Fixed-Stars"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define and track fixed stars by their J2000 catalog coordinates using "},{"isActive":true,"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","type":"reference"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Define Algol (Beta Persei)","let algol = FixedStar(","    name: \"Algol\",","    rightAscension: 3.136148,  \/\/ J2000 RA in hours","    declination: 40.9556,      \/\/ J2000 Dec in degrees","    distance: 92.95    \/\/ Light-years",")","","\/\/ Get ecliptic longitude","let longitude = try algol.eclipticLongitude(at: .now)","","\/\/ Get position in local sky","let observer = Observer(latitude: 40.7, longitude: -74.0)","let horizon = try algol.horizon(at: .now, from: observer)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"J2000 coordinates can be found from star catalogs like SIMBAD, Hipparcos, or the Yale Bright Star Catalog."}]},{"type":"heading","level":2,"text":"Aberration Correction","anchor":"Aberration-Correction"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control light-time and aberration corrections:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ With correction (default) - apparent position","let apparent = try body.geocentricPosition(at: .now, aberration: .corrected)","","\/\/ Without correction - geometric position","let geometric = try body.geocentricPosition(at: .now, aberration: .none)"]},{"type":"heading","level":2,"text":"Refraction Correction","anchor":"Refraction-Correction"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Atmospheric refraction affects horizon coordinates:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Normal refraction (default)","let normal = try body.horizon(at: .now, from: observer, refraction: .normal)","","\/\/ No refraction","let geometric = try body.horizon(at: .now, from: observer, refraction: .none)","","\/\/ JPL Horizons model","let jpl = try body.horizon(at: .now, from: observer, refraction: .jplHorizons)"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"sections":[],"references":{"doc://AstronomyKit/documentation/AstronomyKit/CoordinateSystems":{"abstract":[{"type":"text","text":"Transform positions between different astronomical coordinate systems."}],"type":"topic","role":"article","title":"Coordinate Systems","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CoordinateSystems","url":"\/documentation\/astronomykit\/coordinatesystems","kind":"article"},"https://github.com/cosinekitty/astronomy":{"identifier":"https:\/\/github.com\/cosinekitty\/astronomy","title":"Astronomy Engine","titleInlineContent":[{"type":"text","text":"Astronomy Engine"}],"url":"https:\/\/github.com\/cosinekitty\/astronomy","type":"link"},"doc://AstronomyKit/documentation/AstronomyKit/Observer":{"navigatorTitle":[{"kind":"identifier","text":"Observer"}],"abstract":[{"type":"text","text":"A geographic location for observing celestial objects."}],"type":"topic","role":"symbol","title":"Observer","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Observer","url":"\/documentation\/astronomykit\/observer","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Observer","kind":"identifier"}],"kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/CelestialBody":{"title":"CelestialBody","abstract":[{"text":"A celestial body in the solar system.","type":"text"}],"role":"symbol","type":"topic","navigatorTitle":[{"text":"CelestialBody","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialBody","url":"\/documentation\/astronomykit\/celestialbody","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CelestialBody","kind":"identifier"}]},"doc://AstronomyKit/documentation/AstronomyKit/FixedStar":{"abstract":[{"text":"A fixed star defined by its J2000 equatorial coordinates.","type":"text"}],"title":"FixedStar","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"FixedStar"}],"kind":"symbol","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/FixedStar","url":"\/documentation\/astronomykit\/fixedstar","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FixedStar"}]},"doc://AstronomyKit/documentation/AstronomyKit":{"type":"topic","abstract":[{"type":"text","text":"Swift bindings for Don Cross’ "},{"type":"reference","identifier":"https:\/\/github.com\/cosinekitty\/astronomy","isActive":true},{"type":"text","text":" library."}],"role":"collection","title":"AstronomyKit","identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit","url":"\/documentation\/astronomykit","kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/Constellation":{"navigatorTitle":[{"kind":"identifier","text":"Constellation"}],"type":"topic","abstract":[{"text":"A constellation identified from celestial coordinates.","type":"text"}],"role":"symbol","title":"Constellation","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Constellation","kind":"identifier"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Constellation","url":"\/documentation\/astronomykit\/constellation","kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/Aberration":{"navigatorTitle":[{"kind":"identifier","text":"Aberration"}],"type":"topic","abstract":[{"type":"text","text":"Light aberration correction mode."}],"role":"symbol","title":"Aberration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Aberration"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/Aberration","url":"\/documentation\/astronomykit\/aberration","kind":"symbol"},"doc://AstronomyKit/documentation/AstronomyKit/EquatorDate":{"navigatorTitle":[{"kind":"identifier","text":"EquatorDate"}],"type":"topic","abstract":[{"text":"The equinox reference for equatorial coordinates.","type":"text"}],"role":"symbol","title":"EquatorDate","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"EquatorDate"}],"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/EquatorDate","url":"\/documentation\/astronomykit\/equatordate","kind":"symbol"}}}