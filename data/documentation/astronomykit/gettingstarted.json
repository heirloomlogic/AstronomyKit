{"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"AstronomyKit"}],"title":"Getting Started with AstronomyKit"},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Learn how to add AstronomyKit to your project and perform basic astronomical calculations.","type":"text"}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers"],"generated":true,"anchor":"Essentials"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit provides a type-safe Swift interface for astronomical calculations. This article walks you through installation and your first calculations."}]},{"text":"Installation","type":"heading","level":2,"anchor":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add AstronomyKit to your Swift package:"}]},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/heirloomlogic\/AstronomyKit\", from: \"1.0.0\")","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or in Xcode: "},{"inlineContent":[{"type":"text","text":"File → Add Package Dependencies"}],"type":"strong"},{"type":"text","text":" and enter the repository URL."}]},{"text":"Your First Calculations","type":"heading","level":2,"anchor":"Your-First-Calculations"},{"text":"Import the Package","type":"heading","level":3,"anchor":"Import-the-Package"},{"syntax":"swift","type":"codeListing","code":["import AstronomyKit"]},{"text":"Set Up Your Observer Location","type":"heading","level":3,"anchor":"Set-Up-Your-Observer-Location"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most astronomical calculations require an observer location on Earth:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ New York City","let observer = Observer(latitude: 40.7128, longitude: -74.0060)","","\/\/ With elevation (in meters)","let denver = Observer(latitude: 39.7392, longitude: -104.9903, height: 1609)"]},{"text":"Get the Current Time","type":"heading","level":3,"anchor":"Get-the-Current-Time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AstronomyKit uses "},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","isActive":true,"type":"reference"},{"type":"text","text":" for all time-based calculations:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From a specific date","let newYear = AstroTime(year: 2025, month: 1, day: 1, hour: 12)","","\/\/ From Foundation Date","let fromDate = AstroTime(Date())"]},{"text":"Calculate a Position","type":"heading","level":3,"anchor":"Calculate-a-Position"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find where a celestial body appears in your sky:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Mars in the local sky","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, etc."]},{"text":"Find the Moon Phase","type":"heading","level":3,"anchor":"Find-the-Moon-Phase"},{"syntax":"swift","type":"codeListing","code":["let angle = try Moon.phaseAngle(at: .now)","print(\"\\(Moon.emoji(for: angle)) \\(Moon.phaseName(for: angle))\")","\/\/ Output: 🌔 Waxing Gibbous"]},{"text":"Get Rise and Set Times","type":"heading","level":3,"anchor":"Get-Rise-and-Set-Times"},{"syntax":"swift","type":"codeListing","code":["if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer) {","    print(\"Sunrise: \\(sunrise.date)\")","}","","if let sunset = try CelestialBody.sun.setTime(after: .now, from: observer) {","    print(\"Sunset: \\(sunset.date)\")","}"]},