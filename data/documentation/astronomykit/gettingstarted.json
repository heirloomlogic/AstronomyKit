{"abstract":[{"text":"Learn how to add AstronomyKit to your project and perform basic astronomical calculations.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"AstronomyKit provides a type-safe Swift interface for astronomical calculations. This article walks you through installation and your first calculations."}],"type":"paragraph"},{"level":2,"text":"Installation","type":"heading","anchor":"Installation"},{"inlineContent":[{"type":"text","text":"Add AstronomyKit to your Swift package:"}],"type":"paragraph"},{"syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/heirloomlogic\/AstronomyKit.git\", from: \"0.1.0\")","]"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Or in Xcode: "},{"type":"strong","inlineContent":[{"text":"File → Add Package Dependencies","type":"text"}]},{"type":"text","text":" and enter the repository URL."}],"type":"paragraph"},{"level":2,"text":"Your First Calculations","type":"heading","anchor":"Your-First-Calculations"},{"level":3,"text":"Import the Package","type":"heading","anchor":"Import-the-Package"},{"syntax":"swift","code":["import AstronomyKit"],"type":"codeListing"},{"level":3,"text":"Set Up Your Observer Location","type":"heading","anchor":"Set-Up-Your-Observer-Location"},{"inlineContent":[{"text":"Most astronomical calculations require an observer location on Earth:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ New York City","let observer = Observer(latitude: 40.7128, longitude: -74.0060)","","\/\/ With elevation (in meters)","let denver = Observer(latitude: 39.7392, longitude: -104.9903, height: 1609)"],"type":"codeListing"},{"level":3,"text":"Get the Current Time","type":"heading","anchor":"Get-the-Current-Time"},{"inlineContent":[{"text":"AstronomyKit uses ","type":"text"},{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstroTime","isActive":true,"type":"reference"},{"text":" for all time-based calculations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Current time","let now = AstroTime.now","","\/\/ From a specific date","let newYear = AstroTime(year: 2025, month: 1, day: 1, hour: 12)","","\/\/ From Foundation Date","let fromDate = AstroTime(Date())"],"type":"codeListing"},{"level":3,"text":"Calculate a Position","type":"heading","anchor":"Calculate-a-Position"},{"inlineContent":[{"type":"text","text":"Find where a celestial body appears in your sky:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Mars in the local sky","let mars = try CelestialBody.mars.horizon(at: .now, from: observer)","print(\"Altitude: \\(mars.altitude)°\")     \/\/ Height above horizon","print(\"Direction: \\(mars.compassDirection)\")  \/\/ N, NE, E, etc."],"type":"codeListing"},{"level":3,"text":"Find the Moon Phase","type":"heading","anchor":"Find-the-Moon-Phase"},{"syntax":"swift","code":["let angle = try Moon.phaseAngle(at: .now)","print(\"\\(Moon.emoji(for: angle)) \\(Moon.phaseName(for: angle))\")","\/\/ Output: 🌔 Waxing Gibbous"],"type":"codeListing"},{"level":3,"text":"Get Rise and Set Times","type":"heading","anchor":"Get-Rise-and-Set-Times"},{"syntax":"swift","code":["if let sunrise = try CelestialBody.sun.riseTime(after: .now, from: observer) {","    print(\"Sunrise: \\(sunrise.date)\")","}","","if let sunset = try CelestialBody.sun.setTime(after: .now, from: observer) {","    print(\"Sunset: \\(sunset.date)\")","}"],"type":"codeListing"},{"level":2,"text":"Error Handling","type":"heading","anchor":"Error-Handling"},{"inlineContent":[{"type":"text","text":"All potentially failing calculations throw "},{"type":"reference","isActive":true,"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/AstronomyError"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["do {","    let position = try CelestialBody.earth.horizon(at: .now, from: observer)","} catch AstronomyError.earthNotAllowed {","    print(\"Cannot observe Earth from Earth!\")","} catch {","    print(\"Calculation failed: \\(error)\")","}"],"type":"codeListing"},{"level":2,"text":"Next Steps","type":"heading","anchor":"Next-Steps"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers","isActive":true,"type":"reference"},{"text":" — Deep dive into time and location handling","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/CelestialPositions","type":"reference"},{"type":"text","text":" — Calculate positions for any celestial body"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/MoonPhases","type":"reference","isActive":true},{"type":"text","text":" — Explore moon phase calculations"}],"type":"paragraph"}]}]}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/TimeAndObservers"],"title":"Essentials","generated":true,"anchor":"Essentials"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/astronomykit\/gettingstarted"]}],"sections":[],"metadata":{"roleHeading":"Article","title":"Getting Started with AstronomyKit","modules":[{"name":"AstronomyKit"}],"role":"article"},"identifier":{"url":"doc:\/\/AstronomyKit\/documentation\/AstronomyKit\/GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/AstronomyKit\/documentation\/AstronomyKit"]]},"kind":"article","references":{"doc://AstronomyKit/documentation/AstronomyKit":{"url":"\/documentation\/astronomykit","type":"topic","abstract":[{"text":"Swift bindings for Don Cross’ ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cosinekitty\/astronomy"},{"tex